def calculate(expression):
    try:
        if not re.match(r'^[\d+\-*/().\s]+$', expression): return "❌ Символы!"
        result = eval(expression)
        return f"🧮 {expression} = {result}"
    except: return "❌ Ошибка!"

async def get_new_year_countdown():
    now = datetime.now()
    ny = datetime(now.year + 1, 1, 1, 0, 0, 0)
    diff = ny - now
    return diff.days, diff.seconds // 3600, (diff.seconds % 3600) // 60, diff.seconds % 60

