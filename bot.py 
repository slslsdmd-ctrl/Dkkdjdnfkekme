class MarriageManager:
    """УПРАВЛЕНИЕ БРАКАМИ И СЕМЬЯМИ"""
    
    def __init__(self):
        self.proposals = {}
        self.marriage_bonuses = {}
    
    async def propose(self, user_id: int, target_id: int, chat_id: int) -> dict:
        """ПРЕДЛОЖЕНИЕ БРАКА"""
        if user_id == target_id:
            return {'error': 'Нельзя жениться на себе!'}
        
        # Проверяем, не в браке ли уже
        married = await db.query(
            "SELECT spouse_id FROM marriages WHERE user_id = ? AND chat_id = ?",
            (user_id, chat_id),
            fetch_one=True
        )
        if married:
            return {'error': 'Ты уже в браке!'}
        
        # Проверяем, не в браке ли цель
        target_married = await db.query(
            "SELECT spouse_id FROM marriages WHERE user_id = ? AND chat_id = ?",
            (target_id, chat_id),
            fetch_one=True
        )
        if target_married:
            return {'error': 'Цель уже в браке!'}
        
        # Сохраняем предложение
        key = f"{chat_id}_{target_id}"
        self.proposals[key] = {
            'proposer': user_id,
            'target': target_id,
            'chat_id': chat_id,
            'time': datetime.now().isoformat()
        }
        
        return {
            'success': True,
            'proposer': user_id,
            'target': target_id,
            'message': f'💍 {await get_name(user_id)} предлагает брак {await get_name(target_id)}!'
        }
    
    async def accept_proposal(self, user_id: int, chat_id: int) -> dict:
        """ПРИНЯТИЕ ПРЕДЛОЖЕНИЯ"""
        key = f"{chat_id}_{user_id}"
        if key not in self.proposals:
            return {'error': 'Нет активного предложения!'}
        
        proposal = self.proposals[key]
        if proposal['target'] != user_id:
            return {'error': 'Это не тебе предлагают!'}
        
        # Создаём брак
        await db.query(
            "INSERT INTO marriages (user_id, chat_id, spouse_id, date) VALUES (?, ?, ?, ?)",
            (user_id, chat_id, proposal['proposer'], datetime.now().isoformat())
        )
        await db.query(
            "INSERT INTO marriages (user_id, chat_id, spouse_id, date) VALUES (?, ?, ?, ?)",
            (proposal['proposer'], chat_id, user_id, datetime.now().isoformat())
        )
        
        # Удаляем предложение
        del self.proposals[key]
        
        # Достижения
        await unlock_achievement(user_id, "first_marriage")
        await unlock_achievement(proposal['proposer'], "first_marriage")
        
        # Бонус (по 50 монет)
        await db.add_coins(user_id, 50)
        await db.add_coins(proposal['proposer'], 50)
        
        return {
            'success': True,
            'spouse1': user_id,
            'spouse2': proposal['proposer']
        }
    
    async def divorce(self, user_id: int, chat_id: int) -> dict:
        """РАЗВОД"""
        spouse = await db.query(
            "SELECT spouse_id FROM marriages WHERE user_id = ? AND chat_id = ?",
            (user_id, chat_id),
            fetch_one=True
        )
        if not spouse:
            return {'error': 'Ты не в браке!'}
        
        spouse_id = spouse['spouse_id']
        
        # Удаляем брак
        await db.query(
            "DELETE FROM marriages WHERE user_id = ? AND chat_id = ?",
            (user_id, chat_id)
        )
        await db.query(
            "DELETE FROM marriages WHERE user_id = ? AND chat_id = ?",
            (spouse_id, chat_id)
        )
        
        # Достижение
        await unlock_achievement(user_id, "divorce")
        
        # Штраф (50 монет)
        await db.add_coins(user_id, -50)
        
        return {
            'success': True,
            'spouse': spouse_id
        }
    
    async def get_spouse(self, user_id: int, chat_id: int) -> Optional[int]:
        """ПОЛУЧЕНИЕ СУПРУГА"""
        result = await db.query(
            "SELECT spouse_id FROM marriages WHERE user_id = ? AND chat_id = ?",
            (user_id, chat_id),
            fetch_one=True,
            cache_ttl=30
        )
        return result['spouse_id'] if result else None
    
    async def get_marriage_bonus(self, user_id: int, chat_id: int) -> float:
        """БОНУС ОТ БРАКА"""
        spouse = await self.get_spouse(user_id, chat_id)
        if not spouse:
            return 1.0
        
        # +5% к доходу
        return 1.05
    
    async def get_all_marriages(self, chat_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ ВСЕХ БРАКОВ В ЧАТЕ"""
        result = await db.query(
            "SELECT user_id, spouse_id, date FROM marriages WHERE chat_id = ?",
            (chat_id,),
            fetch_all=True,
            cache_ttl=60
        )
        return result or []

marriage_manager = MarriageManager()

