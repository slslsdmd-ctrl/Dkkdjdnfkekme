class MarketingSystem:
    """ПОЛНАЯ СИСТЕМА МАРКЕТИНГА"""
    
    def __init__(self):
        self.campaigns = {}
        self.ad_channels = {
            "телевидение": {"cost": 10000, "reach": 1000, "conversion": 0.05},
            "интернет": {"cost": 5000, "reach": 5000, "conversion": 0.03},
            "радио": {"cost": 3000, "reach": 2000, "conversion": 0.02},
            "наружная_реклама": {"cost": 8000, "reach": 3000, "conversion": 0.04},
            "соцсети": {"cost": 2000, "reach": 10000, "conversion": 0.01},
            "email": {"cost": 1000, "reach": 5000, "conversion": 0.02},
            "sms": {"cost": 500, "reach": 1000, "conversion": 0.01},
            "партизанский": {"cost": 100, "reach": 100, "conversion": 0.1},
        }
        self.campaign_stats = {}
    
    async def create_campaign(self, user_id: int, business_id: int, channel: str, budget: int) -> dict:
        """СОЗДАТЬ РЕКЛАМНУЮ КАМПАНИЮ"""
        if channel not in self.ad_channels:
            return {'error': 'Неизвестный канал! Доступно: ' + ', '.join(self.ad_channels.keys())}
        
        if budget <= 0:
            return {'error': 'Бюджет должен быть больше 0!'}
        
        business = await db.query(
            "SELECT * FROM businesses WHERE id = ? AND user_id = ?",
            (business_id, user_id),
            fetch_one=True
        )
        if not business:
            return {'error': 'Бизнес не найден!'}
        
        coins = await get_coins(user_id)
        if coins < budget:
            return {'error': f'Недостаточно монет! Нужно {budget}'}
        
        await remove_coins(user_id, budget)
        
        channel_data = self.ad_channels[channel]
        reach = int(channel_data['reach'] * (budget / channel_data['cost']))
        expected_conversions = int(reach * channel_data['conversion'])
        
        campaign_id = f"{user_id}_{business_id}_{int(datetime.now().timestamp())}"
        self.campaigns[campaign_id] = {
            'user_id': user_id,
            'business_id': business_id,
            'channel': channel,
            'budget': budget,
            'reach': reach,
            'conversions': expected_conversions,
            'started': datetime.now().isoformat(),
            'status': 'active',
            'roi': 0
        }
        
        # Сразу даём бонус к доходу
        income_boost = int(business['income'] * (expected_conversions / 1000))
        new_income = business['income'] + income_boost
        
        await db.query(
            "UPDATE businesses SET income = ? WHERE id = ?",
            (new_income, business_id)
        )
        
        return {
            'success': True,
            'campaign_id': campaign_id,
            'channel': channel,
            'budget': budget,
            'reach': reach,
            'conversions': expected_conversions,
            'income_boost': income_boost
        }
    
    async def get_campaigns(self, user_id: int) -> List[dict]:
        """ПОЛУЧИТЬ АКТИВНЫЕ КАМПАНИИ"""
        result = []
        for cid, campaign in self.campaigns.items():
            if campaign['user_id'] == user_id and campaign['status'] == 'active':
                result.append({
                    'id': cid,
                    'channel': campaign['channel'],
                    'budget': campaign['budget'],
                    'reach': campaign['reach'],
                    'conversions': campaign['conversions'],
                    'roi': campaign['roi']
                })
        return result
    
    async def calculate_roi(self, campaign_id: str) -> dict:
        """РАССЧИТАТЬ ROI КАМПАНИИ"""
        if campaign_id not in self.campaigns:
            return {'error': 'Кампания не найдена!'}
        
        campaign = self.campaigns[campaign_id]
        if campaign['status'] != 'active':
            return {'error': 'Кампания не активна!'}
        
        # Случайный ROI от 50% до 300%
        roi = random.uniform(0.5, 3.0)
        profit = int(campaign['budget'] * roi)
        
        campaign['roi'] = roi
        campaign['status'] = 'completed'
        
        # Начисляем прибыль
        await add_coins(campaign['user_id'], profit)
        
        return {
            'success': True,
            'campaign_id': campaign_id,
            'roi': f"{roi*100:.1f}%",
            'profit': profit,
            'budget': campaign['budget']
        }

