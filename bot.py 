    if not message.text:
        return

    text = message.text.strip()
    text_lower = text.lower()
    uid = message.from_user.id
    chat_id = message.chat.id

    if message.chat.type in ["group", "supergroup"]:
        await add_coins(uid, chat_id, 1)

    try:
        admins = await bot.get_chat_administrators(chat_id)
        for admin in admins:
            await set_role(admin.user.id, chat_id, 10)
    except:
        pass
    if uid == YOUR_ID:
        await set_role(uid, chat_id, 10)

    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id:
                await bot.send_message(chat_id, f"👑 **{BOT_NAME} активирован!**\nКоманды: `команды`", parse_mode=ParseMode.MARKDOWN)
                continue
            welcome_text = await get_welcome(chat_id)
            if welcome_text:
                await message.reply(welcome_text.replace("{имя}", user.first_name), parse_mode=ParseMode.MARKDOWN)
        return

    # Проверка обращений к боту
    is_reply_to_bot = message.reply_to_message and message.reply_to_message.from_user.id == bot.id
    is_mention = f"@{BOT_USERNAME}" in text_lower
    is_fable_call = "фабле" in text_lower or "fable" in text_lower
    
    if is_reply_to_bot or is_mention or is_fable_call:
        clean = text
        if is_mention:
            clean = re.sub(rf"@{BOT_USERNAME}", "", clean, flags=re.IGNORECASE).strip()
        else:
            clean = re.sub(r"(?i)\bфабле\b|\bfable\b", "", clean).strip()
        
        clean_lower = clean.lower()

        # Генерация картинок
        if clean_lower.startswith(("сгенерируй", "нарисуй", "фото", "покажи")):
            for prefix in ["сгенерируй", "нарисуй", "фото", "покажи"]:
                if clean_lower.startswith(prefix):
                    prompt = clean[len(prefix):].strip()
                    break
            if prompt:
                await bot.send_chat_action(chat_id, "upload_photo")
                msg = await message.reply("🎨 Генерирую...")
                image_url = await generate_image(prompt)
                if image_url:
                    try:
                        await bot.send_photo(chat_id, image_url, caption=f"🎨 {prompt}")
                        await msg.delete()
                    except:
                        await msg.edit_text(f"❌ Ошибка загрузки!\n{image_url}")
                else:
                    await msg.edit_text("❌ Не удалось сгенерировать.")
                return

        # Поиск
        if clean_lower.startswith(("найди", "поищи", "что такое", "кто такой", "расскажи про", "объясни", "сколько", "где", "когда", "почему", "как")):
            await bot.send_chat_action(chat_id, "typing")
            status_msg = await message.reply("🔍 Ищу...")
            result = await smart_web_search(clean)
            if result:
                txt = f"🔍 {result.get('source', '')}\n\n{result.get('extract', '')[:2000]}"
                if result.get('url'):
                    txt += f"\n\n🔗 {result['url']}"
                await status_msg.edit_text(txt, disable_web_page_preview=True)
            else:
                await status_msg.edit_text("❌ Ничего не найдено.")
            return

        if not clean:
            clean = "привет"

        await bot.send_chat_action(chat_id, "typing")
        reply = await ask_ai(clean)
        if reply:
            await message.reply(reply)
        return

    # ==================== РП КОМАНДЫ ====================
