async def bfg_clan_join(user_id: int, chat_id: int, name_or_id: str) -> str:
    """Вступить в клан (по названию или ID)"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    c.execute("SELECT id, name, members FROM bfg_clans WHERE chat_id = ?", (chat_id,))
    all_clans = c.fetchall()
    
    if not all_clans:
        conn.close()
        return "❌ В этом чате нет кланов! Создай: `создать клан Название`"
    
    found_clan = None
    search = name_or_id.strip().lower()
    
    for clan in all_clans:
        clan_id, clan_name, members = clan
        if str(clan_id) == search:
            found_clan = clan
            break
        if clan_name.lower() == search:
            found_clan = clan
            break
        if search in clan_name.lower():
            found_clan = clan
            break
    
    if not found_clan:
        clan_names = "\n".join([f"• {c[1]} (ID: {c[0]})" for c in all_clans])
        conn.close()
        return f"❌ Клан '{name_or_id}' не найден!\n\n📋 **Доступные кланы:**\n{clan_names}\n\n📝 Вступить: `вступить в клан Название`"
    
    cid, cname, members = found_clan[0], found_clan[1], found_clan[2].split(",") if found_clan[2] else []
    
    if str(user_id) in members:
        conn.close()
        return "❌ Ты уже в этом клане!"
    
    if c.execute("SELECT id FROM bfg_clans WHERE members LIKE ?", (f"%{user_id}%",)).fetchone():
        conn.close()
        return "❌ Ты уже состоишь в другом клане! Выйди сначала: `выйти из клана`"
    
    members.append(str(user_id))
    c.execute("UPDATE bfg_clans SET members = ? WHERE id = ?", (",".join(members), cid))
    conn.commit()
    conn.close()
    
    return f"✅ Ты вступил в клан **{cname}**! 🎉"

