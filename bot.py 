# Базовые функции БД
async def add_coins(uid,cid,amt):
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("INSERT INTO users VALUES(?,?,?)ON CONFLICT(user_id,chat_id)DO UPDATE SET coins=coins+?",(uid,cid,amt,amt));conn.commit();conn.close()

async def remove_coins(uid,cid,amt):
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("UPDATE users SET coins=MAX(0,coins-?)WHERE user_id=? AND chat_id=?",(amt,uid,cid));conn.commit();conn.close()

