    async def get_bonus(self, user_id: int) -> dict:
        """ПОЛУЧЕНИЕ ПРЕМИИ ЗА ДОСТИЖЕНИЯ"""
        profession = await self.get_profession(user_id)
        if not profession:
            return {'error': 'У тебя нет профессии!'}
        
        # Проверяем кулдаун (24 часа)
        last_bonus = await db.query(
            "SELECT last_bonus FROM users WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if last_bonus and last_bonus['last_bonus']:
            last_time = datetime.fromisoformat(last_bonus['last_bonus'])
            if (datetime.now() - last_time).days < 1:
                return {'error': '⏳ Премия доступна раз в 24 часа!'}
        
        # Получаем данные
        exp_result = await db.query(
            "SELECT level, work_count FROM professions WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        # Расчёт премии
        base_bonus = exp_result['level'] * 10
        work_bonus = (exp_result['work_count'] // 10) * 5
        total_bonus = base_bonus + work_bonus + random.randint(0, 100)
        
        # Начисляем
        await db.add_coins(user_id, total_bonus)
        
        # Обновляем кулдаун
        await db.query(
            "UPDATE users SET last_bonus = ? WHERE user_id = ?",
            (datetime.now().isoformat(), user_id)
        )
        
        return {
            'success': True,
            'bonus': total_bonus,
            'level_bonus': base_bonus,
            'work_bonus': work_bonus
        }
    
    # ============================================================
    # СМЕНА ПРОФЕССИИ
    # ============================================================
    
    async def change_profession(self, user_id: int, new_profession: str) -> dict:
        """СМЕНА ПРОФЕССИИ С СОХРАНЕНИЕМ СТАЖА"""
        if new_profession not in PROFESSIONS:
            return {'error': 'Профессия не найдена!'}
        
        current = await self.get_profession(user_id)
        if current == new_profession:
            return {'error': 'Ты уже работаешь по этой профессии!'}
        
        # Проверяем деньги на смену (50% зарплаты)
        if current:
            data = PROFESSIONS[current]
            avg_salary = (data['min'] + data['max']) // 2
            change_cost = avg_salary // 2
            
            coins = await db.get_coins(user_id)
            if coins < change_cost:
                return {'error': f'Недостаточно монет! Нужно {change_cost} для смены профессии!'}
            
            # Снимаем деньги
            await db.add_coins(user_id, -change_cost)
        
        # Сохраняем новую профессию с нулевым опытом
        await db.query(
            "INSERT OR REPLACE INTO professions (user_id, profession, experience, level, work_count, total_earned) VALUES (?, ?, 0, 1, 0, 0)",
            (user_id, new_profession)
        )
        
        # Очищаем кэш
        self.get_profession.cache_clear()
        
        return {
            'success': True,
            'profession': new_profession,
            'emoji': PROFESSIONS[new_profession]['emoji'],
            'desc': PROFESSIONS[new_profession]['desc']
        }
    
    # ============================================================
    # ПОЛУЧЕНИЕ СПИСКА ПРОФЕССИЙ
    # ============================================================
    
    def get_professions_list(self, category: str = None) -> List[dict]:
        """ПОЛУЧЕНИЕ СПИСКА ПРОФЕССИЙ"""
        result = []
        for name, data in PROFESSIONS.items():
            if category and data['category'] != category:
                continue
            result.append({
                'name': name,
                'emoji': data['emoji'],
                'desc': data['desc'],
                'min': data['min'],
                'max': data['max'],
                'category': data['category']
            })
        return sorted(result, key=lambda x: x['name'])
    
    def get_categories(self) -> List[str]:
        """ПОЛУЧЕНИЕ КАТЕГОРИЙ ПРОФЕССИЙ"""
        categories = set()
        for data in PROFESSIONS.values():
            categories.add(data['category'])
        return sorted(categories)

