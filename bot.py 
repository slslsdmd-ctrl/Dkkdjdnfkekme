# КЛАСС УПРАВЛЕНИЯ БИЗНЕСОМ
# ============================================================

class BusinessManager:
    """УПРАВЛЕНИЕ БИЗНЕСАМИ И ЗЕМЛЁЙ"""
    
    def __init__(self):
        self.business_cache = {}
    
    # ============================================================
    # ЗЕМЛЯ
    # ============================================================
    
    async def buy_land(self, user_id: int, land_type: str) -> dict:
        """ПОКУПКА ЗЕМЛИ"""
        if land_type not in LAND_TYPES:
            return {'error': 'Такого типа земли нет!'}
        
        data = LAND_TYPES[land_type]
        price = data['price']
        
        coins = await get_coins(user_id)
        if coins < price:
            return {'error': f'Недостаточно монет! Нужно {price}'}
        
        # Проверяем, есть ли уже земля
        existing = await db.query(
            "SELECT * FROM land WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if existing:
            await db.query(
                "UPDATE land SET land_type = ?, size = ?, price = ? WHERE user_id = ?",
                (land_type, data['size'], price, user_id)
            )
        else:
            await db.query(
                "INSERT INTO land (user_id, land_type, size, price) VALUES (?, ?, ?, ?)",
                (user_id, land_type, data['size'], price)
            )
        
        await remove_coins(user_id, price)
        
        return {
            'success': True,
            'land_type': land_type,
            'size': data['size'],
            'price': price,
            'emoji': data['emoji'],
            'desc': data['desc']
        }
    
    async def get_land(self, user_id: int) -> Optional[dict]:
        """ПОЛУЧЕНИЕ ЗЕМЛИ"""
        result = await db.query(
            "SELECT * FROM land WHERE user_id = ?",
            (user_id,),
            fetch_one=True,
            cache_ttl=30
        )
        return dict(result) if result else None
    
    async def rent_land(self, user_id: int, renter_id: int, price: int) -> dict:
        """СДАЧА ЗЕМЛИ В АРЕНДУ"""
        land = await self.get_land(user_id)
        if not land:
            return {'error': 'У тебя нет земли!'}
        
        if land.get('rented_to'):
            return {'error': 'Земля уже сдана в аренду!'}
        
        coins = await get_coins(renter_id)
        if coins < price:
            return {'error': f'У арендатора нет {price} монет!'}
        
        await remove_coins(renter_id, price)
        await add_coins(user_id, price)
        
        await db.query(
            "UPDATE land SET rented_to = ?, rent_price = ?, last_rent = ? WHERE user_id = ?",
            (renter_id, price, datetime.now().isoformat(), user_id)
        )
        
        return {
            'success': True,
            'renter': renter_id,
            'price': price,
            'land_type': land['land_type']
        }
    
    # ============================================================
    # БИЗНЕС
    # ============================================================
    
    async def create_business(self, user_id: int, business_name: str) -> dict:
        """СОЗДАНИЕ БИЗНЕСА"""
        if business_name not in BUSINESSES:
            return {'error': 'Такого бизнеса нет!'}
        
        existing = await db.query(
            "SELECT * FROM businesses WHERE user_id = ? AND name = ?",
            (user_id, business_name),
            fetch_one=True
        )
        if existing:
            return {'error': 'У тебя уже есть этот бизнес!'}
        
        data = BUSINESSES[business_name]
        price = data['price']
        required_land = data['land_size']
        
        land = await self.get_land(user_id)
        if not land:
            return {'error': 'У тебя нет земли! Купи землю: `купить землю [тип]`'}
        
        if land['size'] < required_land:
            return {'error': f'Недостаточно земли! Нужно {required_land} соток, у тебя {land["size"]}'}
        
        coins = await get_coins(user_id)
        if coins < price:
            return {'error': f'Недостаточно монет! Нужно {price}'}
        
        await remove_coins(user_id, price)
        
        await db.query(
