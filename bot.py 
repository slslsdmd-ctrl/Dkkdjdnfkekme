async def remove_item(user_id, chat_id, item_name, quantity=1):
    """Удаляет предмет из инвентаря"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute(
        "SELECT quantity FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?",
        (user_id, chat_id, item_name)
    )
    row = c.fetchone()
    if row and row[0] >= quantity:
        new_qty = row[0] - quantity
        if new_qty <= 0:
            c.execute(
                "DELETE FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?",
                (user_id, chat_id, item_name)
            )
        else:
            c.execute(
                "UPDATE inventory SET quantity = ? WHERE user_id = ? AND chat_id = ? AND item_name = ?",
                (new_qty, user_id, chat_id, item_name)
            )
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False


async def get_item_buffs(user_id, chat_id):
    """Получает все бафы от предметов"""
    items = await get_inventory(user_id, chat_id)
    buffs = {
        "buff_x": 1,
        "bonus_chance": 0,
        "bonus_amount": 0,
        "cooldown_reduce": 0,
        "protect_chance": 0,
        "rob_bonus": 0,
        "business_x": 1,
        "business_discount": 0,
        "passive_income": 0,
        "msg_bonus": 0,
    }
    
    for item_name, qty in items:
        if item_name in RARE_ITEMS:
            data = RARE_ITEMS[item_name]
            for key in buffs:
                if key in data:
                    if key in ["buff_x", "business_x"]:
                        buffs[key] = max(buffs[key], data[key])
                    else:
                        buffs[key] += data[key] * qty
    
    return buffs


async def deposit_bank(user_id, chat_id, amount):
    """Кладёт деньги в банк"""
    await remove_coins(user_id, chat_id, amount)
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute(
        "INSERT INTO bank (user_id, chat_id, balance, last_interest) VALUES (?,?,?,?) ON CONFLICT(user_id, chat_id) DO UPDATE SET balance = balance + ?, last_interest = ?",
        (user_id, chat_id, amount, now, amount, now)
    )
    conn.commit()
    conn.close()


async def withdraw_bank(user_id, chat_id, amount):
    """Снимает деньги из банка"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT balance FROM bank WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    if row and row[0] >= amount:
        c.execute(
            "UPDATE bank SET balance = balance - ? WHERE user_id = ? AND chat_id = ?",
            (amount, user_id, chat_id)
        )
        conn.commit()
        conn.close()
        await add_coins(user_id, chat_id, amount)
        return True
    conn.close()
    return False


