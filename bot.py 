            "UPDATE land SET land_type = ?, size = ?, price = ? WHERE user_id = ?",
            (next_type, next_data['size'], next_data['price'], user_id)
        )
        
        return {
            'error': False,
            'success': True,
            'old_type': current_type,
            'new_type': next_type,
            'new_size': next_data['size'],
            'cost': upgrade_cost
        }
    
