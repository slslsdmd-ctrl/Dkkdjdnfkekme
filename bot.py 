                return
        except:
            await message.reply("❌ Введи число!")
            return
        if args[1] == "положить":
            if await get_coins(message.from_user.id, message.chat.id) < amount:
                await message.reply("❌ Мало монет!")
                return
            await remove_coins(message.from_user.id, message.chat.id, amount)
            await add_to_clan_treasury(cid, message.chat.id, amount)
            await message.reply(f"💰 +{amount} в казну!")
        elif args[1] == "снять":
            if await get_clan_role(message.from_user.id, message.chat.id, cid) != "leader":
                await message.reply("❌ Только лидер может снимать!")
                return
            if await get_clan_treasury(cid, message.chat.id) < amount:
                await message.reply("❌ Мало в казне!")
                return
            conn = sqlite3.connect("fable_bot.db")
            c = conn.cursor()
            c.execute("UPDATE clans SET treasury = treasury - ? WHERE id = ?", (amount, cid))
            conn.commit()
            conn.close()
            await add_coins(message.from_user.id, message.chat.id, amount)
            await message.reply(f"💰 -{amount} из казны!")
        return

    if text_lower == "команды":
        await message.reply(
