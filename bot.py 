async def auto_moderate_message(chat_id: int, user_id: int, text: str) -> bool:
    """Автоматическая модерация сообщений"""
    try:
        # Проверяем на мат
        for word in BAD_WORDS:
            if word in text.lower():
                # Удаляем сообщение
                try:
                    await bot.delete_message(chat_id, message_id)  # message_id нужно передать
                except:
                    pass
                
                # Выдаём варн
                await add_warn(user_id, chat_id, 0, f"Автомод: мат ({word})")
                
                # Уведомляем пользователя
                try:
                    await bot.send_message(
                        user_id,
                        f"⚠️ **АВТОМАТИЧЕСКАЯ МОДЕРАЦИЯ!**\n\n"
                        f"Твоё сообщение было удалено за использование мата.\n"
                        f"📝 Слово: {word}\n"
                        f"⚠️ Ты получил варн!\n\n"
                        f"💡 Будь вежливее в чате!"
                    )
                except:
                    pass
                
                return True
        
        # Проверяем на спам (более 10 сообщений за минуту)
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT COUNT(*) FROM message_tags WHERE user_id = ? AND chat_id = ? AND timestamp > datetime('now', '-1 minute')", (user_id, chat_id))
        count = c.fetchone()[0]
        conn.close()
        
        if count > 10:
            try:
                await bot.restrict_chat_member(chat_id, user_id, ChatPermissions(can_send_messages=False), until_date=datetime.now() + timedelta(minutes=5))
                await bot.send_message(
                    user_id,
                    f"🔇 **ТЫ ЗАМУЧЕН!**\n\n"
                    f"Ты отправил слишком много сообщений за минуту.\n"
                    f"⏳ Мут на 5 минут!"
                )
            except:
                pass
            return True
        
        return False
    
    except Exception as e:
        log_error(e, "auto_moderate_message")
        return False

