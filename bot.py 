class EconomyManager:
    """ГЛАВНЫЙ МЕНЕДЖЕР ЭКОНОМИКИ"""
    
    def __init__(self):
        self.bank_rates = {}
        self.market_cache = {}
        self.last_market_update = {}
    
    # ============================================================
    # БАНК
    # ============================================================
    
    async def deposit(self, user_id: int, amount: int) -> dict:
        """ПОЛОЖИТЬ В БАНК"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        current_coins = await db.get_coins(user_id)
        if current_coins < amount:
            return {'error': f'Недостаточно монет! Есть {current_coins}'}
        
        # Снимаем монеты
        await db.add_coins(user_id, -amount)
        
        # Добавляем в банк
        current_balance = await db.get_bank_balance(user_id)
        new_balance = current_balance + amount
        
        await db.query(
            "INSERT OR REPLACE INTO bank (user_id, balance, last_interest) VALUES (?, ?, ?)",
            (user_id, new_balance, datetime.now().isoformat())
        )
        
        return {
            'success': True,
            'amount': amount,
            'new_balance': new_balance,
            'interest_rate': await self.get_interest_rate(user_id)
        }
    
    async def withdraw(self, user_id: int, amount: int) -> dict:
        """СНЯТЬ ИЗ БАНКА"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        current_balance = await db.get_bank_balance(user_id)
        if current_balance < amount:
            return {'error': f'Недостаточно в банке! Есть {current_balance}'}
        
        # Снимаем с банка
        new_balance = current_balance - amount
        
        await db.query(
            "UPDATE bank SET balance = ? WHERE user_id = ?",
            (new_balance, user_id)
        )
        
        # Добавляем монеты
        await db.add_coins(user_id, amount)
        
        return {
            'success': True,
            'amount': amount,
            'new_balance': new_balance
        }
    
    async def get_bank_balance(self, user_id: int) -> int:
        """ПОЛУЧЕНИЕ БАЛАНСА В БАНКЕ"""
        result = await db.query(
            "SELECT balance FROM bank WHERE user_id = ?",
            (user_id,),
            fetch_one=True,
            cache_ttl=30
        )
        return result['balance'] if result else 0
    
    async def get_interest_rate(self, user_id: int) -> float:
        """ПОЛУЧЕНИЕ ПРОЦЕНТНОЙ СТАВКИ"""
        base_rate = 0.10  # 10% базовых
        
        # Проверяем предметы
        has_gold_card = await db.query(
            "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = 'золотая_карта'",
            (user_id,),
            fetch_one=True,
            cache_ttl=60
        )
        if has_gold_card:
            base_rate += 0.05  # +5%
        
        return base_rate
    
    async def apply_bank_interest(self):
        """НАЧИСЛЕНИЕ ПРОЦЕНТОВ ПО БАНКУ (каждый час)"""
        while True:
            try:
                await asyncio.sleep(3600)
                
                # Получаем всех с балансом > 0
                users = await db.query(
                    "SELECT user_id, balance FROM bank WHERE balance > 0",
                    fetch_all=True
                )
                
                if not users:
                    continue
                
                for user in users:
                    user_id = user['user_id']
                    balance = user['balance']
                    
                    if balance <= 0:
                        continue
                    
                    # Получаем ставку
                    rate = await self.get_interest_rate(user_id)
                    interest = int(balance * rate)
                    
                    if interest > 0:
                        new_balance = balance + interest
                        
                        # Ограничиваем
                        if new_balance > MAX_COINS:
                            new_balance = MAX_COINS
                            interest = new_balance - balance
                        
                        # Обновляем
                        await db.query(
                            "UPDATE bank SET balance = ? WHERE user_id = ?",
                            (new_balance, user_id)
                        )
                        
                        # Логируем
                        await db.query(
                            "INSERT INTO bank_history (user_id, type, amount, date) VALUES (?, ?, ?, ?)",
                            (user_id, 'interest', interest, datetime.now().isoformat())
                        )
                
                logger.info(f"💳 Начислены проценты {len(users)} пользователям")
                
            except Exception as e:
                log_error(e, "apply_bank_interest")
                await asyncio.sleep(60)
    
    # ============================================================
    # ИНВЕСТИЦИИ
    # ============================================================
    
    async def invest(self, user_id: int, business_id: int, amount: int) -> dict:
        """ИНВЕСТИЦИЯ В БИЗНЕС"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        current_coins = await db.get_coins(user_id)
        if current_coins < amount:
            return {'error': f'Недостаточно монет! Есть {current_coins}'}
        
        # Получаем бизнес
        business = await db.query(
            "SELECT * FROM businesses WHERE id = ? AND user_id != ?",
            (business_id, user_id),
            fetch_one=True
        )
        if not business:
            return {'error': 'Бизнес не найден или ваш'}
        
        # Рассчитываем долю
        business_value = business['income'] * 1000
        share = amount / business_value
        
        if share > 0.5:
            return {'error': 'Доля не может превышать 50% бизнеса!'}
        
        # Снимаем монеты
        await db.add_coins(user_id, -amount)
        
        # Создаём инвестицию
        await db.query(
            """INSERT INTO investments (user_id, business_id, amount, share, date) 
               VALUES (?, ?, ?, ?, ?)""",
            (user_id, business_id, amount, share, datetime.now().isoformat())
        )
        
        return {
            'success': True,
            'business': business['name'],
            'amount': amount,
            'share': f"{share * 100:.1f}%"
        }
    
    async def get_investments(self, user_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ ИНВЕСТИЦИЙ"""
        result = await db.query(
            """SELECT i.*, b.name, b.income 
               FROM investments i 
               JOIN businesses b ON i.business_id = b.id 
               WHERE i.user_id = ?""",
            (user_id,),
            fetch_all=True,
            cache_ttl=60
        )
