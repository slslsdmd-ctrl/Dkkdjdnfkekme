def async_cache(ttl=300):
    """Декоратор для кэширования асинхронных функций"""
    def decorator(func):
        cache_dict = {}
        cache_times = {}
        
        @functools.wraps(func)
        async def wrapper(*args, **kwargs):
            key = str(args) + str(kwargs)
            now = time.time()
            
            if key in cache_dict and (now - cache_times.get(key, 0)) < ttl:
                return cache_dict[key]
            
            result = await func(*args, **kwargs)
            cache_dict[key] = result
            cache_times[key] = now
            return result
        
        return wrapper
    return decorator

