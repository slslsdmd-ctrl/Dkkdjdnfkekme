async def get_target_user(message: types.Message):
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    args = message.text.split()
    if len(args) > 1:
        target = args[1].replace("@", "")
        try:
            member = await message.chat.get_member((await bot.get_chat_member(message.chat.id, target)).user.id)
            return member.user.id
        except:
            return None
    return None

# ========== ОСНОВНОЙ ОБРАБОТЧИК ==========
@dp.message()
async def handle_all_messages(message: types.Message):
    if not message.text:
        return
    
    # ===== ПРИНУДИТЕЛЬНАЯ ВЫДАЧА 10 УРОВНЯ =====
    # ТЕБЕ
    if message.from_user.id == YOUR_ID:
        await set_role(message.from_user.id, message.chat.id, 10)
    
    # СОЗДАТЕЛЮ
    try:
        chat = await bot.get_chat(message.chat.id)
        creator = chat.creator
        if creator and message.from_user.id == creator.id:
            await set_role(message.from_user.id, message.chat.id, 10)
    except:
        pass
    
    # ==== СОХРАНЯЕМ СООБЩЕНИЯ ====
    if message.chat.type in ["group", "supergroup"]:
        await save_message(message.chat.id, message.from_user.id, 
                          message.from_user.username, message.text)
        if message.from_user.id != bot.id:
            chat_id = message.chat.id
            chat_msg_count[chat_id] = chat_msg_count.get(chat_id, 0) + 1
            await check_auto_message(chat_id)
    
    # ==== НОВЫЙ УЧАСТНИК ====
    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id:
                try:
                    chat = await bot.get_chat(message.chat.id)
                    admins = await bot.get_chat_administrators(message.chat.id)
                    
                    admin_names = []
                    for admin in admins:
                        await set_role(admin.user.id, message.chat.id, 10)
                        admin_names.append(f"@{admin.user.username or admin.user.first_name}")
                    
                    await set_role(message.from_user.id, message.chat.id, 10)
                    await set_role(YOUR_ID, message.chat.id, 10)
                    
                    await bot.send_message(
                        message.chat.id,
                        f"👑 **{BOT_NAME} активирован!**\n\n"
                        f"📋 Всем администраторам группы выдан 10 уровень!\n"
                        f"👥 Список: {', '.join(admin_names[:5])}\n\n"
                        f"🎯 Команды: `команды` для списка",
                        parse_mode=ParseMode.MARKDOWN
                    )
                except Exception as e:
                    print(f"Ошибка: {e}")
                continue
            
            if user.id == YOUR_ID:
                await set_role(user.id, message.chat.id, 10)
                await bot.send_message(
                    message.chat.id,
                    f"👑 Супер-админ @{user.username or user.first_name} получил 10 уровень!"
                )
                continue
            
            await save_join_date(user.id, message.chat.id)
            welcome_text = await get_welcome(message.chat.id)
            if welcome_text:
                welcome_text = welcome_text.replace("{имя}", user.first_name)
                await message.reply(welcome_text, parse_mode=ParseMode.MARKDOWN)
        return
    
    # ==== ЛИЧНЫЕ СООБЩЕНИЯ (СТАТИСТИКА) ====
    if message.chat.type == "private":
        if message.text and message.text.lower() == "/статистика":
            if message.from_user.id == YOUR_ID:
                chats, users, msgs = await get_bot_stats()
                await message.reply(
                    f"📊 **Статистика {BOT_NAME}:**\n\n"
                    f"📋 Чатов с ботом: {chats}\n"
                    f"👥 Всего пользователей: {users}\n"
                    f"💬 Всего сообщений: {msgs}\n"
                    f"👑 Твой уровень: 10 (супер-админ)",
                    parse_mode=ParseMode.MARKDOWN
                )
            else:
                await message.reply("❌ У тебя нет доступа к статистике!")
            return
    
    # ==== КОМАНДЫ В ГРУППЕ ====
    text = message.text.strip()
    text_lower = text.lower()
    
    # ===== +ПРИВЕТСТВИЕ =====
    if text.startswith("+приветствие"):
        if await get_role(message.from_user.id, message.chat.id) < 10:
            await message.reply("❌ Недостаточно прав! (нужен 10 уровень)")
            return
        parts = text.split(maxsplit=1)
        if len(parts) < 2:
            await message.reply("ℹ️ Использование: `+приветствие [текст]`\n\nПеременные: `{имя}`, `{username}`")
            return
        await set_welcome(message.chat.id, parts[1])
        await message.reply(f"✅ Приветствие установлено!")
        return
    
    # ===== +ПРАВИЛА =====
    if text.startswith("+правила"):
        if await get_role(message.from_user.id, message.chat.id) < 10:
            await message.reply("❌ Недостаточно прав! (нужен 10 уровень)")
            return
        parts = text.split(maxsplit=1)
        if len(parts) < 2:
            await message.reply("ℹ️ Использование: `+правила [текст]`")
            return
        await set_rules(message.chat.id, parts[1])
        await message.reply(f"✅ Правила установлены!")
        return
    
    # ===== ПРАВИЛА =====
    if text_lower == "правила":
        rules = await get_rules(message.chat.id)
        if rules:
            await message.reply(f"📋 **Правила чата:**\n\n{rules}", parse_mode=ParseMode.MARKDOWN)
        else:
            await message.reply("📋 Правила не установлены.")
        return
    
    # ===== КОМАНДЫ =====
    if text_lower == "команды":
        await message.reply(
            f"📋 **Все команды {BOT_NAME}:**\n\n"
            f"**👑 Уровни (10 уровень):**\n"
            f"• `повысить [N]` или `повысить @user N`\n"
            f"• `понизить [N]` или `понизить @user N`\n"
            f"• `разжаловать` или `разжаловать @user`\n"
            f"• `повысить макс` или `повысить @user макс`\n\n"
            f"**🔨 Модерация (10 уровень):**\n"
            f"• `мут [время]` или `мут @user [время]`\n"
            f"• `размут` или `размут @user`\n"
            f"• `бан [время]` или `бан @user [время]`\n"
            f"• `разбан` или `разбан @user`\n"
            f"• `кик [минуты]` или `кик @user [минуты]`\n"
            f"• `варн [причина]` или `варн @user [причина]`\n"
            f"• `снятьварн` или `снятьварн @user`\n\n"
            f"**👑 Награды:**\n"
            f"• `наградить [название]` или `наградить @user [название]` (2+ уровень)\n"
            f"• `-награда [название]` или `-награда @user [название]` (10 уровень)\n\n"
            f"**🎮 Игры:**\n"
            f"• `кубы` — ответь на сообщение\n"
            f"• `дуэль` — ответь на сообщение\n"
            f"• `кнб` — ответь на сообщение\n"
            f"• `монетка` — ответь на сообщение\n\n"
            f"**📊 Инфо:**\n"
            f"`профиль`, `топ`, `стат`, `админы`, `моя роль`, `правила`",
            parse_mode=ParseMode.MARKDOWN
        )
        return
    
    # ===== ПОВЫСИТЬ =====
    if text_lower.startswith("повысить"):
        if await get_role(message.from_user.id, message.chat.id) < 10:
            await message.reply("❌ Недостаточно прав! (нужен 10 уровень)")
            return
        target_id = await get_target_user(message)
        if not target_id:
            if not message.reply_to_message:
                await message.reply("ℹ️ Ответь на сообщение или укажи @username")
                return
            target_id = message.reply_to_message.from_user.id
        target_name = await get_name(target_id)
        args = text.split()
        current_level = await get_role(target_id, message.chat.id)
        if len(args) > 1 and args[1] == "макс" or (len(args) > 2 and args[2] == "макс"):
            new_level = 10
            if new_level == current_level:
                await message.reply(f"⚠️ У {target_name} уже макс уровень")
                return
            await set_role(target_id, message.chat.id, new_level)
            await message.reply(f"✅ {target_name} повышен до МАКСИМАЛЬНОГО уровня! ({current_level} → 10)")
            return
        try:
            num = None
            for arg in args[1:]:
                if arg.isdigit():
                    num = int(arg)
                    break
            up = num if num else 1
            if up < 1 or up > 10:
                await message.reply("⚠️ Можно повысить на число от 1 до 10 или `макс`")
                return
            new_level = min(current_level + up, 10)
            if new_level == current_level:
                await message.reply(f"⚠️ У {target_name} уже макс уровень")
                return
            await set_role(target_id, message.chat.id, new_level)
            await message.reply(f"✅ {target_name} повышен на {up} уровень! ({current_level} → {new_level})")
        except ValueError:
            await message.reply("⚠️ Укажи число от 1 до 10")
        return
    
    # ===== ПОНИЗИТЬ =====
