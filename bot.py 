class TimeSystem:
    """СИСТЕМА МИРОВОГО ВРЕМЕНИ"""
    
    def __init__(self):
        self.timezones = {
            "москва": "Europe/Moscow",
            "мск": "Europe/Moscow",
            "питер": "Europe/Moscow",
            "лондон": "Europe/London",
            "нью-йорк": "America/New_York",
            "чикаго": "America/Chicago",
            "лос-анджелес": "America/Los_Angeles",
            "сан-франциско": "America/Los_Angeles",
            "токио": "Asia/Tokyo",
            "пекин": "Asia/Shanghai",
            "гонконг": "Asia/Hong_Kong",
            "сингапур": "Asia/Singapore",
            "дубай": "Asia/Dubai",
            "берлин": "Europe/Berlin",
            "париж": "Europe/Paris",
            "рим": "Europe/Rome",
            "мадрид": "Europe/Madrid",
            "варшава": "Europe/Warsaw",
            "киев": "Europe/Kiev",
            "минск": "Europe/Minsk",
            "екатеринбург": "Asia/Yekaterinburg",
            "новосибирск": "Asia/Novosibirsk",
            "владивосток": "Asia/Vladivostok",
            "сидней": "Australia/Sydney",
            "мельбурн": "Australia/Melbourne",
            "окленд": "Pacific/Auckland",
            "гавайи": "Pacific/Honolulu",
            "таити": "Pacific/Tahiti",
        }
        self.cache = {}
        self.cache_ttl = 60  # 1 минута
    
    async def get_time(self, city: str) -> dict:
        """ПОЛУЧИТЬ ВРЕМЯ В ГОРОДЕ"""
        city_lower = city.lower().strip()
        
        # Проверяем кэш
        cache_key = f"time_{city_lower}"
        if cache_key in self.cache:
            data, timestamp = self.cache[cache_key]
            if (datetime.now() - timestamp).seconds < self.cache_ttl:
                return data
        
        # Пробуем найти город
        tz_name = None
        
        # Точное совпадение
        if city_lower in self.timezones:
            tz_name = self.timezones[city_lower]
        
        # Частичное совпадение
        if not tz_name:
            for key, value in self.timezones.items():
                if key in city_lower or city_lower in key:
                    tz_name = value
                    break
        
        if not tz_name:
            # Если город не найден - время МСК
            tz_name = "Europe/Moscow"
        
        try:
            import pytz
            tz = pytz.timezone(tz_name)
            now = datetime.now(tz)
            
            result = {
                "city": city,
                "time": now.strftime("%H:%M"),
                "date": now.strftime("%d.%m.%Y"),
                "weekday": self._get_weekday(now.weekday()),
                "timezone": tz_name,
                "is_day": 6 <= now.hour < 22
            }
            
            self.cache[cache_key] = (result, datetime.now())
            return result
            
        except:
            # Если ошибка - время МСК
            now = datetime.now()
            return {
                "city": city,
                "time": now.strftime("%H:%M"),
                "date": now.strftime("%d.%m.%Y"),
                "weekday": self._get_weekday(now.weekday()),
                "timezone": "Europe/Moscow",
                "is_day": 6 <= now.hour < 22
            }
    
    def _get_weekday(self, day: int) -> str:
        """ПОЛУЧИТЬ ДЕНЬ НЕДЕЛИ"""
        days = ["Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота", "Воскресенье"]
        return days[day]
    
    async def get_world_time(self) -> List[dict]:
        """ПОЛУЧИТЬ ВРЕМЯ В ОСНОВНЫХ ГОРОДАХ"""
        cities = ["москва", "лондон", "нью-йорк", "токио", "пекин", "дубай", "берлин", "париж", "сидней"]
        
        result = []
        for city in cities:
            time_data = await self.get_time(city)
            result.append({
                "city": city,
                "time": time_data["time"],
                "date": time_data["date"],
                "is_day": time_data["is_day"]
            })
        
        return result

time_system = TimeSystem()

