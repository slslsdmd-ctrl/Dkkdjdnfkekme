async def ask_groq(messages) -> str:
    if not GROQ_API_KEY:
        return None
    try:
        async with aiohttp.ClientSession() as session:
            headers = {"Authorization": f"Bearer {GROQ_API_KEY}", "Content-Type": "application/json"}
            payload = {"model": "llama3-70b-8192", "messages": messages, "temperature": 0.8, "max_tokens": 500}
            async with session.post("https://api.groq.com/openai/v1/chat/completions", json=payload, headers=headers, timeout=30) as resp:
                if resp.status == 200:
                    return (await resp.json())["choices"][0]["message"]["content"].strip()
    except:
        pass
    return None

async def ask_pollinations(messages) -> str:
    try:
        headers = {"Content-Type": "application/json"}
        if POLLINATIONS_API_KEY:
            headers["Authorization"] = f"Bearer {POLLINATIONS_API_KEY}"
        payload = {"model": "openai", "messages": messages, "temperature": 0.8, "max_tokens": 500}
        async with aiohttp.ClientSession() as session:
            async with session.post("https://gen.pollinations.ai/v1/chat/completions", json=payload, headers=headers, timeout=30) as resp:
                if resp.status == 200:
                    return (await resp.json())["choices"][0]["message"]["content"].strip()
    except:
        pass
    return None

async def ask_llm(prompt: str, reference_context: str = None, chat_id: int = None) -> str:
    messages = build_ai_messages(prompt, reference_context, chat_id)
    reply = await ask_groq(messages)
    if reply and len(reply) > 5:
        return reply
    reply = await ask_pollinations(messages)
    if reply and len(reply) > 5:
        return reply
    return None

def get_cached_answer(question: str) -> str:
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT answer FROM ai_cache WHERE question_hash = ?", (hashlib.md5(question.lower().encode()).hexdigest(),))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

def save_cached_answer(question: str, answer: str):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO ai_cache (question_hash, question, answer, timestamp) VALUES (?, ?, ?, ?)", (hashlib.md5(question.lower().encode()).hexdigest(), question, answer, datetime.now().isoformat()))
    conn.commit()
    conn.close()

async def ask_ai(prompt: str, chat_id: int = None, user_id: int = None) -> str:
    prompt = normalize_text(prompt)
    prompt_lower = prompt.lower()
    print(f"📝 {prompt}")
    if chat_id and user_id:
        await save_dialog(chat_id, user_id, "user", prompt)
    smart_local = get_local_smart_answer(prompt)
    if smart_local:
        return smart_local
    for key, answer in LOCAL_ANSWERS.items():
        if prompt_lower == key or prompt_lower.startswith(f"{key} "):
            return answer
    cached = get_cached_answer(prompt)
    if cached:
        return cached
    try:
        if needs_web_search(prompt):
            search_result = await smart_web_search(prompt)
            if search_result:
                reply = await ask_llm(prompt, reference_context=search_result.get('extract', ''), chat_id=chat_id)
                if reply and len(reply) > 5:
                    save_cached_answer(prompt, reply)
                    if chat_id:
                        await save_dialog(chat_id, 0, "assistant", reply)
                    return reply
        reply = await ask_llm(prompt, chat_id=chat_id)
        if reply and len(reply) > 5:
            save_cached_answer(prompt, reply)
            if chat_id:
                await save_dialog(chat_id, 0, "assistant", reply)
            return reply
    except Exception as e:
        print(f"AI error: {e}")
    return "Я не совсем понял. Можешь переформулировать? 🤔"

