async def send_duel_turn(chat_id, challenger, opponent, aim_bonus, turn):
    turn_name = "Первый игрок" if turn == challenger else "Второй игрок"
    keyboard = InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="🔫 СТРЕЛЯТЬ", callback_data=f"duel_shoot_{chat_id}_{turn}"),
            InlineKeyboardButton(text="🎯 ПРИЦЕЛИТЬСЯ", callback_data=f"duel_aim_{chat_id}_{turn}")
        ],
        [
            InlineKeyboardButton(text="⏭️ ПРОПУСТИТЬ", callback_data=f"duel_skip_{chat_id}_{turn}")
        ]
    ])
    await bot.send_message(
        chat_id,
        f"🔫 **ДУЭЛЬ!**\n\n"
        f"⚔️ {await get_name(challenger)} против {await get_name(opponent)}\n"
        f"🎲 Ход: **{turn_name}**\n"
        f"🎯 Бонус прицела: +{aim_bonus*10}%\n\n"
        f"👇 Выбери действие:",
        parse_mode=ParseMode.MARKDOWN,
        reply_markup=keyboard
    )

async def end_duel(chat_id, winner, loser, reason):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("DELETE FROM duels WHERE chat_id = ?", (chat_id,))
    conn.commit()
    conn.close()
    active_duels.discard((chat_id, winner, loser))
    active_duels.discard((chat_id, loser, winner))
    await bot.send_message(
        chat_id,
        f"🔫 **ДУЭЛЬ ЗАВЕРШЕНА!**\n\n"
        f"🏆 Победитель: {await get_name(winner)}!\n"
        f"💀 {reason}",
        parse_mode=ParseMode.MARKDOWN
    )

def get_knb_result(choice1, choice2):
    if choice1 == choice2:
        return "🤝 Ничья!"
    wins = {"камень": "ножницы", "ножницы": "бумага", "бумага": "камень"}
    if wins[choice1] == choice2:
        return "🏆 Победил первый игрок!"
    else:
        return "🏆 Победил второй игрок!"

async def get_target_user(message: types.Message):
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    args = message.text.split()
    if len(args) > 1:
        target = args[1].replace("@", "")
        try:
            member = await message.chat.get_member((await bot.get_chat_member(message.chat.id, target)).user.id)
            return member.user.id
        except:
            return None
    return None

