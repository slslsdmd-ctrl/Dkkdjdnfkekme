async def use_promocode(code: str, user_id: int, chat_id: int) -> str:
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT * FROM promocodes WHERE code = ?", (code.upper(),))
        promo = c.fetchone()
        if not promo:
            conn.close()
            return "❌ Промокод не найден!"
        if datetime.now() > datetime.fromisoformat(promo[6]):
            conn.close()
            return "❌ Промокод истёк!"
        if promo[5] >= promo[4]:
            conn.close()
            return "❌ Промокод больше не действует!"
        c.execute("SELECT id FROM promo_uses WHERE code = ? AND user_id = ? AND chat_id = ?", (code.upper(), user_id, chat_id))
        if c.fetchone():
            conn.close()
            return "❌ Ты уже использовал этот промокод!"
        if promo[2] > 0:
            await add_coins(user_id, chat_id, promo[2])
        if promo[3]:
            await add_item(user_id, chat_id, promo[3])
        c.execute("INSERT INTO promo_uses (code, user_id, chat_id) VALUES (?,?,?)", (code.upper(), user_id, chat_id))
        c.execute("UPDATE promocodes SET used_count = used_count + 1 WHERE code = ?", (code.upper(),))
        conn.commit()
        conn.close()
        result = "🎉 Промокод активирован!"
        if promo[2] > 0:
            result += f"\n💰 +{promo[2]} монет"
        if promo[3]:
            item_name = RARE_ITEMS.get(promo[3], {}).get("name", promo[3])
            result += f"\n🎁 +{item_name}"
        return result
    except Exception as e:
        log_error(e, "use_promocode")
        return "❌ Ошибка активации промокода!"

