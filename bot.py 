@dp.callback_query()
async def handle_callback(cb: CallbackQuery):
    """ОБРАБОТКА КНОПОК"""
    try:
        data = cb.data
        user_id = cb.from_user.id
        chat_id = cb.message.chat.id
        
        # Брак - Принять
        if data.startswith("marry_accept_"):
            parts = data.split("_")
            if len(parts) >= 4:
                proposer_id = int(parts[2])
                target_id = int(parts[3])
                
                if user_id != target_id:
                    await cb.answer("❌ Это не тебе предлагают!", show_alert=True)
                    return
                
                result = await accept_marriage(user_id, chat_id)
                
                if result.get('error'):
                    await cb.message.edit_text(f"❌ {result['message']}")
                else:
                    await cb.message.edit_text(
                        f"💍 **Поздравляем!**\n"
                        f"{await get_name(result['spouse1'], bot)} + {await get_name(result['spouse2'], bot)} теперь в браке! 🎉\n"
                        f"💰 +{format_large_number(result['bonus'])} монет каждому!",
                        parse_mode=ParseMode.MARKDOWN
                    )
            return
        
        # Брак - Отклонить
        if data.startswith("marry_reject_"):
            parts = data.split("_")
            if len(parts) >= 4:
                proposer_id = int(parts[2])
                target_id = int(parts[3])
                
                if user_id != target_id:
                    await cb.answer("❌ Это не тебе предлагают!", show_alert=True)
                    return
                
                result = await reject_marriage(user_id, chat_id)
                await cb.message.edit_text("❌ Предложение отклонено!")
            return
        
        await cb.answer()
        
    except Exception as e:
        await cb.answer("❌ Ошибка!")
        print(f"Callback error: {e}")

