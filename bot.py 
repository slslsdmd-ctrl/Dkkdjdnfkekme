        """ПОЛУЧЕНИЕ КЛАНА ПОЛЬЗОВАТЕЛЯ"""
        result = await db.query(
            "SELECT * FROM clans WHERE chat_id = ? AND members LIKE ?",
            (chat_id, f'%{user_id}%'),
            fetch_one=True,
            cache_ttl=30
        )
