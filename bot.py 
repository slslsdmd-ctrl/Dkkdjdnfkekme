cache = {}
cache_ttl = 300  # 5 минут

def get_cached(key):
    """ПОЛУЧИТЬ ИЗ КЭША"""
    if key in cache:
        value, timestamp = cache[key]
        if time.time() - timestamp < cache_ttl:
            return value
    return None

def set_cached(key, value):
    """СОХРАНИТЬ В КЭШ"""
    cache[key] = (value, time.time())

def clear_cache():
    """ОЧИСТИТЬ КЭШ"""
    cache.clear()

