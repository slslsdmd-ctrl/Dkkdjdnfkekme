SLOT_SYMBOLS = ["🍒", "🍋", "🍊", "🍇", "💎", "🎰", "⭐", "🔥", "🍉", "🍓"]
SLOT_VALUES = {
    "🍒": 1, "🍋": 2, "🍊": 3, "🍇": 4,
    "💎": 10, "🎰": 20, "⭐": 5, "🔥": 3,
    "🍉": 2, "🍓": 3
}

class SlotMachine:
    """СЛОТ-АВТОМАТ С ДЖЕКПОТОМ"""
    
    def __init__(self):
        self.jackpot = 0
        self.total_spins = 0
    
    async def spin(self, user_id: int, bet: int) -> dict:
        """ВРАЩЕНИЕ СЛОТОВ"""
        if bet <= 0:
            return {'error': 'Ставка должна быть больше 0!'}
        
        coins = await get_coins(user_id)
        if coins < bet:
            return {'error': f'Недостаточно монет! Есть {coins}'}
        
        await remove_coins(user_id, bet)
        self.total_spins += 1
        
        # Выбираем символы
        symbols = list(SLOT_SYMBOLS)
        weights = [1, 1, 1, 1, 0.3, 0.1, 0.5, 0.5, 0.8, 0.8]
        result = random.choices(symbols, weights=weights, k=3)
        
        # Расчёт выигрыша
        win = 0
        bonus = False
        
        # 3 одинаковых
        if result[0] == result[1] == result[2]:
            multiplier = SLOT_VALUES.get(result[0], 1)
            win = bet * multiplier
            
            # Джекпот
            if result[0] == "🎰":
                win += self.jackpot
                self.jackpot = 0
                bonus = True
            
            # Бонусная игра
            if result[0] == "💎":
                bonus = True
                win *= 2
        
        # 2 одинаковых
        elif result[0] == result[1] or result[1] == result[2]:
            symbol = result[0] if result[0] == result[1] else result[1]
            multiplier = SLOT_VALUES.get(symbol, 1)
            win = bet * (multiplier // 2)
        
        # Спецкомбинации
        if "💎" in result and "🎰" in result:
            win += bet * 5
            bonus = True
        
        if win > 0:
            await add_coins(user_id, win)
            self.jackpot += int(bet * 0.01)
        else:
            self.jackpot += int(bet * 0.02)
        
        # Проверяем достижение
        if win >= bet * 10:
            await unlock_achievement(user_id, "slot_jackpot")
        
        return {
            'success': True,
            'result': result,
            'win': win,
            'bet': bet,
            'jackpot': self.jackpot,
            'bonus': bonus
        }

