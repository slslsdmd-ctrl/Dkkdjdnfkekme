        words = text.split()
        currency_names = {
            "рублях": "RUB", "рублей": "RUB", "рубли": "RUB", "руб": "RUB",
            "долларах": "USD", "долларов": "USD", "доллар": "USD", "баксах": "USD", "$": "USD",
            "бунах": "BYN", "бел": "BYN", "byn": "BYN",
