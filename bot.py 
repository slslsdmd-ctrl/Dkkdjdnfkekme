async def poker_check(chat_id: int, user_id: int) -> str:
    """Пропустить ход в покере"""
    if chat_id not in POKER_GAMES:
        return "❌ В этом чате нет игры!"
    
    game = POKER_GAMES[chat_id]
    if user_id not in game["players"]:
        return "❌ Ты не в игре!"
    
    if game["players"][user_id].get("folded", False):
        return "❌ Ты уже сбросил карты!"
    
    if game["turn"] != user_id:
        return "❌ Сейчас не твой ход!"
    
    # Передаем ход следующему
    players = list(game["players"].keys())
    current_index = players.index(user_id)
    next_index = (current_index + 1) % len(players)
    game["turn"] = players[next_index]
    
    # Проверяем, все ли сделали чек
    checks = sum(1 for p in game["players"].values() if not p.get("folded", False))
    if checks == len([p for p in game["players"].values() if not p.get("folded", False)]):
        # Переходим к следующей фазе
        return await poker_next_phase(chat_id)
    
    return f"✅ {await get_name(user_id)} пропустил ход. Ход перешел к {await get_name(game['turn'])}"

async def poker_bet(chat_id: int, user_id: int, amount: int) -> str:
    """Сделать ставку в покере"""
    if chat_id not in POKER_GAMES:
        return "❌ В этом чате нет игры!"
    
    game = POKER_GAMES[chat_id]
    if user_id not in game["players"]:
        return "❌ Ты не в игре!"
    
    if game["players"][user_id].get("folded", False):
        return "❌ Ты уже сбросил карты!"
    
    if game["turn"] != user_id:
        return "❌ Сейчас не твой ход!"
    
    if amount < game["current_bet"]:
        return f"❌ Ставка должна быть минимум {game['current_bet']} монет!"
    
    if await get_coins(user_id) < amount:
        return f"❌ У тебя нет {amount} монет!"
    
    await remove_coins(user_id, amount)
    game["players"][user_id]["bet"] += amount
    game["pot"] += amount
    game["current_bet"] = amount
    game["last_raiser"] = user_id
    
    # Передаем ход следующему
    players = list(game["players"].keys())
    current_index = players.index(user_id)
    next_index = (current_index + 1) % len(players)
    game["turn"] = players[next_index]
    
    return f"💰 {await get_name(user_id)} поставил {amount} монет!\n"
    f"📊 Банк: {game['pot']} монет\n"
    f"Ход перешел к {await get_name(game['turn'])}"

async def poker_fold(chat_id: int, user_id: int) -> str:
    """Сбросить карты в покере"""
    if chat_id not in POKER_GAMES:
        return "❌ В этом чате нет игры!"
    
    game = POKER_GAMES[chat_id]
    if user_id not in game["players"]:
        return "❌ Ты не в игре!"
    
    if game["players"][user_id].get("folded", False):
        return "❌ Ты уже сбросил карты!"
    
    if game["turn"] != user_id:
        return "❌ Сейчас не твой ход!"
    
    game["players"][user_id]["folded"] = True
    
    # Проверяем, сколько осталось игроков
    active = [p for p in game["players"].values() if not p.get("folded", False)]
    if len(active) == 1:
        # Один игрок выигрывает
        winner = [uid for uid, p in game["players"].items() if not p.get("folded", False)][0]
        await add_coins(winner, game["pot"])
        result = f"🏆 {await get_name(winner)} выигрывает {game['pot']} монет!"
        del POKER_GAMES[chat_id]
        return result
    
    # Передаем ход следующему
    players = [uid for uid in game["players"].keys() if not game["players"][uid].get("folded", False)]
    current_index = players.index(user_id)
    next_index = (current_index + 1) % len(players)
    game["turn"] = players[next_index]
    
    return f"❌ {await get_name(user_id)} сбросил карты. Ход перешел к {await get_name(game['turn'])}"

async def poker_showdown(chat_id: int) -> str:
    """Показывает результаты в покере"""
    if chat_id not in POKER_GAMES:
        return "❌ В этом чате нет игры!"
    
    game = POKER_GAMES[chat_id]
    
    # Оцениваем руки всех игроков
    results = {}
    for uid, data in game["players"].items():
        if not data.get("folded", False):
            hand = data["hand"]
            community = game["community"]
            results[uid] = evaluate_poker_hand(hand, community)
    
    if not results:
        return "❌ Нет активных игроков!"
    
    # Находим победителя
    winner = max(results.items(), key=lambda x: x[1]["rank"])
    winner_id, winner_hand = winner
    
    await add_coins(winner_id, game["pot"])
    
    result = f"🃏 **ШАУДАУН!**\n\n"
    result += f"📊 Общие карты: {', '.join(game['community'])}\n\n"
    
    for uid, hand in results.items():
        cards = ', '.join(game["players"][uid]["hand"])
        result += f"👤 {await get_name(uid)}: {cards} — {hand['name']}\n"
    
    result += f"\n🏆 **ПОБЕДИТЕЛЬ: {await get_name(winner_id)}**\n"
    result += f"💰 Выигрыш: {game['pot']} монет!"
    
    del POKER_GAMES[chat_id]
    return result

