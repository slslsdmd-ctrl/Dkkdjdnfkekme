        await callback.answer(f"✅ Ты выбрал: {choice}")
        choice1 = knb_choices.get((chat_id, player1))
        choice2 = choice
        result = get_knb_result(choice1, choice2)
        if "первый" in result:
            winner = player1
            result_text = f"🏆 Победил: {await get_name(winner)}!\n{result}"
        elif "второй" in result:
            winner = player2
            result_text = f"🏆 Победил: {await get_name(winner)}!\n{result}"
        else:
            result_text = f"🤝 {result}"
        await callback.message.edit_text(text=f"✊✌️✋ **Результат игры:**\n\n📌 {await get_name(player1)} выбрал: **{choice1}**\n📌 {await get_name(player2)} выбрал: **{choice2}**\n\n{result_text}", parse_mode=ParseMode.MARKDOWN, reply_markup=None)
        active_knb.discard(game_key)
        knb_choices.pop((chat_id, player1), None)
        knb_choices.pop((chat_id, player2), None)

@dp.callback_query(lambda c: c.data.startswith("coin_"))
async def coin_callback(callback: types.CallbackQuery):
    data = callback.data.split("_")
    if len(data) < 6:
        await callback.answer("❌ Ошибка в данных!", show_alert=True)
        return
    _, chat_id, player1, player2, choice = data
    chat_id = int(chat_id)
    player1 = int(player1)
    player2 = int(player2)
    user_id = callback.from_user.id
    if user_id != player1 and user_id != player2:
        await callback.answer("❌ Это не твоя игра!", show_alert=True)
        return
    game_key = (chat_id, player1, player2)
    if game_key not in active_coin:
        await callback.answer("❌ Игра уже завершена!", show_alert=True)
        return
    if user_id == player1:
        coin_choices[(chat_id, player1)] = choice
        await callback.answer(f"✅ Ты выбрал: {choice}")
        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="🪙 ОРЁЛ", callback_data=f"coin_{chat_id}_{player1}_{player2}_орёл"),
             InlineKeyboardButton(text="🪙 РЕШКА", callback_data=f"coin_{chat_id}_{player1}_{player2}_решка")]
        ])
        await callback.message.edit_text(text=f"🪙 **{await get_name(player1)}** вызывает **{await get_name(player2)}** на **Монетку**!\n\n🎲 **{await get_name(player2)}**, теперь твой выбор:", parse_mode=ParseMode.MARKDOWN, reply_markup=keyboard)
    else:
        coin_choices[(chat_id, player2)] = choice
        await callback.answer(f"✅ Ты выбрал: {choice}")
        choice1 = coin_choices.get((chat_id, player1))
        choice2 = choice
        result = random.choice(["орёл", "решка"])
        if choice1 == result and choice2 == result:
            result_text = f"🤝 Ничья! Оба выбрали {result}"
        elif choice1 == result:
            winner = player1
            result_text = f"🏆 Победил: {await get_name(winner)}! (выбрал {choice1}, выпало {result})"
        elif choice2 == result:
            winner = player2
            result_text = f"🏆 Победил: {await get_name(winner)}! (выбрал {choice2}, выпало {result})"
        else:
            result_text = f"😅 Никто не угадал! Выпало {result}"
        await callback.message.edit_text(text=f"🪙 **Результат игры в Монетку:**\n\n📌 {await get_name(player1)} выбрал: **{choice1}**\n📌 {await get_name(player2)} выбрал: **{choice2}**\n\n🪙 Выпало: **{result}**\n\n{result_text}", parse_mode=ParseMode.MARKDOWN, reply_markup=None)
        active_coin.discard(game_key)
        coin_choices.pop((chat_id, player1), None)
        coin_choices.pop((chat_id, player2), None)

