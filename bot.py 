async def ask_ai(prompt: str, username: str) -> str:
    """Генерация живого ответа через Groq."""
    
    # Проверяем цензуру (запрещённые темы)
    dangerous_topics = [
        "бомб", "взрывчатк", "оружи", "наркотик", "героин", "кокаин", "марихуан",
        "убить", "смерть", "самоубийств", "как сделать", "как собрать", "инструкци"
    ]
    
    msg = prompt.lower()
    
    # Если запрос касается опасных тем — даём вежливый, но полезный ответ
    for word in dangerous_topics:
        if word in msg:
            responses = [
