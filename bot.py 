def build_ai_messages(prompt: str, reference_context: str = None):
    messages = [{"role": "system", "content": "Ты — Fable, дружелюбный ИИ-помощник в Telegram. Отвечай на русском языке кратко, но информативно. Будь вежливым и полезным."}]
