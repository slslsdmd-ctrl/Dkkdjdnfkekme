def detect_emotion(text: str) -> str:
    text_lower = text.lower()
    if any(w in text_lower for w in ["хаха", "ахах", "лол", "кек", "смешно", "😂", "🤣", "ору", "ржу"]):
        return "радость"
    if any(w in text_lower for w in ["грустно", "печаль", "жаль", "плохо", "😢", "😭", "тоска"]):
        return "грусть"
    if any(w in text_lower for w in ["бесит", "злюсь", "гнев", "ярость", "🤬", "ненавижу"]):
        return "злость"
    if any(w in text_lower for w in ["ого", "вау", "ничего себе", "😱", "🤯", "офигеть"]):
        return "удивление"
    if any(w in text_lower for w in ["страшно", "боюсь", "ужас", "😨", "жуть"]):
        return "страх"
    if any(w in text_lower for w in ["люблю", "обожаю", "❤️", "😍", "милый"]):
        return "любовь"
    return None

