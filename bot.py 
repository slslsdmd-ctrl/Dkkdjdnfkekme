                'success': True,
                'result': 'finished',
                'score': game['score'],
                'total': game['total'],
                'reward': reward
            }
        
        next_q = game['questions'][game['current']]
        return {
            'error': False,
            'success': True,
            'result': result,
            'score': game['score'],
            'current': game['current'] + 1,
            'total': game['total'],
            'question': next_q['q'],
            'answers': next_q['answers']
        }

