class AIManager:
    """УПРАВЛЕНИЕ ИСКУССТВЕННЫМ ИНТЕЛЛЕКТОМ"""
    
    def __init__(self):
        self.cache = {}
        self.contexts = {}
        self.beliefs = {}
        self.learning = {}
        self.stats = {'requests': 0, 'cache_hits': 0, 'cache_misses': 0}
    
    # ============================================================
    # ОСНОВНЫЕ AI ФУНКЦИИ
    # ============================================================
    
    async def ask(self, prompt: str, user_id: int = None, chat_id: int = None) -> str:
        """ГЛАВНЫЙ AI ЗАПРОС"""
        self.stats['requests'] += 1
        
        # Проверяем кэш
        cache_key = hashlib.md5(prompt.lower().encode()).hexdigest()
        if cache_key in self.cache:
            cache_time, cached_answer = self.cache[cache_key]
            if (datetime.now() - cache_time).seconds < 86400:  # 24 часа
                self.stats['cache_hits'] += 1
                return cached_answer
        
        self.stats['cache_misses'] += 1
        
        # Проверяем базу знаний
        kb_answer = self.search_knowledge(prompt)
        if kb_answer:
            self.cache[cache_key] = (datetime.now(), kb_answer)
            return kb_answer
        
        # Проверяем эмоции
        emotion_answer = self.detect_emotion(prompt)
        if emotion_answer:
            self.cache[cache_key] = (datetime.now(), emotion_answer)
            return emotion_answer
        
        # Проверяем мнения
        belief_answer = self.get_belief(prompt)
        if belief_answer:
            self.cache[cache_key] = (datetime.now(), belief_answer)
            return belief_answer
        
        # Запрос к API
        try:
            # Параллельные запросы
            results = await asyncio.gather(
                self._ask_groq(prompt),
                self._ask_deepseek(prompt),
                return_exceptions=True
            )
            
            for result in results:
                if result and isinstance(result, str) and len(result) > 3:
                    self.cache[cache_key] = (datetime.now(), result)
                    return result
            
            return "🤔 Интересный вопрос! Дай мне подумать... Может переформулируешь?"
            
        except Exception as e:
            log_error(e, "AI ask")
            return "⚠️ Что-то пошло не так, но я уже работаю над этим! 🔥"
    
    # ============================================================
    # ПОИСК В БАЗЕ ЗНАНИЙ
    # ============================================================
    
    def search_knowledge(self, prompt: str) -> Optional[str]:
        """ПОИСК В БАЗЕ ЗНАНИЙ"""
        prompt_lower = prompt.lower().strip()
        
        # Точное совпадение
        if prompt_lower in KNOWLEDGE_BASE:
            return random.choice(KNOWLEDGE_BASE[prompt_lower])
        
        # Частичное совпадение
        for key, answers in KNOWLEDGE_BASE.items():
            if key in prompt_lower or prompt_lower in key:
                return random.choice(answers)
        
        return None
    
