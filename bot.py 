        c.execute("DELETE FROM bfg_stocks WHERE user_id = ? AND chat_id = ? AND stock = ?", (user_id, chat_id, stock_name))
    else:
        c.execute("UPDATE bfg_stocks SET quantity = quantity - ? WHERE user_id = ? AND chat_id = ? AND stock = ?", (quantity, user_id, chat_id, stock_name))
    conn.commit()
    conn.close()
    await add_coins(user_id, chat_id, int(total))
    return f"✅ Продано {quantity} акций {data['name']} за {total:.2f} монет!"

async def bfg_my_stocks(user_id: int, chat_id: int) -> str:
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT stock, quantity FROM bfg_stocks WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    rows = c.fetchall()
    conn.close()
    if not rows:
        return "📊 У тебя нет акций!"
    txt = "📊 **Мои акции**\n\n"
    total = 0
    for stock, quantity in rows:
        if stock in STOCKS:
            data = STOCKS[stock]
            value = data["price"] * quantity
            txt += f"{data['emoji']} {data['name']}: {quantity} шт. (💰{value:.2f})\n"
            total += value
    txt += f"\n💰 Общая стоимость: **{total:.2f}** монет"
    return txt

