async def add_coins(user_id: int, amount: int):
    """Добавляет монеты глобально (без привязки к чату)"""
    if amount <= 0:
        return
    
    for attempt in range(3):
        try:
            conn = sqlite3.connect("fable_bot.db", timeout=10)
            c = conn.cursor()
            c.execute("SELECT coins FROM users WHERE user_id = ?", (user_id,))
            row = c.fetchone()
            
            if row:
                new_amount = row[0] + amount
                if new_amount > MAX_COINS:
                    new_amount = MAX_COINS
                c.execute("UPDATE users SET coins = ? WHERE user_id = ?", (new_amount, user_id))
            else:
                initial_coins = min(amount, MAX_COINS)
                c.execute("INSERT INTO users (user_id, coins) VALUES (?, ?)", (user_id, initial_coins))
            
            conn.commit()
            conn.close()
            return
        
        except sqlite3.OperationalError as e:
            if "database is locked" in str(e):
                await asyncio.sleep(0.5)
            else:
                log_error(e, "add_coins")
                return
        except Exception as e:
            log_error(e, "add_coins")
            return

async def remove_coins(user_id: int, amount: int):
    """Снимает монеты глобально"""
    if amount <= 0:
        return
    
    for attempt in range(3):
        try:
            conn = sqlite3.connect("fable_bot.db", timeout=10)
            c = conn.cursor()
            c.execute("SELECT coins FROM users WHERE user_id = ?", (user_id,))
            row = c.fetchone()
            
            if row:
                new_amount = max(0, row[0] - amount)
                c.execute("UPDATE users SET coins = ? WHERE user_id = ?", (new_amount, user_id))
            
            conn.commit()
            conn.close()
            return
        
        except sqlite3.OperationalError as e:
            if "database is locked" in str(e):
                await asyncio.sleep(0.5)
            else:
                log_error(e, "remove_coins")
                return
        except Exception as e:
            log_error(e, "remove_coins")
            return

