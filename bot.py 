    # ============================================================
    
    async def donate_treasury(self, user_id: int, chat_id: int, amount: int) -> dict:
        """ПОПОЛНЕНИЕ КЛАНОВОЙ КАЗНЫ"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        coins = await db.get_coins(user_id)
        if coins < amount:
            return {'error': f'Недостаточно монет! Есть {coins}'}
        
        await db.add_coins(user_id, -amount)
        
        await db.query(
            "UPDATE clans SET treasury = treasury + ? WHERE id = ?",
            (amount, clan['id'])
        )
        
        return {
            'success': True,
            'clan': clan['name'],
            'amount': amount,
            'treasury': clan['treasury'] + amount
        }
    
    # ============================================================
    # ВОЙНЫ КЛАНОВ
    # ============================================================
    
    async def start_war(self, chat_id: int, user_id: int, clan1_id: int, clan2_id: int) -> dict:
        """НАЧАЛО ВОЙНЫ МЕЖДУ КЛАНАМИ"""
        # Проверяем, что пользователь - лидер
        clan1 = await self.get_clan_by_id(clan1_id)
        if not clan1:
            return {'error': 'Клан 1 не найден!'}
        
        if clan1['owner_id'] != user_id:
            return {'error': 'Только лидер клана может начать войну!'}
        
        # Проверяем, не идёт ли уже война
        war_key = f"{chat_id}_{clan1_id}_{clan2_id}"
        if war_key in self.wars:
            return {'error': 'Война уже идёт!'}
        
        # Проверяем кулдаун
        cooldown_key = f"{chat_id}_{clan1_id}"
        if cooldown_key in self.war_cooldowns:
            last_war = self.war_cooldowns[cooldown_key]
            if (datetime.now() - last_war).days < 1:
                return {'error': '⏳ Клан может начинать войну раз в день!'}
        
        clan2 = await self.get_clan_by_id(clan2_id)
        if not clan2:
            return {'error': 'Клан 2 не найден!'}
        
        self.wars[war_key] = {
            'clan1': clan1_id,
            'clan2': clan2_id,
            'chat_id': chat_id,
            'status': 'active',
            'score1': 0,
            'score2': 0,
            'started': datetime.now().isoformat(),
            'battles': []
        }
        
        self.war_cooldowns[cooldown_key] = datetime.now()
        
        return {
            'success': True,
            'clan1': clan1['name'],
            'clan2': clan2['name'],
            'status': 'active'
        }
    
    async def war_battle(self, chat_id: int, user_id: int) -> dict:
        """БИТВА В ВОЙНЕ КЛАНОВ"""
        # Находим активную войну
        war = None
        war_key = None
        for key, w in self.wars.items():
            if w['chat_id'] == chat_id and w['status'] == 'active':
                war = w
                war_key = key
                break
        
        if not war:
            return {'error': 'Нет активной войны!'}
        
        # Проверяем, что пользователь в одном из кланов
        clan1 = await self.get_clan_by_id(war['clan1'])
        clan2 = await self.get_clan_by_id(war['clan2'])
        
        if not clan1 or not clan2:
            return {'error': 'Кланы не найдены!'}
        
        members1 = clan1['members'].split(',') if clan1['members'] else []
        members2 = clan2['members'].split(',') if clan2['members'] else []
        
        user_in_clan1 = str(user_id) in members1
        user_in_clan2 = str(user_id) in members2
        
        if not user_in_clan1 and not user_in_clan2:
            return {'error': 'Ты не участвуешь в войне!'}
        
        # Находим противника из другого клана
        enemy_members = members2 if user_in_clan1 else members1
        if not enemy_members:
            return {'error': 'Вражеский клан пуст!'}
        
        enemy_id = int(random.choice(enemy_members))
        
        # Расчёт силы
        user_power = random.randint(1, 20) + (await db.query(
            "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = 'меч'",
            (user_id,),
            fetch_one=True
        ) or {}).get('quantity', 0) * 2
        
        enemy_power = random.randint(1, 20) + (await db.query(
            "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = 'меч'",
            (enemy_id,),
            fetch_one=True
        ) or {}).get('quantity', 0) * 2
        
        # Битва
        if user_power > enemy_power:
            if user_in_clan1:
                war['score1'] += 1
            else:
                war['score2'] += 1
            result = f"🏆 {await get_name(user_id)} победил {await get_name(enemy_id)}!"
        else:
            if user_in_clan1:
                war['score2'] += 1
            else:
                war['score1'] += 1
            result = f"💀 {await get_name(enemy_id)} победил {await get_name(user_id)}!"
        
        war['battles'].append(result)
        
        # Проверяем победу (до 5)
        if war['score1'] >= 5 or war['score2'] >= 5:
            winner_id = war['clan1'] if war['score1'] >= 5 else war['clan2']
            winner_name = clan1['name'] if war['score1'] >= 5 else clan2['name']
            prize = war['score1'] * 100 if war['score1'] >= 5 else war['score2'] * 100
            
            # Награждаем победивший клан
            await db.query(
                "UPDATE clans SET treasury = treasury + ? WHERE id = ?",
                (prize, winner_id)
            )
            
            # Завершаем войну
            war['status'] = 'finished'
            self.wars[war_key] = war
            
            return {
                'success': True,
                'finished': True,
                'winner': winner_name,
                'prize': prize,
                'score': f"{clan1['name']} {war['score1']} - {war['score2']} {clan2['name']}",
                'battles': war['battles'][-5:]
            }
        
        return {
            'success': True,
            'finished': False,
            'result': result,
            'score': f"{clan1['name']} {war['score1']} - {war['score2']} {clan2['name']}"
        }
    
    # ============================================================
    # АЛЬЯНСЫ
    # ============================================================
    
    async def create_alliance(self, chat_id: int, user_id: int, clan1_id: int, clan2_id: int) -> dict:
        """СОЗДАНИЕ АЛЬЯНСА"""
        # Проверяем, что пользователь - лидер
        clan1 = await self.get_clan_by_id(clan1_id)
        if not clan1:
            return {'error': 'Клан 1 не найден!'}
        
        if clan1['owner_id'] != user_id:
            return {'error': 'Только лидер клана может создать альянс!'}
        
        clan2 = await self.get_clan_by_id(clan2_id)
        if not clan2:
            return {'error': 'Клан 2 не найден!'}
        
        # Проверяем, что кланы не воюют
        for war in self.wars.values():
            if war['status'] == 'active':
                if (war['clan1'] == clan1_id and war['clan2'] == clan2_id) or \
                   (war['clan1'] == clan2_id and war['clan2'] == clan1_id):
                    return {'error': 'Кланы находятся в состоянии войны!'}
        
        # Создаём альянс
        if chat_id not in self.alliances:
            self.alliances[chat_id] = []
        
        # Проверяем, не в альянсе ли уже
        for alliance in self.alliances[chat_id]:
            if clan1_id in alliance or clan2_id in alliance:
                return {'error': 'Один из кланов уже в альянсе!'}
        
        self.alliances[chat_id].append([clan1_id, clan2_id])
        
        return {
            'success': True,
            'clan1': clan1['name'],
            'clan2': clan2['name']
        }
    
    async def break_alliance(self, chat_id: int, user_id: int, clan1_id: int, clan2_id: int) -> dict:
        """РАСТОРЖЕНИЕ АЛЬЯНСА"""
        if chat_id not in self.alliances:
            return {'error': 'Нет альянсов!'}
        
        clan1 = await self.get_clan_by_id(clan1_id)
        if not clan1:
            return {'error': 'Клан 1 не найден!'}
        
        if clan1['owner_id'] != user_id:
            return {'error': 'Только лидер клана может расторгнуть альянс!'}
        
        for i, alliance in enumerate(self.alliances[chat_id]):
            if clan1_id in alliance and clan2_id in alliance:
                del self.alliances[chat_id][i]
                
                clan2 = await self.get_clan_by_id(clan2_id)
                return {
                    'success': True,
                    'message': f'Альянс между {clan1["name"]} и {clan2["name"]} расторгнут!'
                }
        
        return {'error': 'Альянс не найден!'}
    
    async def get_alliances(self, chat_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ СПИСКА АЛЬЯНСОВ"""
        if chat_id not in self.alliances:
            return []
        
        alliances = []
        for alliance in self.alliances[chat_id]:
            clan1 = await self.get_clan_by_id(alliance[0])
            clan2 = await self.get_clan_by_id(alliance[1])
            if clan1 and clan2:
                alliances.append({
                    'clan1': clan1['name'],
                    'clan2': clan2['name'],
                    'clan1_id': alliance[0],
                    'clan2_id': alliance[1]
                })
        
        return alliances

clan_manager = ClanManager()

