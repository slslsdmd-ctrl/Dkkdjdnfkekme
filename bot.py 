async def roulette_shoot(chat_id, player_id, opponent_id):
    player_name = await get_name(player_id)
    opponent_name = await get_name(opponent_id)
    if player_id not in roulette_games or opponent_id not in roulette_games:
        await bot.send_message(chat_id, "❌ Игра завершена!")
        return
    bullets = roulette_games[player_id].get("bullets", [])
    if not bullets:
        await bot.send_message(chat_id, "🤝 Ничья!")
        roulette_games.clear()
        return
    shot = bullets.pop(0)
    if shot == 1:
        roulette_games.clear()
        await bot.send_message(chat_id, f"🔫 **{player_name}** нажал...\n💥 БОЕВОЙ!\n💀 Убит!\n🏆 {opponent_name}!", parse_mode=ParseMode.MARKDOWN)
    else:
        next_player = opponent_id
        if len(bullets) == 0:
            roulette_games.clear()
            await bot.send_message(chat_id, "💨 Холостой! Ничья!")
            return
        roulette_games[player_id]["turn"] = next_player
        roulette_games[player_id]["bullets"] = bullets
        roulette_games[opponent_id]["turn"] = next_player
        roulette_games[opponent_id]["bullets"] = bullets
        kb = InlineKeyboardMarkup(inline_keyboard=[[InlineKeyboardButton(text="🔫 ВЫСТРЕЛИТЬ", callback_data=f"rshoot_{chat_id}_{next_player}_{player_id}")]])
        await bot.send_message(chat_id, f"💨 Холостой!\n⏳ {opponent_name}\n💀 Патронов: {len(bullets)}", reply_markup=kb)

