async def deposit_bank(user_id: int, amount: int):
    if amount <= 0:
        return
    
    current_coins = await get_coins(user_id)
    if current_coins < amount:
        return
    
    await remove_coins(user_id, amount)
    
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        now = datetime.now().isoformat()
        
        c.execute("SELECT balance FROM bank WHERE user_id = ?", (user_id,))
        row = c.fetchone()
        current_balance = row[0] if row else 0
        
        new_balance = min(current_balance + amount, MAX_COINS)
        
        c.execute("INSERT INTO bank (user_id, balance, last_interest) VALUES (?,?,?) ON CONFLICT(user_id) DO UPDATE SET balance = ?, last_interest = ?", 
                  (user_id, new_balance, now, new_balance, now))
        
        # Записываем историю
        c.execute("INSERT INTO bank_history (user_id, type, amount, date) VALUES (?,?,?,?)", 
                  (user_id, "deposit", amount, now))
        
        conn.commit()
        conn.close()
    except Exception as e:
        log_error(e, "deposit_bank")

async def withdraw_bank(user_id: int, amount: int) -> bool:
    if amount <= 0:
        return False
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT balance FROM bank WHERE user_id = ?", (user_id,))
        row = c.fetchone()
        if row and row[0] >= amount:
            c.execute("UPDATE bank SET balance = balance - ? WHERE user_id = ?", (amount, user_id))
            now = datetime.now().isoformat()
            c.execute("INSERT INTO bank_history (user_id, type, amount, date) VALUES (?,?,?,?)", 
                      (user_id, "withdraw", amount, now))
            conn.commit()
            conn.close()
            await add_coins(user_id, amount)
            return True
        conn.close()
        return False
    except Exception as e:
        log_error(e, "withdraw_bank")
        return False

