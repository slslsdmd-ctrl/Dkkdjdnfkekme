async def tournament_fight(chat_id: int) -> str:
    """Проведение боя в турнире"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    c.execute("SELECT id, prize FROM tournaments WHERE chat_id = ? AND status = 'active'", (chat_id,))
    row = c.fetchone()
    
    if not row:
        conn.close()
        return "❌ Нет активного турнира!"
    
    tournament_id, prize = row[0], row[1]
    
    c.execute("SELECT user_id FROM tournament_participants WHERE tournament_id = ?", (tournament_id,))
    participants = [row[0] for row in c.fetchall()]
    
    if len(participants) < 2:
        conn.close()
        return f"❌ Нужно минимум 2 участника! Сейчас {len(participants)}"
    
    random.shuffle(participants)
    winners = []
    results = []
    
    for i in range(0, len(participants) - 1, 2):
        p1 = participants[i]
        p2 = participants[i + 1]
        
        p1_power = random.randint(1, 10) + (await has_item(p1, "меч") * 2)
        p2_power = random.randint(1, 10) + (await has_item(p2, "меч") * 2)
        
        p1_score = sum(random.randint(1, p1_power) for _ in range(3))
        p2_score = sum(random.randint(1, p2_power) for _ in range(3))
        
        if p1_score > p2_score:
            winners.append(p1)
            results.append(f"✅ {await get_name(p1)} победил {await get_name(p2)} ({p1_score}-{p2_score})")
        else:
            winners.append(p2)
            results.append(f"✅ {await get_name(p2)} победил {await get_name(p1)} ({p2_score}-{p1_score})")
    
    if len(participants) % 2 == 1:
        winners.append(participants[-1])
        results.append(f"🔄 {await get_name(participants[-1])} проходит без боя")
    
    if len(winners) == 1:
        champion = winners[0]
        c.execute("UPDATE tournaments SET status = 'finished', winner_id = ? WHERE id = ?", 
                  (champion, tournament_id))
        await add_coins(champion, prize)
        conn.commit()
        conn.close()
        
        return f"🏆 **ПОБЕДИТЕЛЬ ТУРНИРА: {await get_name(champion)}**\n💰 +{prize} монет!\n\n" + "\n".join(results)
    else:
        c.execute("DELETE FROM tournament_participants WHERE tournament_id = ?", (tournament_id,))
        for winner in winners:
            c.execute("INSERT INTO tournament_participants (tournament_id, user_id) VALUES (?,?)", 
                      (tournament_id, winner))
        conn.commit()
        conn.close()
        
        return "⚔️ **Раунд завершён!**\n\n" + "\n".join(results) + f"\n\n🔄 Осталось {len(winners)} участников\n📝 Следующий бой: `турнир бой`"

