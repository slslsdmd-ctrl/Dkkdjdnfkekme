async def unlock_achievement(user_id: int, ach_name: str) -> str:
    """РАЗБЛОКИРОВАТЬ ДОСТИЖЕНИЕ"""
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT unlocked FROM achievements WHERE user_id = ? AND ach_name = ?", (user_id, ach_name))
        if not c.fetchone():
            c.execute("INSERT INTO achievements (user_id, ach_name, unlocked) VALUES (?, ?, ?)", 
                     (user_id, ach_name, datetime.now().isoformat()))
            if ach_name in ACHIEVEMENTS:
                reward = ACHIEVEMENTS[ach_name]["reward"]
                await add_coins(user_id, reward)
                conn.commit()
                conn.close()
                return f"🏆 **{ACHIEVEMENTS[ach_name]['name']}**!\n{ACHIEVEMENTS[ach_name]['desc']}\n💰 +{reward} монет"
        conn.close()
        return None
    except Exception as e:
        log_error(e, "unlock_achievement")
        return None

