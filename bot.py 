async def use_promocode(code,uid,cid):
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("SELECT * FROM promocodes WHERE code=?",(code.upper(),));p=c.fetchone()
    if not p:conn.close();return"❌ Не найден!"
    if datetime.now()>datetime.fromisoformat(p[6]):conn.close();return"❌ Истёк!"
    if p[5]>=p[4]:conn.close();return"❌ Закончился!"
    c.execute("SELECT id FROM promo_uses WHERE code=? AND user_id=? AND chat_id=?",(code.upper(),uid,cid))
    if c.fetchone():conn.close();return"❌ Уже использован!"
    if p[2]>0:await add_coins(uid,cid,p[2])
    if p[3]:await add_item(uid,cid,p[3])
    c.execute("INSERT INTO promo_uses(code,user_id,chat_id)VALUES(?,?,?)",(code.upper(),uid,cid))
    c.execute("UPDATE promocodes SET used_count=used_count+1 WHERE code=?",(code.upper(),));conn.commit();conn.close()
    res="🎉 Активирован!"
    if p[2]>0:res+=f"\n💰 +{p[2]}"
    if p[3]:res+=f"\n🎁 +{RARE_ITEMS.get(p[3],{}).get('name',p[3])}"
    return res

