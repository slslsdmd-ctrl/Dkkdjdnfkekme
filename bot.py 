def get_local_smart_answer(prompt: str) -> str:
    prompt_lower = normalize_text(prompt).lower()
    if "монетк" in prompt_lower or "орел или решка" in prompt_lower:
        return f"🪙 Выпало: **{random.choice(['Орёл', 'Решка'])}**"
    if prompt_lower.startswith("выбери ") or prompt_lower.startswith("что выбрать"):
        choices = re.split(r"\s+или\s+|,", prompt_lower)
        choices = [c.strip() for c in choices if c.strip() and c not in ["выбери", "что выбрать"]]
        if len(choices) >= 2:
            return f"🤔 Я выбираю: **{random.choice(choices)}**"
    if prompt_lower.startswith("рандом") or prompt_lower.startswith("случайное"):
        numbers = re.findall(r'\d+', prompt_lower)
        if len(numbers) >= 2:
            left = int(numbers[0])
            right = int(numbers[1])
            return f"🎲 Случайное число: **{random.randint(left, right)}**"
    return None

