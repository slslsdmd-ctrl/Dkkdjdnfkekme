class AuctionSystem:
    """СИСТЕМА АУКЦИОНОВ МЕЖДУ ИГРОКАМИ"""
    
    def __init__(self):
        self.auctions = {}
        self.auction_id = 0
    
    async def create_auction(self, user_id: int, item_name: str, quantity: int, start_price: int) -> dict:
        """СОЗДАТЬ АУКЦИОН"""
        if quantity <= 0:
            return {"error": "Количество должно быть больше 0!"}
        
        if start_price <= 0:
            return {"error": "Начальная цена должна быть больше 0!"}
        
        has = await has_item(user_id, item_name)
        if has < quantity:
            return {"error": f"У тебя нет {quantity} {item_name}!"}
        
        await remove_item(user_id, item_name, quantity)
        
        self.auction_id += 1
        auction_id = self.auction_id
        
        self.auctions[auction_id] = {
            "id": auction_id,
            "seller": user_id,
            "item": item_name,
            "quantity": quantity,
            "current_price": start_price,
            "start_price": start_price,
            "buyout_price": start_price * 2,
            "bids": [],
            "created": datetime.now().isoformat(),
            "ends": (datetime.now() + timedelta(hours=24)).isoformat(),
            "status": "active"
        }
        
        return {
            "success": True,
            "auction_id": auction_id,
            "item": item_name,
            "quantity": quantity,
            "start_price": start_price
        }
    
    async def place_bid(self, auction_id: int, user_id: int, bid: int) -> dict:
        """СДЕЛАТЬ СТАВКУ НА АУКЦИОНЕ"""
        if auction_id not in self.auctions:
            return {"error": "Аукцион не найден!"}
        
        auction = self.auctions[auction_id]
        if auction["status"] != "active":
            return {"error": "Аукцион завершён!"}
        
        if auction["seller"] == user_id:
            return {"error": "Нельзя делать ставку на свой лот!"}
        
        if bid <= auction["current_price"]:
            return {"error": f"Ставка должна быть больше {auction['current_price']}!"}
        
        coins = await get_coins(user_id)
        if coins < bid:
            return {"error": f"Недостаточно монет! Есть {coins}"}
        
        # Возвращаем предыдущую ставку
        if auction["bids"]:
            last_bid = auction["bids"][-1]
            await add_coins(last_bid["user_id"], last_bid["amount"])
        
        # Блокируем ставку
        await remove_coins(user_id, bid)
        
        auction["bids"].append({
            "user_id": user_id,
            "amount": bid,
            "time": datetime.now().isoformat()
        })
        auction["current_price"] = bid
        
        # Проверяем выкуп
        if bid >= auction["buyout_price"]:
            return await self.buyout_auction(auction_id, user_id)
        
        return {
            "success": True,
            "auction_id": auction_id,
            "current_price": bid,
            "message": f"✅ Ставка {bid} принята!"
        }
    
    async def buyout_auction(self, auction_id: int, user_id: int) -> dict:
        """ВЫКУПИТЬ ЛОТ НА АУКЦИОНЕ"""
        if auction_id not in self.auctions:
            return {"error": "Аукцион не найден!"}
        
        auction = self.auctions[auction_id]
        if auction["status"] != "active":
            return {"error": "Аукцион завершён!"}
        
        # Проверяем деньги
        coins = await get_coins(user_id)
        if coins < auction["buyout_price"]:
            return {"error": f"Недостаточно монет! Нужно {auction['buyout_price']}"}
        
        # Снимаем деньги
        await remove_coins(user_id, auction["buyout_price"])
        
        # Передаём предмет
        await add_item(user_id, auction["item"], auction["quantity"])
        
        # Передаём деньги продавцу
        await add_coins(auction["seller"], auction["buyout_price"])
        
        auction["status"] = "completed"
        auction["winner"] = user_id
        auction["ended"] = datetime.now().isoformat()
        
        return {
            "success": True,
            "auction_id": auction_id,
            "item": auction["item"],
            "quantity": auction["quantity"],
            "price": auction["buyout_price"],
            "message": f"🎉 {await get_name(user_id)} выкупил {auction['item']} за {auction['buyout_price']} монет!"
        }
    
    async def get_active_auctions(self) -> List[dict]:
        """ПОЛУЧИТЬ АКТИВНЫЕ АУКЦИОНЫ"""
        result = []
        for aid, auction in self.auctions.items():
            if auction["status"] == "active":
                result.append({
                    "id": aid,
                    "item": auction["item"],
                    "quantity": auction["quantity"],
                    "current_price": auction["current_price"],
                    "buyout_price": auction["buyout_price"],
                    "bids_count": len(auction["bids"]),
                    "ends": auction["ends"]
                })
        return result

