    c.execute("SELECT answer FROM ai_cache WHERE question_hash = ?", (hashlib.md5(question.lower().strip().encode()).hexdigest(),))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

def save_cached_answer(question: str, answer: str):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO ai_cache (question_hash, question, answer, timestamp) VALUES (?, ?, ?, ?)", (hashlib.md5(question.lower().strip().encode()).hexdigest(), question, answer, datetime.now().isoformat()))
    conn.commit()
    conn.close()

async def ask_ai(prompt: str) -> str:
    prompt = normalize_text(prompt)
    prompt_lower = prompt.lower()
    print(f"📝 {prompt}")
    
    smart_local = get_local_smart_answer(prompt)
    if smart_local:
        return smart_local
    
    for key, answer in LOCAL_ANSWERS.items():
        if prompt_lower == key or prompt_lower.startswith(f"{key} "):
            return answer
    
    cached = get_cached_answer(prompt)
    if cached:
        return cached
    
    try:
        if needs_web_search(prompt):
            search_result = await smart_web_search(prompt)
            if search_result:
                reference = search_result.get('extract', '')
                reply = await ask_llm(prompt, reference_context=reference)
                if reply and len(reply) > 10:
                    save_cached_answer(prompt, reply)
                    return reply
                if len(reference) > 20:
                    save_cached_answer(prompt, reference)
                    return f"🔍 {search_result.get('source', '')}:\n{reference[:1500]}"
        
        reply = await ask_llm(prompt)
        if reply and len(reply) > 10:
            save_cached_answer(prompt, reply)
            return reply
    except Exception as e:
        print(f"Ошибка AI: {e}")
    
    return "❌ Не смог найти ответ. Попробуй переформулировать вопрос."

