    def _get_connection_sync(self):
        """СИНХРОННОЕ ПОЛУЧЕНИЕ СОЕДИНЕНИЯ"""
        conn = sqlite3.connect(
            self.db_path,
            timeout=5,
            check_same_thread=False,
            isolation_level=None
        )
        conn.execute("PRAGMA journal_mode=WAL")
        conn.execute("PRAGMA synchronous=NORMAL")
        conn.execute("PRAGMA cache_size=100000")
        conn.execute("PRAGMA temp_store=MEMORY")
        conn.row_factory = sqlite3.Row
        return conn
    
    async def _get_connection(self):
        """АСИНХРОННОЕ ПОЛУЧЕНИЕ СОЕДИНЕНИЯ"""
        async with self.lock:
            if self.connections:
                conn = self.connections.pop()
                try:
                    conn.execute("SELECT 1")
                    return conn
                except:
                    pass
            
            return self._get_connection_sync()
    
    async def _return_connection(self, conn):
        """ВОЗВРАЩЕНИЕ СОЕДИНЕНИЯ"""
        async with self.lock:
            if len(self.connections) < self.max_connections:
                self.connections.append(conn)
            else:
                conn.close()
    
    async def query(self, sql: str, params: tuple = (), fetch_one=False, fetch_all=False, cache_ttl=0):
        """ОПТИМИЗИРОВАННЫЙ ЗАПРОС С КЭШЕМ"""
        self.stats['queries'] += 1
        
        # Проверяем кэш
        cache_key = f"{sql}:{params}"
        if cache_ttl > 0 and cache_key in self.cache:
            cache_time = self.cache_times.get(cache_key, 0)
            if time.time() - cache_time < cache_ttl:
                self.stats['hits'] += 1
                return self.cache[cache_key]
        
        self.stats['misses'] += 1
        conn = await self._get_connection()
        
        try:
            cursor = conn.cursor()
            cursor.execute(sql, params)
            
            if fetch_one:
                result = cursor.fetchone()
            elif fetch_all:
                result = cursor.fetchall()
            else:
                conn.commit()
                result = cursor.rowcount
            
            # Сохраняем в кэш
            if cache_ttl > 0:
                self.cache[cache_key] = result
                self.cache_times[cache_key] = time.time()
            
            await self._return_connection(conn)
            return result
        except Exception as e:
            await self._return_connection(conn)
            raise e
    
    def get_stats(self) -> dict:
        """ПОЛУЧИТЬ СТАТИСТИКУ БД"""
        total = self.stats['hits'] + self.stats['misses']
        hit_rate = (self.stats['hits'] / total * 100) if total > 0 else 0
        
        return {
            'connections': len(self.connections),
            'cache_size': len(self.cache),
            'queries': self.stats['queries'],
            'hits': self.stats['hits'],
            'misses': self.stats['misses'],
            'hit_rate': f"{hit_rate:.1f}%"
        }
    
    def clear_cache(self):
        """ОЧИСТИТЬ КЭШ"""
        self.cache.clear()
        self.cache_times.clear()

