def get_rank(coins: int) -> dict:
    """ПОЛУЧИТЬ РАНГ ПО КОЛИЧЕСТВУ МОНЕТ"""
    ranks = [
        (10**12, "👑 ИМПЕРАТОР", 500),
        (10**11, "💎 КОРОЛЬ", 300),
        (10**10, "👑 МАГНАТ", 200),
        (10**9, "💎 МИЛЛИАРДЕР", 100),
        (10**8, "💰 МУЛЬТИМИЛЛИОНЕР", 75),
        (10**7, "💰 МИЛЛИОНЕР", 50),
        (10**6, "📈 БОГАЧ", 25),
        (10**5, "📈 СОСТОЯТЕЛЬНЫЙ", 10),
        (10**4, "💵 СРЕДНИЙ КЛАСС", 5),
        (10**3, "🪙 РАБОЧИЙ", 2),
    ]
    
    for threshold, name, bonus in ranks:
        if coins >= threshold:
            return {"name": name, "bonus": bonus, "threshold": threshold}
    
    return {"name": "🐣 НОВИЧОК", "bonus": 1, "threshold": 0}

def get_level_info(level: int) -> dict:
    """ПОЛУЧИТЬ ИНФОРМАЦИЮ ОБ УРОВНЕ"""
    xp_for_level = level * 100
    return {
        "level": level,
        "xp_needed": xp_for_level,
        "bonus": level * 5,
        "title": get_level_title(level)
    }

def get_level_title(level: int) -> str:
    """ПОЛУЧИТЬ НАЗВАНИЕ УРОВНЯ"""
    titles = {
        1: "Новичок",
        5: "Ученик",
        10: "Мастер",
        25: "Эксперт",
        50: "Профессионал",
        75: "Гуру",
        100: "Легенда"
    }
    
    for max_level, title in sorted(titles.items()):
        if level <= max_level:
            return title
    return "Бог"

