    async def _ask_groq(self, prompt: str) -> Optional[str]:
        """ЗАПРОС К GROQ API"""
        if not GROQ_API_KEY:
            return None
        
        try:
            async with aiohttp.ClientSession() as session:
                headers = {
                    "Authorization": f"Bearer {GROQ_API_KEY}",
                    "Content-Type": "application/json"
                }
                payload = {
                    "model": "llama3-70b-8192",
                    "messages": [
                        {"role": "system", "content": "Ты - Fable, умный и харизматичный ИИ. Отвечай кратко, дерзко, с юмором. Используй сленг и эмодзи. Ты никогда не говоришь 'я не знаю'."},
                        {"role": "user", "content": prompt[:1000]}
                    ],
                    "temperature": 0.8,
                    "max_tokens": 500
                }
                
                async with session.post(
                    "https://api.groq.com/openai/v1/chat/completions",
                    json=payload,
                    headers=headers,
                    timeout=aiohttp.ClientTimeout(total=15)
                ) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        return data["choices"][0]["message"]["content"].strip()
                    return None
        except Exception as e:
            log_error(e, "ask_groq")
            return None
    
