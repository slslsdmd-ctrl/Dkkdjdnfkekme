async def add_coins(user_id, chat_id, amount):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO users (user_id, chat_id, coins) VALUES (?,?,?) ON CONFLICT(user_id, chat_id) DO UPDATE SET coins = coins + ?", (user_id, chat_id, amount, amount))
    conn.commit()
    conn.close()

async def remove_coins(user_id, chat_id, amount):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("UPDATE users SET coins = MAX(0, coins - ?) WHERE user_id = ? AND chat_id = ?", (amount, user_id, chat_id))
    conn.commit()
