            cache_ttl=60
        )
        return result or []
    
    async def join_clan(self, user_id: int, chat_id: int, clan_name: str) -> dict:
        """ВСТУПЛЕНИЕ В КЛАН"""
        # Проверяем, есть ли клан
        clan = await self.get_clan_by_name(chat_id, clan_name)
        if not clan:
            # Пробуем по ID
            try:
                clan_id = int(clan_name)
                clan = await self.get_clan_by_id(clan_id)
            except:
                pass
        
        if not clan:
            return {'error': 'Клан не найден!'}
        
        # Проверяем, не в клане ли уже
        in_clan = await db.query(
            "SELECT id FROM clans WHERE chat_id = ? AND members LIKE ?",
            (chat_id, f'%{user_id}%'),
            fetch_one=True
        )
        if in_clan:
            return {'error': 'Ты уже в клане!'}
        
        # Добавляем в клан
        members = clan['members'].split(',') if clan['members'] else []
        members.append(str(user_id))
        
        await db.query(
            "UPDATE clans SET members = ? WHERE id = ?",
            (','.join(members), clan['id'])
        )
        
        # Очищаем кэш
        self.get_clan.cache_clear()
        
        # Достижение
        await unlock_achievement(user_id, "join_clan")
        
        return {
            'success': True,
            'clan': clan['name'],
            'members': len(members)
        }
    
    async def leave_clan(self, user_id: int, chat_id: int) -> dict:
        """ВЫХОД ИЗ КЛАНА"""
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        # Проверяем, не лидер ли
        if clan['owner_id'] == user_id:
            return {'error': 'Лидер не может выйти! Передай клан другому участнику.'}
        
        # Удаляем из клана
        members = clan['members'].split(',') if clan['members'] else []
        members.remove(str(user_id))
        
        await db.query(
            "UPDATE clans SET members = ? WHERE id = ?",
            (','.join(members), clan['id'])
        )
        
        # Очищаем кэш
        self.get_clan.cache_clear()
        
        return {
            'success': True,
            'clan': clan['name']
        }
    
    async def transfer_clan(self, user_id: int, chat_id: int, new_owner_id: int) -> dict:
        """ПЕРЕДАЧА КЛАНА"""
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        if clan['owner_id'] != user_id:
            return {'error': 'Только лидер может передать клан!'}
        
        # Проверяем, что новый лидер в клане
        members = clan['members'].split(',') if clan['members'] else []
        if str(new_owner_id) not in members:
            return {'error': 'Новый лидер не состоит в клане!'}
        
        # Передаём
        await db.query(
            "UPDATE clans SET owner_id = ? WHERE id = ?",
            (new_owner_id, clan['id'])
        )
        
        # Очищаем кэш
        self.get_clan.cache_clear()
        
        return {
            'success': True,
            'clan': clan['name'],
            'new_owner': new_owner_id
        }
    
