async def get_global_rich_list_paginated(page: int = 1, per_page: int = 10) -> dict:
    """
    Возвращает глобальный топ богачей с пагинацией
    """
    try:
        offset = (page - 1) * per_page
        
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        
        c.execute("SELECT COUNT(*) FROM users WHERE coins > 0")
        total_users = c.fetchone()[0]
        
        c.execute("""
            SELECT user_id, coins 
            FROM users 
            WHERE coins > 0
            ORDER BY coins DESC 
            LIMIT ? OFFSET ?
        """, (per_page, offset))
        
        rows = c.fetchall()
        conn.close()
        
        total_pages = (total_users + per_page - 1) // per_page
        
        return {
            "users": rows,
            "total_users": total_users,
            "total_pages": total_pages,
            "current_page": page,
            "per_page": per_page,
            "has_next": page < total_pages,
            "has_prev": page > 1
        }
    except Exception as e:
        log_error(e, "get_global_rich_list_paginated")
        return {
            "users": [],
            "total_users": 0,
            "total_pages": 0,
            "current_page": 1,
            "per_page": per_page,
            "has_next": False,
            "has_prev": False
        }

