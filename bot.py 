class Roulette:
    """УЛУЧШЕННАЯ РУЛЕТКА С РАЗНЫМИ СТАВКАМИ"""
    
    def __init__(self):
        self.numbers = list(range(0, 37))
        self.red = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36]
        self.black = [2,4,6,8,10,11,13,15,17,20,22,24,26,28,29,31,33,35]
        self.green = [0]
    
    async def spin(self, user_id: int, bet: int, bet_type: str, value: str) -> dict:
        """ВРАЩЕНИЕ РУЛЕТКИ"""
        if bet <= 0:
            return {'error': 'Ставка должна быть больше 0!'}
        
        coins = await db.get_coins(user_id)
        if coins < bet:
            return {'error': f'Недостаточно монет! Есть {coins}'}
        
        await db.add_coins(user_id, -bet)
        
        # Выпавшее число
        number = random.choice(self.numbers)
        color = "зеленый" if number == 0 else "красный" if number in self.red else "черный"
        
        # Расчёт выигрыша
        win = 0
        multiplier = 0
        
        bet_type_lower = bet_type.lower()
        
        if bet_type_lower == "число" and value.isdigit():
            if int(value) == number:
                multiplier = 35
                win = bet * multiplier
        
        elif bet_type_lower == "цвет":
            if value.lower() == color:
                multiplier = 2 if color != "зеленый" else 35
                win = bet * multiplier
        
        elif bet_type_lower == "четность":
            is_even = number % 2 == 0 and number != 0
            if value.lower() == "четное" and is_even:
                multiplier = 2
                win = bet * multiplier
            elif value.lower() == "нечетное" and not is_even and number != 0:
                multiplier = 2
                win = bet * multiplier
        
        elif bet_type_lower == "диапазон":
            ranges = {
                "1-12": range(1, 13),
                "13-24": range(13, 25),
                "25-36": range(25, 37)
            }
            if value in ranges:
                if number in ranges[value]:
                    multiplier = 3
                    win = bet * multiplier
        
        elif bet_type_lower == "ряд":
            rows = {
                "1-34": [1,4,7,10,13,16,19,22,25,28,31,34],
                "2-35": [2,5,8,11,14,17,20,23,26,29,32,35],
                "3-36": [3,6,9,12,15,18,21,24,27,30,33,36]
            }
            if value in rows:
                if number in rows[value]:
                    multiplier = 2
                    win = bet * multiplier
        
        if win > 0:
            await db.add_coins(user_id, win)
        
        return {
            'success': True,
            'number': number,
            'color': color,
            'win': win,
            'bet': bet,
            'multiplier': multiplier,
            'bet_type': bet_type,
            'bet_value': value
        }

