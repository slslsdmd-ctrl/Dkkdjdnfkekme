        for user in message.new_chat_members:
            if user.id == bot.id:
                adder_id = message.from_user.id
                await set_role(adder_id, message.chat.id, 10)
                await bot.send_message(
                    message.chat.id,
                    f"👑 {await get_name(adder_id)} добавил бота и получил 10 уровень!"
                )
                
                try:
                    admins = await bot.get_chat_administrators(message.chat.id)
                    admin_names = []
                    for admin in admins:
                        await set_role(admin.user.id, message.chat.id, 10)
                        admin_names.append(f"@{admin.user.username or admin.user.first_name}")
                    
                    await bot.send_message(
                        message.chat.id,
                        f"👑 Всем администраторам выдан 10 уровень!\n👥 {', '.join(admin_names[:5])}"
