FORGE_LEVELS = {}  # {user_id: {item: level}}

async def forge_get_level(user_id: int, item: str) -> int:
    """Получает текущий уровень предмета в кузнице"""
    if item not in FORGE_ITEMS:
        return 0
    
    if user_id not in FORGE_LEVELS:
        FORGE_LEVELS[user_id] = {}
    
    return FORGE_LEVELS[user_id].get(item, 0)

async def forge_upgrade(user_id: int, item: str) -> str:
    """Улучшает предмет в кузнице"""
    if item not in FORGE_ITEMS:
        return "❌ Такого предмета нет в кузнице! Доступно: меч, щит, лук, кольчуга"
    
    current_level = await forge_get_level(user_id, item)
    upgrades = FORGE_ITEMS[item]["upgrades"]
    
    if current_level >= len(upgrades):
        return f"❌ {item} уже на максимальном уровне!"
    
    next_upgrade = upgrades[current_level]
    
    if await get_coins(user_id) < next_upgrade["cost"]:
        return f"❌ Не хватает монет! Нужно {next_upgrade['cost']} монет"
    
    await remove_coins(user_id, next_upgrade["cost"])
    
    FORGE_LEVELS[user_id][item] = current_level + 1
    
    return f"✅ {next_upgrade['name']} создан!\n"
    f"💪 Бонус: +{next_upgrade['bonus']}\n"
    f"💰 -{next_upgrade['cost']} монет"

async def forge_info(user_id: int) -> str:
    """Информация о кузнице"""
    txt = "🔨 **КУЗНИЦА**\n\n"
    
    for item, data in FORGE_ITEMS.items():
        current_level = await forge_get_level(user_id, item)
        upgrades = data["upgrades"]
        
        if current_level >= len(upgrades):
            txt += f"✅ {upgrades[-1]['name']} (МАКСИМУМ)\n"
        else:
            next_upgrade = upgrades[current_level]
            txt += f"📌 {item.capitalize()}: {next_upgrade['name']} (💰{next_upgrade['cost']})\n"
            txt += f"   Текущий уровень: {current_level}/{len(upgrades)}\n"
    
    txt += "\n📝 `улучшить [предмет]` — улучшить предмет"
    return txt

