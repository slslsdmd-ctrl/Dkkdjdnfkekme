class CraftSystem:
    """СИСТЕМА КРАФТА ПРЕДМЕТОВ"""
    
    def __init__(self):
        self.recipes = {
            "меч": {
                "materials": {"железо": 3, "дерево": 2},
                "result": {"меч": 1},
                "exp": 10,
                "level": 1
            },
            "щит": {
                "materials": {"железо": 4, "дерево": 3},
                "result": {"щит": 1},
                "exp": 15,
                "level": 2
            },
            "золотая_удочка": {
                "materials": {"золото": 5, "дерево": 1},
                "result": {"золотая_удочка": 1},
                "exp": 30,
                "level": 5
            },
            "алмазная_кирка": {
                "materials": {"алмаз": 5, "железо": 2},
                "result": {"алмазная_кирка": 1},
                "exp": 40,
                "level": 7
            },
            "квантовый_ноутбук": {
                "materials": {"золото": 10, "алмаз": 3},
                "result": {"квантовый_ноутбук": 1},
                "exp": 50,
                "level": 10
            },
        }
        self.crafting_levels = {}
    
    async def craft(self, user_id: int, recipe_name: str) -> dict:
        """СКРАФТИТЬ ПРЕДМЕТ"""
        if recipe_name not in self.recipes:
            return {"error": "Рецепт не найден!"}
        
        recipe = self.recipes[recipe_name]
        
        # Проверяем уровень крафта
        level = await self.get_crafting_level(user_id)
        if level < recipe["level"]:
            return {"error": f"Нужен {recipe['level']} уровень крафта!"}
        
        # Проверяем материалы
        materials = recipe["materials"]
        for mat, qty in materials.items():
            has = await has_item(user_id, mat)
            if has < qty:
                return {"error": f"Недостаточно {mat}! Нужно {qty}"}
        
        # Снимаем материалы
        for mat, qty in materials.items():
            await remove_item(user_id, mat, qty)
        
        # Создаём предмет
        for result_item, result_qty in recipe["result"].items():
            await add_item(user_id, result_item, result_qty)
        
        # Добавляем опыт крафта
        new_exp = await self.add_crafting_exp(user_id, recipe["exp"])
        
        return {
            "success": True,
            "crafted": recipe_name,
            "exp_gained": recipe["exp"],
            "new_exp": new_exp,
            "message": f"🔨 {recipe_name} создан!"
        }
    
    async def get_crafting_level(self, user_id: int) -> int:
        """ПОЛУЧИТЬ УРОВЕНЬ КРАФТА"""
        if user_id not in self.crafting_levels:
            self.crafting_levels[user_id] = {"level": 1, "exp": 0}
        return self.crafting_levels[user_id]["level"]
    
    async def add_crafting_exp(self, user_id: int, exp: int) -> int:
        """ДОБАВИТЬ ОПЫТ КРАФТА"""
        if user_id not in self.crafting_levels:
            self.crafting_levels[user_id] = {"level": 1, "exp": 0}
        
        data = self.crafting_levels[user_id]
        data["exp"] += exp
        
        # Повышение уровня
        while data["exp"] >= data["level"] * 50:
            data["exp"] -= data["level"] * 50
            data["level"] += 1
        
        return data["exp"]

craft_system = CraftSystem()

