def get_fast_answer(text: str) -> str:
    """ПОЛУЧИТЬ БЫСТРЫЙ ОТВЕТ"""
    text_lower = text.lower().strip()
    for key, answers in FAST_ANSWERS.items():
        if key in text_lower:
            return random.choice(answers)
    return None

