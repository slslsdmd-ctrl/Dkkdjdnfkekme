class AchievementManager:
    """УПРАВЛЕНИЕ ДОСТИЖЕНИЯМИ"""
    
    def __init__(self):
        self.cache = {}
    
    async def unlock(self, user_id: int, ach_name: str) -> Optional[dict]:
        """РАЗБЛОКИРОВКА ДОСТИЖЕНИЯ"""
        if ach_name not in ACHIEVEMENTS:
            return None
        
        # Проверяем, не разблокировано ли уже
        existing = await db.query(
            "SELECT * FROM achievements WHERE user_id = ? AND ach_name = ?",
            (user_id, ach_name),
            fetch_one=True
        )
        if existing:
            return None
        
        # Разблокируем
        await db.query(
            "INSERT INTO achievements (user_id, ach_name, unlocked) VALUES (?, ?, ?)",
            (user_id, ach_name, datetime.now().isoformat())
        )
        
        # Награда
        reward = ACHIEVEMENTS[ach_name]['reward']
        await db.add_coins(user_id, reward)
        
        # Очищаем кэш
        self.get_achievements.cache_clear()
        
        return {
            'name': ACHIEVEMENTS[ach_name]['name'],
            'desc': ACHIEVEMENTS[ach_name]['desc'],
            'reward': reward
        }
    
    async def get_achievements(self, user_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ ДОСТИЖЕНИЙ ПОЛЬЗОВАТЕЛЯ"""
        result = await db.query(
            "SELECT ach_name, unlocked FROM achievements WHERE user_id = ?",
            (user_id,),
            fetch_all=True,
            cache_ttl=30
        )
        return result or []
    
    async def get_progress(self, user_id: int) -> dict:
        """ПРОГРЕСС ПО ДОСТИЖЕНИЯМ"""
        unlocked = await self.get_achievements(user_id)
        total = len(ACHIEVEMENTS)
        
        return {
            'unlocked': len(unlocked),
            'total': total,
            'percent': round(len(unlocked) / total * 100, 1),
            'total_reward': sum(ACHIEVEMENTS[a['ach_name']]['reward'] for a in unlocked)
        }
    
    async def check_all(self, user_id: int) -> List[dict]:
        """ПРОВЕРКА ВСЕХ ДОСТИЖЕНИЙ"""
        unlocked = []
        
        # Получаем данные пользователя
        coins = await db.get_coins(user_id)
        msg_count = await db.query(
            "SELECT count FROM message_counts WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        msg_count = msg_count['count'] if msg_count else 0
        
        # Проверяем достижения
        checks = [
            ("msg_100", msg_count >= 100),
            ("msg_1000", msg_count >= 1000),
            ("msg_10000", msg_count >= 10000),
            ("coins_1000", coins >= 1000),
            ("coins_10000", coins >= 10000),
            ("millionaire", coins >= 1000000),
            ("billionaire", coins >= 1000000000),
        ]
        
        for ach_name, condition in checks:
            if condition:
                result = await self.unlock(user_id, ach_name)
                if result:
                    unlocked.append(result)
        
        return unlocked

