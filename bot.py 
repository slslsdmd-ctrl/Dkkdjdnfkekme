@dp.message()
async def handle_ai(message: Message):
    """ОБРАБОТКА AI СООБЩЕНИЙ"""
    user_id = message.from_user.id
    chat_id = message.chat.id
    text = message.text
    
    if not text:
        return
    
    # Проверяем, нужно ли обрабатывать AI
    is_reply_to_bot = message.reply_to_message and message.reply_to_message.from_user.id == bot.id
    is_mention = BOT_USERNAME and BOT_USERNAME in text
    is_fable_call = any(word in text.lower() for word in ["фабле", "fable"])
    
    if not (is_reply_to_bot or is_mention or is_fable_call):
        return
    
    # Очищаем текст
    clean = text
    if is_mention:
        clean = re.sub(rf"@{BOT_USERNAME}", "", clean)
    else:
        clean = re.sub(r"(?i)\bфабле\b|\bfable\b", "", clean).strip()
    
    if not clean:
        clean = "привет"
    
    # Проверяем команды AI
    if any(clean.lower().startswith(word) for word in ["код", "напиши код", "сгенерируй код"]):
        prompt = clean
        for word in ["код", "напиши код", "сгенерируй код"]:
            if prompt.lower().startswith(word):
                prompt = prompt[len(word):].strip()
                break
        
        if prompt:
            await bot.send_chat_action(chat_id, "typing")
            await message.reply(await generate_code(prompt), parse_mode=ParseMode.MARKDOWN)
        return
    
    if any(clean.lower().startswith(word) for word in ["стих", "напиши стих"]):
        prompt = clean
        for word in ["стих", "напиши стих"]:
            if prompt.lower().startswith(word):
                prompt = prompt[len(word):].strip()
                break
        
        await bot.send_chat_action(chat_id, "typing")
        await message.reply(await generate_poem(prompt), parse_mode=ParseMode.MARKDOWN)
        return
    
    if any(clean.lower().startswith(word) for word in ["история", "расскажи историю"]):
        prompt = clean
        for word in ["история", "расскажи историю"]:
            if prompt.lower().startswith(word):
                prompt = prompt[len(word):].strip()
                break
        
        await bot.send_chat_action(chat_id, "typing")
        await message.reply(await generate_story(prompt), parse_mode=ParseMode.MARKDOWN)
        return
    
    if any(clean.lower().startswith(word) for word in ["совет", "дай совет"]):
        prompt = clean
        for word in ["совет", "дай совет"]:
            if prompt.lower().startswith(word):
                prompt = prompt[len(word):].strip()
                break
        
        await bot.send_chat_action(chat_id, "typing")
        await message.reply(await get_advice(prompt), parse_mode=ParseMode.MARKDOWN)
        return
    
    if any(clean.lower().startswith(word) for word in ["картинка", "сгенерируй картинку", "нарисуй"]):
        prompt = clean
        for word in ["картинка", "сгенерируй картинку", "нарисуй"]:
            if prompt.lower().startswith(word):
                prompt = prompt[len(word):].strip()
                break
        
        if prompt:
            status = await message.reply(f"🎨 Генерирую: **{prompt[:50]}**...", parse_mode=ParseMode.MARKDOWN)
            image_url = await generate_image(prompt)
            
            if image_url:
                try:
                    await bot.send_photo(chat_id, image_url, caption=f"🎨 {prompt}", reply_to_message_id=message.message_id)
                    await status.delete()
                except:
                    await status.edit_text(f"❌ Ошибка загрузки!\nСсылка: {image_url}")
            else:
                await status.edit_text("❌ Не удалось сгенерировать изображение")
        return
    
    if any(clean.lower().startswith(word) for word in ["найди", "поищи", "поиск"]):
        query = clean
        for word in ["найди", "поищи", "поиск"]:
            if query.lower().startswith(word):
                query = query[len(word):].strip()
                break
        
        if query:
            status = await message.reply(f"🔍 Ищу: **{query[:50]}**...", parse_mode=ParseMode.MARKDOWN)
            result = await search_web(query)
            
            if result:
                reply = f"🔍 **{result['title']}**\n\n"
                reply += f"{result['extract'][:500]}...\n\n"
                reply += f"📡 Источник: {result['source']}\n"
                if result.get('url'):
                    reply += f"🔗 {result['url']}"
                await status.edit_text(reply, parse_mode=ParseMode.MARKDOWN)
            else:
                await status.edit_text("❌ Ничего не найдено!")
        return
    
    # Обычный AI ответ
    await bot.send_chat_action(chat_id, "typing")
    reply = await ask_ai(clean, user_id, chat_id)
    await message.reply(reply, parse_mode=ParseMode.MARKDOWN)

