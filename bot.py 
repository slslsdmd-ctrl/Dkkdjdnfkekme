@dp.message()
async def handle_all_messages(message: types.Message):
    """Основной обработчик всех сообщений"""
    if not message.text:
        return
    
    try:
        text = message.text.strip()
        text_lower = text.lower()
        uid = message.from_user.id
        chat_id = message.chat.id
        
        # Определяем переменные для ответов боту
        is_reply_to_bot = message.reply_to_message and message.reply_to_message.from_user.id == bot.id
        is_mention = BOT_USERNAME and BOT_USERNAME in text
        is_fable_call = any(word in text_lower for word in ["фабле", "fable"])
        
        # АДМИН КОМАНДЫ В ЛИЧКЕ
        if chat_id == uid and uid == YOUR_ID:
            if text_lower.startswith("+промокод"):
                args = text.split()
                if len(args) >= 4:
                    code = args[1].upper()
                    item = args[2].lower()
                    uses = int(args[3]) if len(args) > 3 and args[3].isdigit() else 1
                    coins = int(args[4]) if len(args) >= 5 and args[4].isdigit() else 0
                    await create_promocode(code, uid, coins, item, uses)
                    item_name = RARE_ITEMS.get(item, {}).get("name", item)
                    await message.reply(f"✅ Промокод **{code}** создан!\n🎁 {item_name}\n👥 {uses} исп.\n💰 {coins} монет")
                else:
                    await message.reply("ℹ️ +промокод КОД предмет кол-во [монеты]")
                return
            
            if text_lower.startswith("+монеты"):
                args = text.split()
                if len(args) >= 3:
                    try:
                        target = int(args[1])
                        amount = int(args[2])
                        await add_coins(target, amount)
                        await message.reply(f"✅ +{amount} монет для {await get_name(target)}")
                    except Exception as e:
                        log_error(e, "+монеты")
                        await message.reply("❌ Формат: +монеты id сумма")
                return
            
            if text_lower.startswith("+дать"):
                args = text.split()
                if len(args) >= 3:
                    try:
                        target = int(args[1])
                        item = args[2].lower()
                        qty = int(args[3]) if len(args) >= 4 else 1
                        await add_item(target, item, qty)
                        item_name = RARE_ITEMS.get(item, {}).get("name", item)
                        await message.reply(f"✅ {await get_name(target)} получил {item_name} x{qty}!")
                    except Exception as e:
                        log_error(e, "+дать")
                        await message.reply("❌ Формат: +дать id предмет [кол-во]")
                return
            
            if text_lower.startswith("+уровень"):
                args = text.split()
                if len(args) >= 3:
                    try:
                        target = int(args[1])
                        level = int(args[2])
                        await set_role(target, level)
                        await message.reply(f"✅ {await get_name(target)} теперь {level} уровня!")
                    except Exception as e:
                        log_error(e, "+уровень")
                        await message.reply("❌ Формат: +уровень id уровень")
                return
            
            if text_lower.startswith("+модуль"):
                args = text.split()
                if len(args) >= 3:
