import asyncio
import random
import sqlite3
from datetime import datetime, timedelta
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command
from aiogram.types import ChatPermissions, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.enums import ParseMode
import os

TOKEN = os.getenv('BOT_TOKEN')
BOT_NAME = "Fable"

bot = Bot(token=TOKEN)
dp = Dispatcher()

# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("""CREATE TABLE IF NOT EXISTS messages
                 (id INTEGER PRIMARY KEY, chat_id INTEGER, user_id INTEGER, 
                  username TEXT, text TEXT, date TEXT)""")
    c.execute("""CREATE TABLE IF NOT EXISTS warns
                 (user_id INTEGER, chat_id INTEGER, count INTEGER, 
                  reason TEXT, date TEXT, warned_by INTEGER)""")
    c.execute("""CREATE TABLE IF NOT EXISTS rp_roles
                 (user_id INTEGER, chat_id INTEGER, level INTEGER DEFAULT 1,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS user_join_date
                 (user_id INTEGER, chat_id INTEGER, join_date TEXT,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS duels
                 (chat_id INTEGER, challenger INTEGER, opponent INTEGER, turn INTEGER, aim_bonus INTEGER, message_id INTEGER)""")
    c.execute("""CREATE TABLE IF NOT EXISTS chat_stats
                 (chat_id INTEGER PRIMARY KEY, msg_count INTEGER DEFAULT 0, last_auto_time TIMESTAMP)""")
    conn.commit()
    conn.close()

async def save_message(chat_id, user_id, username, text):
    if not text or len(text) > 1000:
        return
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO messages (chat_id, user_id, username, text, date) VALUES (?,?,?,?,?)",
              (chat_id, user_id, username, text[:500], datetime.now().isoformat()))
    conn.commit()
    conn.close()

async def save_join_date(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO user_join_date (user_id, chat_id, join_date) VALUES (?,?,?)",
              (user_id, chat_id, datetime.now().isoformat()))
    conn.commit()
    conn.close()

async def get_join_date(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT join_date FROM user_join_date WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

async def get_role(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT level FROM rp_roles WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    conn.close()
    return row[0] if row else 1

async def set_role(user_id, chat_id, level):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO rp_roles (user_id, chat_id, level) VALUES (?,?,?)", (user_id, chat_id, level))
    conn.commit()
    conn.close()

async def add_warn(user_id, chat_id, reason, warned_by):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM warns WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    count = c.fetchone()[0] + 1
    c.execute("INSERT INTO warns (user_id, chat_id, count, reason, date, warned_by) VALUES (?,?,?,?,?,?)",
              (user_id, chat_id, count, reason, datetime.now().isoformat(), warned_by))
    conn.commit()
    conn.close()
    
    if count >= 5:
        await bot.ban_chat_member(chat_id, user_id)
        return f"⚠️ {count}/5 варнов. Пользователь исключён."
    return f"⚠️ Предупреждение {count}/5: {reason}"

async def remove_warn(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT count FROM warns WHERE user_id = ? AND chat_id = ? ORDER BY date DESC LIMIT 1", (user_id, chat_id))
    row = c.fetchone()
    if row:
        c.execute("DELETE FROM warns WHERE user_id = ? AND chat_id = ? AND count = ?", (user_id, chat_id, row[0]))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

async def get_user_message_count(chat_id, user_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM messages WHERE chat_id = ? AND user_id = ?", (chat_id, user_id))
    count = c.fetchone()[0]
    conn.close()
    return count

async def get_total_user_messages(user_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM messages WHERE user_id = ?", (user_id,))
    count = c.fetchone()[0]
    conn.close()
    return count

async def get_random_message(chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT text FROM messages WHERE chat_id = ? AND text != '' AND user_id != ? ORDER BY RANDOM() LIMIT 1", (chat_id, bot.id))
    row = c.fetchone()
    conn.close()
    if row and row[0]:
        return row[0]
    return None

async def get_name(user_id):
    try:
        user = await bot.get_chat(user_id)
        return f"@{user.username}" if user.username else user.first_name
    except:
        return f"id{user_id}"

# ========== АВТО-СООБЩЕНИЯ ==========
chat_msg_count = {}
chat_last_auto = {}

async def check_auto_message(chat_id: int):
    now = datetime.now()
    
    if chat_id in chat_last_auto:
        time_diff = now - chat_last_auto[chat_id]
        if time_diff.total_seconds() < 10800:
            return
    
    if chat_id in chat_msg_count:
        if chat_msg_count[chat_id] >= random.randint(15, 20):
            chat_msg_count[chat_id] = 0
            chat_last_auto[chat_id] = now
            
            phrase = await get_random_message(chat_id)
            if phrase:
                await bot.send_message(chat_id, f"📖 {phrase}")

# ========== ИГРЫ ==========
cube_games = {}

# ========== ПРИВЕТСТВИЕ ==========
async def send_welcome(message: types.Message, user):
    user_name = user.first_name
    user_id = user.id
    total_msgs = await get_total_user_messages(user_id)
    
    welcome_text = (
        f"👋 **Добро пожаловать, {user_name}!**\n\n"
        f"📊 **Твоя статистика в системе {BOT_NAME}:**\n"
        f"💬 Всего сообщений: **{total_msgs}**\n\n"
        f"🎯 Используй команды:\n"
        f"`Кубы` — сыграть в кости\n"
        f"`Профиль` — посмотреть свой профиль\n"
        f"`Топ` — топ активных\n"
        f"`Админы` — список РП-админов"
    )
    
    await message.reply(welcome_text, parse_mode=ParseMode.MARKDOWN)

# ========== ОСНОВНОЙ ОБРАБОТЧИК ==========
@dp.message()
async def handle_all_messages(message: types.Message):
    if not message.text:
        return
    
    # ==== СОХРАНЯЕМ СООБЩЕНИЯ ====
    if message.chat.type in ["group", "supergroup"]:
        await save_message(message.chat.id, message.from_user.id, 
                          message.from_user.username, message.text)
        
        if message.from_user.id != bot.id:
            chat_id = message.chat.id
            chat_msg_count[chat_id] = chat_msg_count.get(chat_id, 0) + 1
            await check_auto_message(chat_id)
    
    # ==== НОВЫЙ УЧАСТНИК (включая бота) ====
    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id:
                try:
                    chat = await bot.get_chat(message.chat.id)
                    admins = await bot.get_chat_administrators(message.chat.id)
                    
                    admin_list = []
                    for admin in admins:
                        admin_id = admin.user.id
                        await set_role(admin_id, message.chat.id, 10)
                        admin_list.append(f"@{admin.user.username or admin.user.first_name}")
                    
                    await bot.send_message(
                        message.chat.id,
                        f"👑 **{BOT_NAME} активирован!**\n\n"
                        f"📋 Всем администраторам группы выдан 10 уровень!\n"
                        f"👥 Список: {', '.join(admin_list)}\n\n"
                        f"🎯 Команды: `Кубы`, `Профиль`, `Топ`, `Админы`",
                        parse_mode=ParseMode.MARKDOWN
                    )
                except Exception as e:
                    print(f"Ошибка: {e}")
                continue
            
            if user.id == 8039111975:
                await set_role(user.id, message.chat.id, 10)
                await bot.send_message(
                    message.chat.id,
                    f"👑 Супер-админ @{user.username or user.first_name} получил 10 уровень!"
                )
            else:
                await save_join_date(user.id, message.chat.id)
                await send_welcome(message, user)
        return
    
    # ==== ОБРАБОТКА КОМАНД ====
    text = message.text.strip()
    text_lower = text.lower()
    
    # КУБЫ
    if text_lower == "кубы":
        if message.reply_to_message:
            challenger_id = message.from_user.id
            opponent_id = message.reply_to_message.from_user.id
            
            if challenger_id == opponent_id:
                await message.reply("❌ Нельзя играть с самим собой!")
                return
            
            if challenger_id in cube_games or opponent_id in cube_games:
                await message.reply("⚠️ Один из игроков уже участвует в игре!")
                return
            
            cube_games[challenger_id] = {"opponent": opponent_id, "step": "wait"}
            cube_games[opponent_id] = {"opponent": challenger_id, "step": "wait"}
            
            keyboard = InlineKeyboardMarkup(inline_keyboard=[
                [
                    InlineKeyboardButton(text="✅ СОГЛАСИТЬСЯ", callback_data=f"cube_accept_{message.chat.id}_{challenger_id}_{opponent_id}"),
                    InlineKeyboardButton(text="❌ ОТКАЗАТЬСЯ", callback_data=f"cube_decline_{message.chat.id}_{challenger_id}_{opponent_id}")
                ]
            ])
            
            await message.reply(
                f"🎲 **{await get_name(challenger_id)}** вызывает на кубы **{await get_name(opponent_id)}**!\n\n"
                f"👇 **{await get_name(opponent_id)}**, согласись на игру:",
                parse_mode=ParseMode.MARKDOWN,
                reply_markup=keyboard
            )
        else:
            await message.reply("ℹ️ Чтобы сыграть в кубы, ответь на сообщение противника и напиши **Кубы**", parse_mode=ParseMode.MARKDOWN)
        return
    
    # ПРОФИЛЬ
    if text_lower == "профиль":
        level = await get_role(message.from_user.id, message.chat.id)
        msg_count = await get_user_message_count(message.chat.id, message.from_user.id)
        total_msgs = await get_total_user_messages(message.from_user.id)
        join_date = await get_join_date(message.from_user.id, message.chat.id)
        
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT COUNT(*) FROM warns WHERE user_id = ? AND chat_id = ?", (message.from_user.id, message.chat.id))
        warn_count = c.fetchone()[0]
        conn.close()
        
        text_list = f"📊 **Профиль @{message.from_user.username or message.from_user.first_name}**\n"
        text_list += f"🎭 Уровень: {level}/10\n"
        text_list += f"💬 Сообщений в этом чате: {msg_count}\n"
        text_list += f"🌍 Всего сообщений в системе: {total_msgs}\n"
        text_list += f"⚠️ Варнов: {warn_count}/5\n"
        if join_date:
            text_list += f"📅 В чате с: {join_date[:10]}"
        await message.reply(text_list, parse_mode=ParseMode.MARKDOWN)
        return
    
    # ТОП
    if text_lower == "топ":
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT user_id, COUNT(*) as cnt FROM messages WHERE chat_id = ? GROUP BY user_id ORDER BY cnt DESC LIMIT 5", (message.chat.id,))
        rows = c.fetchall()
        conn.close()
        if not rows:
            await message.reply("📭 Нет сообщений.")
            return
        text_list = f"🏆 **Топ активных в {BOT_NAME}:**\n"
        for i, (uid, cnt) in enumerate(rows, 1):
            try:
                member = await bot.get_chat_member(message.chat.id, uid)
                name = f"@{member.user.username}" if member.user.username else f"id{uid}"
                text_list += f"{i}. {name} — {cnt} сообщений\n"
            except:
                pass
        await message.answer(text_list, parse_mode=ParseMode.MARKDOWN)
        return
    
    # СТАТИСТИКА
    if text_lower in ["стат", "статистика"]:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT COUNT(*) FROM messages WHERE chat_id = ?", (message.chat.id,))
        total = c.fetchone()[0]
        c.execute("SELECT COUNT(DISTINCT user_id) FROM messages WHERE chat_id = ?", (message.chat.id,))
        users = c.fetchone()[0]
        conn.close()
        await message.reply(f"📊 **Статистика чата {BOT_NAME}:**\n💬 Сообщений: {total}\n👥 Участников писало: {users}", parse_mode=ParseMode.MARKDOWN)
        return
    
    # МОЯ РОЛЬ
    if text_lower in ["моя роль", "мой уровень", "мояроль"]:
        level = await get_role(message.from_user.id, message.chat.id)
        await message.reply(f"🎭 Ваш РП-уровень в {BOT_NAME}: **{level}** из 10", parse_mode=ParseMode.MARKDOWN)
        return
    
    # АДМИНЫ
    if text_lower in ["админы", "рп админы", "список админов"]:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT user_id, level FROM rp_roles WHERE chat_id = ? AND level >= 1 ORDER BY level DESC", (message.chat.id,))
        rows = c.fetchall()
        conn.close()
        if not rows:
            await message.answer("🎭 РП-админов пока нет.")
            return
        text_list = f"👑 **РП-админы {BOT_NAME}:**\n"
        for uid, lvl in rows:
            try:
                member = await bot.get_chat_member(message.chat.id, uid)
                name = f"@{member.user.username}" if member.user.username else member.user.full_name
                text_list += f"⭐ Lv{lvl}: {name}\n"
            except:
                pass
        await message.answer(text_list, parse_mode=ParseMode.MARKDOWN)
        return

# ========== КОЛБЭКИ ДЛЯ КУБОВ ==========
@dp.callback_query(lambda c: c.data.startswith("cube_accept_"))
async def cube_accept(callback: types.CallbackQuery):
    _, _, chat_id, challenger_id, opponent_id = callback.data.split("_")
    chat_id = int(chat_id)
    challenger_id = int(challenger_id)
    opponent_id = int(opponent_id)
    
    if callback.from_user.id != opponent_id:
        await callback.answer("❌ Только вызванный игрок может согласиться!", show_alert=True)
        return
    
    await callback.message.delete()
    
    msg = await bot.send_message(
        chat_id,
        f"🎲 **Кубы начались!**\n\n"
        f"👤 {await get_name(challenger_id)} против {await get_name(opponent_id)}\n\n"
        f"⏳ Первый бросок делает {await get_name(challenger_id)}..."
    )
    
    await asyncio.sleep(1.5)
    dice1 = await bot.send_dice(chat_id, emoji="🎲")
    await asyncio.sleep(0.5)
    dice2 = await bot.send_dice(chat_id, emoji="🎲")
    total1 = dice1.dice.value + dice2.dice.value
    
    await asyncio.sleep(1)
    await bot.send_message(
        chat_id,
        f"🎲 **{await get_name(challenger_id)}** кинул кубики!\n"
        f"{dice1.dice.value} + {dice2.dice.value} = **{total1}**\n\n"
        f"⏳ Теперь очередь {await get_name(opponent_id)}..."
    )
    
    await asyncio.sleep(1.5)
    dice3 = await bot.send_dice(chat_id, emoji="🎲")
    await asyncio.sleep(0.5)
    dice4 = await bot.send_dice(chat_id, emoji="🎲")
    total2 = dice3.dice.value + dice4.dice.value
    
    await asyncio.sleep(1)
    
    if total1 > total2:
        result = f"🏆 **Победил {await get_name(challenger_id)}!** ({total1} vs {total2})"
    elif total2 > total1:
        result = f"🏆 **Победил {await get_name(opponent_id)}!** ({total1} vs {total2})"
    else:
        result = f"🤝 **Ничья!** ({total1} vs {total2})"
    
    await bot.send_message(
        chat_id,
        f"🎲 **Результат игры в кубы:**\n\n"
        f"{await get_name(challenger_id)}: {dice1.dice.value} + {dice2.dice.value} = **{total1}**\n"
        f"{await get_name(opponent_id)}: {dice3.dice.value} + {dice4.dice.value} = **{total2}**\n\n"
        f"{result}",
        parse_mode=ParseMode.MARKDOWN
    )
    
    cube_games.pop(challenger_id, None)
    cube_games.pop(opponent_id, None)
    
    await callback.answer()

@dp.callback_query(lambda c: c.data.startswith("cube_decline_"))
async def cube_decline(callback: types.CallbackQuery):
    _, _, chat_id, challenger_id, opponent_id = callback.data.split("_")
    chat_id = int(chat_id)
    challenger_id = int(challenger_id)
    opponent_id = int(opponent_id)
    
    if callback.from_user.id != opponent_id:
        await callback.answer("❌ Только вызванный игрок может отказаться!", show_alert=True)
        return
    
    await callback.message.delete()
    await bot.send_message(
        chat_id,
        f"❌ {await get_name(opponent_id)} отказался играть в кубы."
    )
    
    cube_games.pop(challenger_id, None)
    cube_games.pop(opponent_id, None)
    
    await callback.answer()

# ========== ЗАПУСК ==========
async def main():
    init_db()
    print(f"✅ {BOT_NAME} запущен!")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())