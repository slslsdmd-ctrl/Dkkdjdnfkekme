NAME_CACHE = {}

async def get_name(user_id: int, bot) -> str:
    """ПОЛУЧИТЬ ИМЯ ПОЛЬЗОВАТЕЛЯ С КЭШЕМ"""
    if user_id in NAME_CACHE:
        return NAME_CACHE[user_id]
    
    try:
        user = await bot.get_chat(user_id)
        name = f"@{user.username}" if user.username else user.first_name
        NAME_CACHE[user_id] = name
        return name
    except:
        return f"id{user_id}"

async def get_mention(user_id: int, bot) -> str:
    """ПОЛУЧИТЬ УПОМИНАНИЕ ПОЛЬЗОВАТЕЛЯ"""
    name = await get_name(user_id, bot)
    return f"[{name}](tg://user?id={user_id})"

def clear_name_cache():
    """ОЧИСТИТЬ КЭШ ИМЁН"""
    NAME_CACHE.clear()

