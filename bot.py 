async def unlock_job_achievement(user_id: int, job: str, progress: int) -> str:
    if job not in JOB_ACHIEVEMENTS:
        return None
    
    for ach in JOB_ACHIEVEMENTS[job]:
        threshold = int(ach["desc"].split()[-2]) if "100" in ach["desc"] else 0
        if threshold == 0:
            continue
        
        if progress >= threshold:
            ach_key = f"job_{job}_{threshold}"
            result = await unlock_achievement(user_id, ach_key)
            if result:
                return result
    
    return None

