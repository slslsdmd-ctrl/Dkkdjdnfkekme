        """ПОЛУЧИТЬ ЦЕНУ АКЦИИ"""
        if symbol not in STOCKS_DATA:
            return None
        
        base_price = STOCKS_DATA[symbol]['price']
        volatility = 0.03  # 3% волатильность
        
        # Случайные колебания
        change = random.uniform(-volatility * 2, volatility * 2)
        price = base_price * (1 + change)
        
        return max(1, price)
    
    async def buy_stock(self, user_id: int, symbol: str, quantity: int) -> dict:
        """КУПИТЬ АКЦИИ"""
        if symbol not in STOCKS_DATA:
            return {'error': 'Акция не найдена!'}
        
        if quantity <= 0:
            return {'error': 'Количество должно быть больше 0!'}
        
        price = await self.get_stock_price(symbol)
        total_cost = int(price * quantity)
        
        coins = await get_coins(user_id)
        if coins < total_cost:
            return {'error': f'Недостаточно монет! Нужно {total_cost}'}
        
        # Снимаем монеты
        await remove_coins(user_id, total_cost)
        
        # Добавляем акции
        await db.query(
            """INSERT INTO stocks (user_id, stock_name, quantity, avg_price) 
               VALUES (?, ?, ?, ?) 
               ON CONFLICT(user_id, stock_name) 
               DO UPDATE SET 
               quantity = quantity + ?,
               avg_price = ((avg_price * quantity) + ?) / (quantity + ?)""",
            (user_id, symbol, quantity, price, quantity, total_cost, quantity)
        )
        
        return {
            'success': True,
            'stock': symbol,
            'quantity': quantity,
            'price': price,
            'total': total_cost
        }
    
    async def sell_stock(self, user_id: int, symbol: str, quantity: int) -> dict:
        """ПРОДАТЬ АКЦИИ"""
        if symbol not in STOCKS_DATA:
            return {'error': 'Акция не найдена!'}
        
        if quantity <= 0:
            return {'error': 'Количество должно быть больше 0!'}
        
        # Проверяем наличие
        stock = await db.query(
            "SELECT quantity, avg_price FROM stocks WHERE user_id = ? AND stock_name = ?",
            (user_id, symbol),
            fetch_one=True
        )
        
        if not stock or stock['quantity'] < quantity:
            return {'error': f'Недостаточно акций! Есть {stock["quantity"] if stock else 0}'}
        
        price = await self.get_stock_price(symbol)
        total_value = int(price * quantity)
        profit = total_value - (stock['avg_price'] * quantity)
        
        # Удаляем акции
        new_quantity = stock['quantity'] - quantity
        if new_quantity == 0:
            await db.query(
                "DELETE FROM stocks WHERE user_id = ? AND stock_name = ?",
                (user_id, symbol)
            )
        else:
            await db.query(
                "UPDATE stocks SET quantity = ? WHERE user_id = ? AND stock_name = ?",
                (new_quantity, user_id, symbol)
            )
        
        # Добавляем монеты
        await add_coins(user_id, total_value)
        
        return {
            'success': True,
            'stock': symbol,
            'quantity': quantity,
            'price': price,
            'total': total_value,
            'profit': profit
        }
    
    async def get_stocks(self, user_id: int) -> list:
        """ПОЛУЧИТЬ АКЦИИ ПОЛЬЗОВАТЕЛЯ"""
        result = await db.query(
