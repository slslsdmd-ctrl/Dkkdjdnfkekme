async def save_join_date(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO user_join_date (user_id, chat_id, join_date) VALUES (?,?,?)", (user_id, chat_id, datetime.now().isoformat()))
    conn.commit()
    conn.close()

