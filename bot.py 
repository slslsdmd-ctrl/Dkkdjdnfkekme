class RPManager:
    """УПРАВЛЕНИЕ РОЛЕВЫМИ ИГРАМИ"""
    
    def __init__(self):
        self.rp_cooldowns = {}
        self.rp_stats = {}
    
    async def do_action(self, user_id: int, target_id: int, action: str) -> dict:
        """ВЫПОЛНЕНИЕ РП ДЕЙСТВИЯ"""
        if user_id == target_id:
            return {'error': 'Нельзя с самим собой!'}
        
        if action not in RP_ACTIONS:
            return {'error': 'Такого действия нет!'}
        
        # Проверяем кулдаун
        key = f"{user_id}_{action}"
        if key in self.rp_cooldowns:
            last_time = self.rp_cooldowns[key]
            if (datetime.now() - last_time).seconds < 10:
                return {'error': '⏳ Подожди 10 секунд!'}
        
        # Выбираем фразу
        phrase = random.choice(RP_ACTIONS[action]).format(
            user=await get_name(user_id),
            target=await get_name(target_id)
        )
        
        # Шанс на крит
        crit = random.random() < 0.1
        if crit:
            phrase += "\n💥 **КРИТИЧЕСКОЕ ПОПАДАНИЕ!**"
        
        # Проверяем питомца
        pet = await db.query(
            "SELECT pet_name, happiness FROM pets WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if pet and pet['happiness'] > 50 and random.random() < 0.3:
            phrase += f"\n🐕 {pet['pet_name']} помог!"
        
        # Обновляем статистику
        await self.update_stats(user_id, action)
        
        # Обновляем кулдаун
        self.rp_cooldowns[key] = datetime.now()
        
        # Добавляем опыт (1-3 монеты)
        reward = random.randint(1, 3)
        await db.add_coins(user_id, reward)
        
        # Проверяем достижения
        count = await self.get_action_count(user_id, action)
        if count == 1:
            ach = await unlock_achievement(user_id, "first_rp")
            if ach:
                phrase += f"\n\n{ach}"
        
        return {
            'success': True,
            'phrase': phrase,
            'crit': crit,
            'reward': reward,
            'action': action
        }
    
    async def update_stats(self, user_id: int, action: str):
        """ОБНОВЛЕНИЕ СТАТИСТИКИ РП"""
        key = f"{user_id}_{action}"
        self.rp_stats[key] = self.rp_stats.get(key, 0) + 1
    
    async def get_action_count(self, user_id: int, action: str) -> int:
        """ПОЛУЧЕНИЕ КОЛИЧЕСТВА ДЕЙСТВИЙ"""
        key = f"{user_id}_{action}"
        return self.rp_stats.get(key, 0)
    
    async def get_stats(self, user_id: int) -> dict:
        """ПОЛУЧЕНИЕ СТАТИСТИКИ РП"""
        stats = {}
        for key, count in self.rp_stats.items():
            if key.startswith(str(user_id)):
                action = key.split('_', 1)[1]
                stats[action] = count
        return stats

