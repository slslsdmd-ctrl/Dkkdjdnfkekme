    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT level, income, last_collect FROM businesses WHERE user_id = ? AND name = ?", (user_id, name))
        row = c.fetchone()
        if not row:
            conn.close()
            return 0
        
        level, income, last_collect = row
        last = datetime.fromisoformat(last_collect)
        now = datetime.now()
        hours = (now - last).total_seconds() / 3600
        
        if hours < 1:
            conn.close()
            return 0
        
        earned = int(income * hours)
        current_coins = await get_coins(user_id)
        if current_coins + earned > MAX_COINS:
            earned = MAX_COINS - current_coins
            if earned <= 0:
                conn.close()
                return 0
        
        c.execute("UPDATE businesses SET last_collect = ? WHERE user_id = ? AND name = ?", 
                  (now.isoformat(), user_id, name))
        conn.commit()
        conn.close()
        
        await add_coins(user_id, earned)
        return earned
    except Exception as e:
        log_error(e, "collect_business_income")
        return 0

