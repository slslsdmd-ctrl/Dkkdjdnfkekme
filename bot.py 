async def add_item(user_id, chat_id, item_name, quantity=1):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO inventory (user_id, chat_id, item_name, quantity) VALUES (?,?,?,?) ON CONFLICT(user_id, chat_id, item_name) DO UPDATE SET quantity = quantity + ?", (user_id, chat_id, item_name, quantity, quantity))
    conn.commit()
    conn.close()

async def remove_item(user_id, chat_id, item_name, quantity=1):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT quantity FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?", (user_id, chat_id, item_name))
    row = c.fetchone()
    if row and row[0] >= quantity:
        new_qty = row[0] - quantity
        if new_qty <= 0:
            c.execute("DELETE FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?", (user_id, chat_id, item_name))
        else:
            c.execute("UPDATE inventory SET quantity = ? WHERE user_id = ? AND chat_id = ? AND item_name = ?", (new_qty, user_id, chat_id, item_name))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

