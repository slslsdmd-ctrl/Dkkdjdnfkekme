    if any(prompt_lower.startswith(g) for g in greetings) or prompt_lower in greetings:
        return 'greeting'
    if any(word in prompt_lower for word in ["время", "часов", "который час", "сколько время"]):
        return 'time'
    if any(word in prompt_lower for word in ["погода", "погод", "weather"]):
