cached_rates = {}
last_update_rates = None

async def update_rates():
    global cached_rates, last_update_rates
    try:
        async with aiohttp.ClientSession() as session:
            url = "https://api.exchangerate-api.com/v4/latest/USD"
            async with session.get(url, timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    cached_rates = data["rates"]
                    last_update_rates = datetime.now()
    except:
        pass

async def get_rates():
    if not cached_rates or not last_update_rates or (datetime.now() - last_update_rates).total_seconds() > 1800:
        await update_rates()
    return cached_rates

