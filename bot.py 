    async def get_daily_quests(self, user_id: int) -> List[dict]:
        """ПОЛУЧИТЬ ЕЖЕДНЕВНЫЕ КВЕСТЫ"""
        daily_quests = [
            {"id": "daily_work", "name": "💼 Рабочий день", "desc": "Поработать 5 раз", "goal": 5, "reward": 100},
            {"id": "daily_messages", "name": "💬 Болтун", "desc": "Написать 50 сообщений", "goal": 50, "reward": 80},
            {"id": "daily_business", "name": "🏪 Бизнесмен", "desc": "Собрать доход с бизнеса", "goal": 1, "reward": 120},
            {"id": "daily_pet", "name": "🐕 Хозяин", "desc": "Покормить питомца", "goal": 1, "reward": 60},
            {"id": "daily_quiz", "name": "🧠 Эрудит", "desc": "Пройди викторину", "goal": 1, "reward": 90},
            {"id": "daily_slots", "name": "🎰 Азартный", "desc": "Сыграть в слоты 3 раза", "goal": 3, "reward": 110},
        ]
        
        quests = []
        today = datetime.now().date().isoformat()
        
        for quest in daily_quests:
            # Проверяем прогресс
            progress_result = await db.execute(
                "SELECT progress FROM quest_progress WHERE user_id = ? AND quest_id = ? AND type = 'daily'",
                (user_id, quest['id']), fetch_one=True
            )
            
            current_progress = progress_result['progress'] if progress_result else 0
            
            # Проверяем, выполнено ли сегодня
            completed_result = await db.execute(
                "SELECT id FROM quest_completed WHERE user_id = ? AND quest_id = ? AND date LIKE ?",
                (user_id, quest['id'], f"{today}%"), fetch_one=True
            )
            
            is_completed = completed_result is not None
            
            quests.append({
                'id': quest['id'],
                'name': quest['name'],
                'desc': quest['desc'],
                'progress': current_progress,
                'goal': quest['goal'],
                'reward': quest['reward'],
                'completed': is_completed
            })
        
        return quests
    
    async def update_quest(self, user_id: int, quest_id: str, amount: int = 1) -> Optional[dict]:
        """ОБНОВИТЬ ПРОГРЕСС КВЕСТА"""
        # Находим квест
        daily_quests = [
            {"id": "daily_work", "goal": 5, "reward": 100},
            {"id": "daily_messages", "goal": 50, "reward": 80},
            {"id": "daily_business", "goal": 1, "reward": 120},
            {"id": "daily_pet", "goal": 1, "reward": 60},
            {"id": "daily_quiz", "goal": 1, "reward": 90},
            {"id": "daily_slots", "goal": 3, "reward": 110},
        ]
        
        quest = next((q for q in daily_quests if q['id'] == quest_id), None)
        if not quest:
            return None
        
        # Проверяем, не выполнено ли уже
        today = datetime.now().date().isoformat()
        completed_result = await db.execute(
            "SELECT id FROM quest_completed WHERE user_id = ? AND quest_id = ? AND date LIKE ?",
            (user_id, quest_id, f"{today}%"), fetch_one=True
        )
        if completed_result:
            return None
        
        # Обновляем прогресс
        await db.execute(
            "INSERT INTO quest_progress (user_id, quest_id, type, progress) VALUES (?, ?, 'daily', ?) "
            "ON CONFLICT(user_id, quest_id) DO UPDATE SET progress = progress + ?",
            (user_id, quest_id, amount, amount)
        )
        
        # Проверяем, достигнут ли лимит
        progress_result = await db.execute(
            "SELECT progress FROM quest_progress WHERE user_id = ? AND quest_id = ? AND type = 'daily'",
            (user_id, quest_id), fetch_one=True
        )
        
        if progress_result and progress_result['progress'] >= quest['goal']:
            # Отмечаем выполненным
            await db.execute(
                "INSERT INTO quest_completed (user_id, quest_id, date) VALUES (?, ?, ?)",
                (user_id, quest_id, datetime.now().isoformat())
            )
            
            # Награда
            await add_coins(user_id, quest['reward'])
            
            return {
                'completed': True,
                'quest_id': quest_id,
                'reward': quest['reward']
            }
        
        return {
            'completed': False,
            'quest_id': quest_id,
            'progress': progress_result['progress'] if progress_result else 0,
            'goal': quest['goal']
        }

