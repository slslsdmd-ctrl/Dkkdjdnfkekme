async def handle_admin_command(message: types.Message) -> bool:
    """ОБРАБОТКА АДМИН КОМАНД"""
    text = message.text
    user_id = message.from_user.id
    
    # Только владелец
    if user_id != OWNER_ID:
        return False
    
    if text.startswith("/admin stats"):
        # Статистика бота
        stats = await admin_panel.get_bot_stats()
        await message.reply(
            f"📊 **СТАТИСТИКА БОТА**\n\n"
            f"👥 Пользователей: {stats['total_users']}\n"
            f"💬 Чатов: {stats['total_chats']}\n"
            f"💰 Всего монет: {format_large_number(stats['total_coins'])}\n"
            f"🟢 Активных: {stats['active_users_24h']}\n"
            f"📝 Сообщений: {stats['total_messages']}\n"
            f"⏱️ Аптайм: {stats['uptime']}",
            parse_mode=ParseMode.MARKDOWN
        )
        return True
    
    elif text.startswith("/admin ban"):
        # /admin ban [user_id] [reason]
        parts = text.split(maxsplit=3)
        if len(parts) >= 3:
            target_id = int(parts[2])
            reason = parts[3] if len(parts) > 3 else "Нарушение правил"
            result = await admin_panel.ban_user(target_id, reason)
            await message.reply(result["message"])
        return True
    
    elif text.startswith("/admin unban"):
        parts = text.split()
        if len(parts) >= 3:
            target_id = int(parts[2])
            result = await admin_panel.unban_user(target_id)
            await message.reply(result["message"])
        return True
    
    elif text.startswith("/admin mute"):
        parts = text.split()
        if len(parts) >= 3:
            target_id = int(parts[2])
            duration = int(parts[3]) if len(parts) > 3 else 60
            result = await admin_panel.mute_user(target_id, duration)
            await message.reply(result["message"])
        return True
    
    elif text.startswith("/admin give"):
        # /admin give [user_id] [amount]
        parts = text.split()
        if len(parts) >= 4:
            target_id = int(parts[2])
            amount = int(parts[3])
            result = await admin_panel.give_coins(target_id, amount)
            await message.reply(result["message"])
        return True
    
    elif text.startswith("/admin broadcast"):
        # /admin broadcast [message]
        parts = text.split(maxsplit=2)
        if len(parts) >= 3:
            msg = parts[2]
            result = await admin_panel.broadcast(user_id, msg)
            await message.reply(
                f"📢 **РАССЫЛКА**\n"
                f"✅ Отправлено: {result['sent_count']}/{result['total_chats']}\n"
                f"📝 Сообщение: {result['message']}...",
                parse_mode=ParseMode.MARKDOWN
            )
        return True
    
    elif text.startswith("/admin reset"):
        parts = text.split()
        if len(parts) >= 3:
            target_id = int(parts[2])
            result = await admin_panel.reset_user(target_id)
            await message.reply(result["message"])
        return True
    
    return False

