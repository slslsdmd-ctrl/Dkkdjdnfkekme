def get_cached_answer(question: str) -> str:
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    question_hash = hashlib.md5(question.lower().strip().encode()).hexdigest()
    c.execute("SELECT answer, used_count FROM ai_cache WHERE question_hash = ?", (question_hash,))
    row = c.fetchone()
    if row:
        c.execute("UPDATE ai_cache SET used_count = used_count + 1 WHERE question_hash = ?", (question_hash,))
        conn.commit()
        conn.close()
        return row[0]
    words = set(question.lower().split())
    c.execute("SELECT question, answer FROM ai_cache ORDER BY used_count DESC LIMIT 20")
    rows = c.fetchall()
    conn.close()
    for q, ans in rows:
        q_words = set(q.lower().split())
        if len(words & q_words) >= 2:
            return ans
    return None

def save_cached_answer(question: str, answer: str):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    question_hash = hashlib.md5(question.lower().strip().encode()).hexdigest()
    now = datetime.now().isoformat()
    c.execute("""INSERT OR REPLACE INTO ai_cache 
                 (question_hash, question, answer, timestamp, used_count) 
                 VALUES (?, ?, ?, ?, COALESCE((SELECT used_count FROM ai_cache WHERE question_hash = ?), 1))""",
              (question_hash, question, answer, now, question_hash))
    conn.commit()
    conn.close()

