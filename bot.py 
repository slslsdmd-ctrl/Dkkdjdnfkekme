class TaxSystem:
    """ПОЛНАЯ НАЛОГОВАЯ СИСТЕМА"""
    
    def __init__(self):
        self.tax_rates = {
            "income_tax": 0.10,      # 10% налог на доход
            "property_tax": 0.01,    # 1% налог на имущество
            "business_tax": 0.05,    # 5% налог на бизнес
            "capital_gains": 0.15,   # 15% налог на прирост капитала
            "luxury_tax": 0.20,      # 20% налог на роскошь
            "inheritance_tax": 0.10,  # 10% налог на наследство
        }
        self.tax_history = {}
        self.tax_exemptions = {}
    
    # ============================================================
    # ОСНОВНЫЕ НАЛОГИ
    # ============================================================
    
    async def calculate_income_tax(self, user_id: int, income: int) -> int:
        """РАССЧИТАТЬ НАЛОГ НА ДОХОД"""
        # Прогрессивная шкала
        if income <= 10000:
            rate = 0.05
        elif income <= 50000:
            rate = 0.10
        elif income <= 100000:
            rate = 0.15
        elif income <= 500000:
            rate = 0.20
        else:
            rate = 0.25
        
        # Проверяем льготы
        exemption = await self.check_exemption(user_id, "income")
        if exemption:
            rate = max(0, rate - 0.05)
        
        tax = int(income * rate)
        
        # Записываем историю
        key = f"tax_{user_id}_{datetime.now().strftime('%Y-%m')}"
        self.tax_history[key] = self.tax_history.get(key, 0) + tax
        
        return tax
    
    async def calculate_property_tax(self, user_id: int) -> int:
        """РАССЧИТАТЬ НАЛОГ НА ИМУЩЕСТВО"""
        # Получаем недвижимость пользователя
        properties = await get_properties(user_id)
        if not properties:
            return 0
        
        total_value = 0
        for prop in properties:
            data = REAL_ESTATE.get(prop["property_name"])
            if data:
                total_value += data["price"] * prop["level"]
        
        tax = int(total_value * self.tax_rates["property_tax"])
        
        # Записываем историю
        key = f"property_tax_{user_id}_{datetime.now().strftime('%Y-%m')}"
        self.tax_history[key] = self.tax_history.get(key, 0) + tax
        
        return tax
    
    async def calculate_business_tax(self, user_id: int) -> int:
        """РАССЧИТАТЬ НАЛОГ НА БИЗНЕС"""
        businesses = await get_businesses(user_id)
        if not businesses:
            return 0
        
        total_income = sum(b["income"] for b in businesses)
        tax = int(total_income * self.tax_rates["business_tax"])
        
        # Записываем историю
        key = f"business_tax_{user_id}_{datetime.now().strftime('%Y-%m')}"
        self.tax_history[key] = self.tax_history.get(key, 0) + tax
        
        return tax
    
    async def calculate_capital_gains_tax(self, user_id: int, profit: int) -> int:
        """РАССЧИТАТЬ НАЛОГ НА ПРИРОСТ КАПИТАЛА"""
        if profit <= 0:
            return 0
        
        tax = int(profit * self.tax_rates["capital_gains"])
        
        # Записываем историю
        key = f"capital_tax_{user_id}_{datetime.now().strftime('%Y-%m')}"
        self.tax_history[key] = self.tax_history.get(key, 0) + tax
        
        return tax
    
    async def check_exemption(self, user_id: int, tax_type: str) -> bool:
        """ПРОВЕРИТЬ ЛЬГОТУ ПО НАЛОГУ"""
        key = f"{user_id}_{tax_type}"
        if key in self.tax_exemptions:
            exemption = self.tax_exemptions[key]
            if exemption["expires"] > datetime.now():
                return True
        return False
    
    async def grant_exemption(self, user_id: int, tax_type: str, days: int) -> dict:
        """ПРЕДОСТАВИТЬ ЛЬГОТУ ПО НАЛОГУ"""
        key = f"{user_id}_{tax_type}"
        self.tax_exemptions[key] = {
            "tax_type": tax_type,
            "expires": datetime.now() + timedelta(days=days)
        }
        
        return {
            "success": True,
            "user_id": user_id,
            "tax_type": tax_type,
            "expires": self.tax_exemptions[key]["expires"].isoformat()
        }
    
    async def collect_taxes(self, user_id: int) -> dict:
        """СОБРАТЬ ВСЕ НАЛОГИ С ПОЛЬЗОВАТЕЛЯ"""
        # Получаем баланс
        coins = await get_coins(user_id)
        if coins <= 0:
            return {"error": "Нечего облагать налогом!"}
        
        # Рассчитываем налоги
        income_tax = await self.calculate_income_tax(user_id, coins)
        property_tax = await self.calculate_property_tax(user_id)
        business_tax = await self.calculate_business_tax(user_id)
        
        total_tax = income_tax + property_tax + business_tax
        
        if total_tax <= 0:
            return {"message": "Налоги не начислены!"}
        
        # Снимаем налоги
        if coins < total_tax:
            total_tax = coins  # Снимаем всё
            await remove_coins(user_id, total_tax)
            return {
                "success": True,
                "warning": "⚠️ Недостаточно средств! Сняты все монеты.",
                "total_tax": total_tax
            }
        
        await remove_coins(user_id, total_tax)
        
        return {
            "success": True,
            "income_tax": income_tax,
            "property_tax": property_tax,
            "business_tax": business_tax,
            "total_tax": total_tax,
            "remaining": await get_coins(user_id)
        }
    
    async def get_tax_history(self, user_id: int, limit: int = 10) -> List[dict]:
        """ПОЛУЧИТЬ ИСТОРИЮ НАЛОГОВ"""
        result = []
        for key, amount in self.tax_history.items():
            if str(user_id) in key:
                result.append({
                    "date": key.split("_")[-1],
                    "amount": amount
                })
        return sorted(result, key=lambda x: x["date"], reverse=True)[:limit]

