    if any(prompt_lower == cmd or prompt_lower.startswith(cmd + " ") for cmd in commands):
        return 'command'
    question_words = ["кто", "что", "где", "когда", "почему", "зачем", "как", "сколько", "какой", "какая", "какие", "чей", "чья", "чье", "ли", "расскажи", "объясни", "найди", "поищи"]
