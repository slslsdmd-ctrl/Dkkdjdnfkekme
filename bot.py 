class FriendManager:
    """УПРАВЛЕНИЕ ДРУЗЬЯМИ"""
    
    def __init__(self):
        self.friend_requests = {}
        self.friend_bonuses = {}
    
    async def add_friend(self, user_id: int, friend_id: int) -> dict:
        """ДОБАВЛЕНИЕ В ДРУЗЬЯ"""
        if user_id == friend_id:
            return {'error': 'Нельзя добавить себя!'}
        
        # Проверяем, не друзья ли уже
        existing = await db.query(
            "SELECT * FROM friends WHERE user_id = ? AND friend_id = ?",
            (user_id, friend_id),
            fetch_one=True
        )
        if existing:
            return {'error': 'Вы уже друзья!'}
        
        # Добавляем друга
        await db.query(
            "INSERT INTO friends (user_id, friend_id, chat_id, date) VALUES (?, ?, ?, ?)",
            (user_id, friend_id, 0, datetime.now().isoformat())
        )
        await db.query(
            "INSERT INTO friends (user_id, friend_id, chat_id, date) VALUES (?, ?, ?, ?)",
            (friend_id, user_id, 0, datetime.now().isoformat())
        )
        
        return {
            'success': True,
            'friend': friend_id
        }
    
    async def remove_friend(self, user_id: int, friend_id: int) -> dict:
        """УДАЛЕНИЕ ИЗ ДРУЗЕЙ"""
        await db.query(
            "DELETE FROM friends WHERE user_id = ? AND friend_id = ?",
            (user_id, friend_id)
        )
        await db.query(
            "DELETE FROM friends WHERE user_id = ? AND friend_id = ?",
            (friend_id, user_id)
        )
        
        return {
            'success': True,
            'friend': friend_id
        }
    
    async def get_friends(self, user_id: int) -> List[int]:
        """ПОЛУЧЕНИЕ СПИСКА ДРУЗЕЙ"""
        result = await db.query(
            "SELECT friend_id FROM friends WHERE user_id = ?",
            (user_id,),
            fetch_all=True,
            cache_ttl=30
        )
        return [r['friend_id'] for r in result] if result else []
    
    async def get_friend_bonus(self, user_id: int) -> float:
        """БОНУС ОТ ДРУЗЕЙ"""
        friends = await self.get_friends(user_id)
        if not friends:
            return 1.0
        
        # +1% за каждого друга (макс 20%)
        bonus = 1 + min(len(friends) * 0.01, 0.2)
        return bonus

friend_manager = FriendManager()

