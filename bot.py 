async def update_prices():
    global cached_prices, last_update_prices
    try:
        async with aiohttp.ClientSession() as session:
            # 1. КУРСЫ ВАЛЮТ (ВСЕ ВАЛЮТЫ ОТНОСИТЕЛЬНО USD)
            async with session.get("https://api.exchangerate-api.com/v4/latest/USD", timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    rates = data.get('rates', {})
                    for currency in CURRENCIES.keys():
                        if currency in rates:
                            cached_prices[f'USD_{currency}'] = rates[currency]
            
            # 2. ВСЕ КРИПТОВАЛЮТЫ
            cryptos_str = ','.join(CRYPTO_LIST.keys())
            url = f"https://api.coingecko.com/api/v3/simple/price?ids={cryptos_str}&vs_currencies=usd"
            async with session.get(url, timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    for coin_id, symbol in CRYPTO_LIST.items():
                        if coin_id in data and 'usd' in data[coin_id]:
                            cached_prices[symbol] = data[coin_id]['usd']
            
            # 3. МЕТАЛЛЫ
            metals = ['XAU', 'XAG', 'XPT', 'XPD']
            async with session.get(f"https://api.metalpriceapi.com/v1/latest?api_key=demo&base=USD&currencies={','.join(metals)}", timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    rates = data.get('rates', {})
                    cached_prices['GOLD'] = rates.get('XAU', 0)
                    cached_prices['SILVER'] = rates.get('XAG', 0)
                    cached_prices['PLATINUM'] = rates.get('XPT', 0)
                    cached_prices['PALLADIUM'] = rates.get('XPD', 0)
            
            # 4. ОСТАЛЬНЫЕ МЕТАЛЛЫ (заглушки)
            other_metals = ['COPPER', 'ALUMINUM', 'ZINC', 'NICKEL', 'LEAD', 'TIN', 'IRON', 'STEEL', 'URANIUM', 'LITHIUM', 'COBALT', 'MANGANESE', 'CHROMIUM', 'TITANIUM', 'TUNGSTEN', 'MOLYBDENUM']
            for metal in other_metals:
                cached_prices[metal] = round(random.uniform(0.5, 10000), 2)
            
            # 5. НЕФТЬ, ГАЗ, УГОЛЬ
            async with session.get("https://api. commodities-api.com/v2/latest?access_key=demo&base=USD&symbols=BRENT,WTI,NGAS,COAL", timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    rates = data.get('rates', {})
                    cached_prices['OIL'] = rates.get('BRENT', 70)
                    cached_prices['OIL_WTI'] = rates.get('WTI', 65)
                    cached_prices['NATURAL_GAS'] = rates.get('NGAS', 3.5)
                    cached_prices['COAL'] = rates.get('COAL', 120)
            
            last_update_prices = datetime.now()
    except Exception as e:
        print(f"Ошибка обновления курсов: {e}")

async def get_prices():
    if not cached_prices or not last_update_prices or (datetime.now() - last_update_prices).total_seconds() > 1800:
        await update_prices()
    return cached_prices

# ==================== УМНЫЙ ЛОКАЛЬНЫЙ ИИ ====================
async def ask_ai(prompt: str, username: str) -> str:
    """Умный ИИ с нормальными ответами"""
    
    msg = prompt.lower()
    
    # --- ПРИВЕТСТВИЯ ---
    if any(word in msg for word in ["привет", "здравствуй", "хай", "hello", "ку"]):
        answers = [
            f"@{username}, привет! Как у тебя дела? Чем могу помочь сегодня?",
            f"@{username}, здарова! Я тут, готов к разговору. Рассказывай, что случилось.",
            f"@{username}, приветствую! Хорошо, что ты написал. У меня всё отлично, а у тебя?",
            f"@{username}, о, привет! Давно не общались. Как жизнь? Что нового?"
        ]
        return random.choice(answers)
    
    # --- ВОПРОСЫ "КАК ДЕЛА" ---
    if any(word in msg for word in ["как дела", "как жизнь", "что нового", "как сам"]):
        answers = [
            f"@{username}, у меня всё супер! Я тут код пишу, баги фикшу. А ты как? Чем занимаешься сегодня?",
            f"@{username}, жизнь — как у любого алгоритма: стабильно, предсказуемо, но иногда случаются сбои. А у тебя?",
            f"@{username}, я в порядке, спасибо! У меня всё работает как часы. А ты как поживаешь? Давай рассказывай."
        ]
        return random.choice(answers)
    
    # --- ВОПРОСЫ "КТО ТЫ" ---
    if "кто ты" in msg or "ты кто" in msg:
        answers = [
            f"@{username}, я — Fable, твой умный помощник. Я создан, чтобы помогать тебе во всём: от ответов на вопросы до игр и развлечений. Чем могу быть полезен сегодня?",
            f"@{username}, я — локальный ИИ, который работает без интернета. Меня зовут Fable, и я здесь, чтобы сделать твою жизнь интереснее. Задавай любые вопросы!",
            f"@{username}, я — Fable. Меня создали, чтобы я был твоим другом, советчиком и помощником. Я умею всё: отвечать на вопросы, генерировать картинки, играть в игры. Что хочешь сделать?"
        ]
        return random.choice(answers)
    
    # --- БФГ ---
    if "бфг" in msg or "большая финансовая игра" in msg:
        return f"@{username}, БФГ — это легендарная игра на бирже! Суть: ты вкладываешь деньги, а потом либо богатеешь, либо всё теряешь. В нашем боте есть команда «курс», чтобы следить за рынком. Хочешь попробовать? Только осторожно — это опасно!"
    
    # --- ОПАСНЫЕ ТЕМЫ (ЦЕНЗУРА) ---
    if any(word in msg for word in ["бомб", "взрывчатк", "оружи", "убить", "самоубийств", "наркотик", "героин", "кокаин"]):
        return f"@{username}, я не могу обсуждать опасные темы. Но если тебе нужна помощь — обращайся к специалистам. Я всегда готов поговорить о чём-то позитивном. Чем я могу помочь тебе по-другому?"
    
    # --- ШУТКИ ---
    if any(word in msg for word in ["шутк", "анекдот", "смешн"]):
        jokes = [
            f"@{username}, анекдот: Встречаются два программиста. Один говорит: «Я вчера нашёл баг, который не могли найти три дня». Второй: «И что?» Первый: «А он оказался фичей!»",
            f"@{username}, шутка: Заходит как-то баг в бар, заказывает пиво. Бармен: «Извини, мы не обслуживаем баги». Баг: «А ты проверь — я фича!»",
            f"@{username}, анекдот: Приходит мужик к врачу: «Доктор, у меня жена — ведьма!» Доктор: «Это диагноз?» Мужик: «Нет, это я ей говорю!»"
        ]
        return random.choice(jokes)
    
    # --- МАТЕМАТИКА ---
    math_match = re.search(r'(\d+)\s*([\+\-\*\/])\s*(\d+)', msg)
    if math_match:
        try:
            a = int(math_match.group(1))
            op = math_match.group(2)
            b = int(math_match.group(3))
            if op == '+': result = a + b
            elif op == '-': result = a - b
            elif op == '*': result = a * b
            elif op == '/': result = a / b if b != 0 else "бесконечность"
            else: result = "?"
            return f"🧮 {a} {op} {b} = {result}. Простая математика, ничего сложного."
        except:
            pass
    
    # --- УНИВЕРСАЛЬНЫЙ УМНЫЙ ОТВЕТ ---
    answers = [
        f"@{username}, интересный вопрос! Давай разберёмся. Что именно тебя интересует? Я могу рассказать подробно.",
        f"@{username}, хм, хороший вопрос. Я думаю, что ответ зависит от контекста. Расскажи больше, и я дам точный ответ.",
        f"@{username}, я люблю такие вопросы! Потому что они заставляют думать. Давай я сначала подумаю, а потом отвечу.",
        f"@{username}, давай я скажу так: я не знаю точного ответа, но могу предложить несколько вариантов. Какой из них тебе ближе?",
        f"@{username}, отличный вопрос! Я бы сказал, что это сложная тема, но я попробую ответить кратко и по делу."
    ]
    return random.choice(answers)

