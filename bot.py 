async def search_google_scrape(query: str) -> list:
    encoded_query = urllib.parse.quote(query)
    url = f"https://www.google.com/search?q={encoded_query}&num=5&hl=ru"
    headers = {'User-Agent': random.choice(USER_AGENTS), 'Accept': 'text/html', 'Accept-Language': 'ru-RU,ru;q=0.9'}
    try:
        async with aiohttp.ClientSession() as session:
            await asyncio.sleep(random.uniform(0.5, 1.5))
            async with session.get(url, headers=headers, timeout=15) as response:
                if response.status == 200:
                    soup = BeautifulSoup(await response.text(), 'lxml')
                    results = []
                    for item in soup.select('div.g')[:5]:
                        try:
                            title_elem = item.select_one('h3'); snippet_elem = item.select_one('div.VwiC3b')
                            if title_elem and snippet_elem: results.append({'title': html.unescape(title_elem.get_text()), 'snippet': html.unescape(snippet_elem.get_text()), 'source': 'Google'})
                        except: continue
                    return results
    except: pass
    return []

async def search_wikipedia(query: str) -> str:
    try:
        async with aiohttp.ClientSession(headers=HTTP_HEADERS) as session:
            for lang in ("ru", "en"):
                search_url = f"https://{lang}.wikipedia.org/w/api.php?action=query&list=search&format=json&utf8=1&srlimit=3&srsearch={urllib.parse.quote(query)}"
                async with session.get(search_url, timeout=10) as resp:
                    if resp.status != 200: continue
                    data = await resp.json()
                    for page in data.get("query", {}).get("search", []):
                        title = page.get("title", "")
                        summary_url = f"https://{lang}.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title)}"
                        async with session.get(summary_url, timeout=10) as resp2:
                            if resp2.status == 200:
                                data2 = await resp2.json(); extract = data2.get("extract", "")
                                if extract and len(extract) > 50: return f"{title}\n{extract[:2000]}"
    except: pass
    return None

async def smart_web_search(query: str) -> dict:
    cache_key = hashlib.md5(f"search_{query}".encode()).hexdigest()
    conn = sqlite3.connect("fable_bot.db"); c = conn.cursor()
    c.execute("SELECT result, timestamp FROM search_cache WHERE key = ?", (cache_key,))
    row = c.fetchone(); conn.close()
    if row:
        result = json.loads(row[0])
        if datetime.now() - datetime.fromisoformat(row[1]) < timedelta(hours=24): return result
    result = None
    wiki_result = await search_wikipedia(query)
    if wiki_result: result = {'title': '', 'extract': wiki_result, 'url': '', 'source': 'Wikipedia'}
    if not result:
        google_results = await search_google_scrape(query)
        if google_results: result = {'title': google_results[0]['title'], 'extract': google_results[0]['snippet'], 'url': '', 'source': 'Google'}
    if result:
        conn = sqlite3.connect("fable_bot.db"); c = conn.cursor()
        c.execute("INSERT OR REPLACE INTO search_cache (key, result, timestamp) VALUES (?, ?, ?)", (cache_key, json.dumps(result, ensure_ascii=False), datetime.now().isoformat()))
        conn.commit(); conn.close()
    return result

# ==================== AI ====================
def build_ai_messages(prompt: str, reference_context: str = None, chat_id: int = None):
    system_prompt = "Ты — Fable, живой и умный ИИ-помощник. Общайся естественно на русском. Отвечай кратко."
    messages = [{"role": "system", "content": system_prompt}]
    if chat_id:
        context = get_dialog_context(chat_id)
        if context: messages.extend(context)
    if reference_context: messages.append({"role": "system", "content": f"Факты:\n{reference_context}"})
    messages.append({"role": "user", "content": prompt})
    return messages

async def ask_groq(messages) -> str:
    if not GROQ_API_KEY: return None
    try:
        async with aiohttp.ClientSession() as session:
            headers = {"Authorization": f"Bearer {GROQ_API_KEY}", "Content-Type": "application/json"}
            payload = {"model": "llama3-70b-8192", "messages": messages, "temperature": 0.8, "max_tokens": 500}
            async with session.post("https://api.groq.com/openai/v1/chat/completions", json=payload, headers=headers, timeout=30) as resp:
