    if cb.from_user.id == p1:
        coin_choices[(cid, p1)] = choice
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="🪙 Орёл", callback_data=f"coin_{cid}_{p1}_{p2}_орёл"),
             InlineKeyboardButton(text="🪙 Решка", callback_data=f"coin_{cid}_{p1}_{p2}_решка")]])
        await cb.message.edit_text(f"🪙 {await get_name(p2)}:", reply_markup=kb)
    else:
        coin_choices[(cid, p2)] = choice
        result = random.choice(["орёл", "решка"])
        c1, c2 = coin_choices[(cid, p1)], choice
        if c1 == result and c2 == result: txt = "🤝 Ничья!"
        elif c1 == result: txt = f"🏆 {await get_name(p1)}!"
        elif c2 == result: txt = f"🏆 {await get_name(p2)}!"
        else: txt = "😅 Никто!"
        await cb.message.edit_text(f"🪙 {result}\n{c1} vs {c2}\n{txt}", reply_markup=None)
        active_coin.discard((cid, p1, p2))

