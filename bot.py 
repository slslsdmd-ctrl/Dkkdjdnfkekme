async def get_coins(user_id: int) -> int:
    """БЫСТРОЕ ПОЛУЧЕНИЕ МОНЕТ С КЭШЕМ"""
    cache_key = f"coins_{user_id}"
    cached = get_cached(cache_key)
    if cached is not None:
        return cached
    
    result = await db_pool.execute(
        "SELECT coins FROM users WHERE user_id = ?",
        (user_id,),
        fetch_one=True,
        cache_ttl=30
    )
    coins = result['coins'] if result else 0
    set_cached(cache_key, coins)
    return min(coins, MAX_COINS)


async def add_coins(user_id: int, amount: int):
    """БЫСТРОЕ ДОБАВЛЕНИЕ МОНЕТ"""
    if amount <= 0:
        return
    
    amount = min(amount, MAX_COINS)
    
    await db_pool.execute(
        "UPDATE users SET coins = MIN(coins + ?, ?) WHERE user_id = ?",
        (amount, MAX_COINS, user_id)
    )


async def remove_coins(user_id: int, amount: int):
    """БЫСТРОЕ СНЯТИЕ МОНЕТ"""
    if amount <= 0:
        return
    
    amount = min(amount, MAX_COINS)
    
    await db_pool.execute(
        "UPDATE users SET coins = MAX(coins - ?, 0) WHERE user_id = ?",
        (amount, user_id)
    )


