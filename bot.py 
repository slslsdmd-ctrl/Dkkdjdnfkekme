class ClanWarSystem:
    """ПОЛНАЯ СИСТЕМА КЛАНОВЫХ ВОЙН"""
    
    def __init__(self):
        self.active_wars = {}
        self.war_history = {}
        self.battle_logs = {}
        self.war_stats = {}
        self.war_id = 0
    
    # ============================================================
    # ОСНОВНЫЕ ФУНКЦИИ ВОЙНЫ
    # ============================================================
    
    async def declare_war(self, chat_id: int, user_id: int, target_clan_id: int) -> dict:
        """ОБЪЯВИТЬ ВОЙНУ ДРУГОМУ КЛАНУ"""
        # Проверяем, есть ли у пользователя клан
        user_clan = await clan_manager.get_clan(user_id, chat_id)
        if not user_clan:
            return {"error": "Ты не в клане!"}
        
        # Проверяем, является ли пользователь лидером
        if user_clan["owner_id"] != user_id:
            return {"error": "Только лидер клана может объявлять войну!"}
        
        # Проверяем, существует ли целевой клан
        target_clan = await clan_manager.get_clan_by_id(target_clan_id)
        if not target_clan:
            return {"error": "Целевой клан не найден!"}
        
        # Нельзя воевать с самим собой
        if user_clan["id"] == target_clan_id:
            return {"error": "Нельзя объявлять войну своему клану!"}
        
        # Проверяем, нет ли уже активной войны
        for war in self.active_wars.values():
            if war["chat_id"] == chat_id and war["status"] == "active":
                if war["clan1"] == user_clan["id"] or war["clan2"] == user_clan["id"]:
                    return {"error": "Твой клан уже участвует в войне!"}
        
        # Проверяем кулдаун (24 часа после предыдущей войны)
        clan_key = f"clan_{user_clan['id']}"
        if clan_key in self.war_stats:
            last_war = self.war_stats[clan_key].get("last_war")
            if last_war:
                last_time = datetime.fromisoformat(last_war)
                if (datetime.now() - last_time).days < 1:
                    return {"error": "⏳ Клан может воевать раз в 24 часа!"}
        
        self.war_id += 1
        war_id = self.war_id
        
        self.active_wars[war_id] = {
            "id": war_id,
            "chat_id": chat_id,
            "clan1": user_clan["id"],
            "clan2": target_clan_id,
            "clan1_name": user_clan["name"],
            "clan2_name": target_clan["name"],
            "started": datetime.now().isoformat(),
            "status": "active",
            "score1": 0,
            "score2": 0,
            "battles": [],
            "turns": 0,
            "max_turns": 10,
            "winner": None,
            "prize": 0
        }
        
        # Записываем статистику
        self.war_stats[clan_key] = self.war_stats.get(clan_key, {})
        self.war_stats[clan_key]["last_war"] = datetime.now().isoformat()
        self.war_stats[clan_key]["wars"] = self.war_stats[clan_key].get("wars", 0) + 1
        
        return {
            "success": True,
            "war_id": war_id,
            "clan1": user_clan["name"],
            "clan2": target_clan["name"],
            "message": f"⚔️ Война объявлена! {user_clan['name']} против {target_clan['name']}!"
        }
    
    async def get_war_info(self, war_id: int) -> dict:
        """ПОЛУЧИТЬ ИНФОРМАЦИЮ О ВОЙНЕ"""
        if war_id not in self.active_wars:
            return {"error": "Война не найдена!"}
        
        war = self.active_wars[war_id]
        
        return {
            "success": True,
            "war_id": war_id,
            "clan1": war["clan1_name"],
            "clan2": war["clan2_name"],
            "score": f"{war['score1']} - {war['score2']}",
            "status": war["status"],
            "turns": war["turns"],
            "max_turns": war["max_turns"],
            "battles": war["battles"][-10:],
            "started": war["started"]
        }
    
    async def get_active_wars(self, chat_id: int) -> List[dict]:
        """ПОЛУЧИТЬ АКТИВНЫЕ ВОЙНЫ В ЧАТЕ"""
        result = []
        for war in self.active_wars.values():
            if war["chat_id"] == chat_id and war["status"] == "active":
                result.append({
                    "id": war["id"],
                    "clan1": war["clan1_name"],
                    "clan2": war["clan2_name"],
                    "score": f"{war['score1']} - {war['score2']}",
                    "turns": war["turns"],
                    "max_turns": war["max_turns"]
                })
        return result
    
    # ============================================================
    # БИТВЫ В ВОЙНЕ
    # ============================================================
    
    async def battle(self, war_id: int, user_id: int) -> dict:
        """УЧАСТВОВАТЬ В БИТВЕ"""
        if war_id not in self.active_wars:
            return {"error": "Война не найдена!"}
        
        war = self.active_wars[war_id]
        if war["status"] != "active":
            return {"error": "Война уже завершена!"}
        
        # Проверяем, принадлежит ли игрок к одному из кланов
        clan1 = await clan_manager.get_clan_by_id(war["clan1"])
        clan2 = await clan_manager.get_clan_by_id(war["clan2"])
        
        if not clan1 or not clan2:
            return {"error": "Клан не найден!"}
        
        members1 = clan1["members"].split(",") if clan1["members"] else []
        members2 = clan2["members"].split(",") if clan2["members"] else []
        
        user_in_clan1 = str(user_id) in members1
        user_in_clan2 = str(user_id) in members2
        
        if not user_in_clan1 and not user_in_clan2:
            return {"error": "Ты не участвуешь в этой войне!"}
        
        # Проверяем кулдаун битвы (5 минут)
        battle_key = f"battle_{user_id}_{war_id}"
        if battle_key in self.battle_logs:
            last_battle = self.battle_logs[battle_key]
            if (datetime.now() - last_battle).seconds < 300:
                remaining = 300 - (datetime.now() - last_battle).seconds
                return {"error": f"⏳ Подожди {remaining} секунд перед следующей битвой!"}
        
        # Находим противника из другого клана
        enemy_members = members2 if user_in_clan1 else members1
        if not enemy_members:
            return {"error": "Вражеский клан пуст!"}
        
        enemy_id = int(random.choice(enemy_members))
        
        # Расчёт силы
        user_power = random.randint(1, 20)
        enemy_power = random.randint(1, 20)
        
        # Бонусы от предметов
        user_sword = await has_item(user_id, "меч")
        enemy_sword = await has_item(enemy_id, "меч")
        
        user_power += user_sword * 2
        enemy_power += enemy_sword * 2
        
        # Бонус от питомца
        user_pet = await get_pet(user_id)
        enemy_pet = await get_pet(enemy_id)
        
        if user_pet and user_pet["happiness"] > 50:
            user_power += user_pet["level"] // 2
        if enemy_pet and enemy_pet["happiness"] > 50:
            enemy_power += enemy_pet["level"] // 2
        
        # Битва
        user_rolls = [random.randint(1, 20) for _ in range(3)]
        enemy_rolls = [random.randint(1, 20) for _ in range(3)]
        
        user_total = sum(user_rolls) + user_power
        enemy_total = sum(enemy_rolls) + enemy_power
        
        # Результат
        if user_total > enemy_total:
            if user_in_clan1:
                war["score1"] += 1
            else:
                war["score2"] += 1
            result_text = f"🏆 {await get_name(user_id)} победил {await get_name(enemy_id)}!"
            winner = user_id
        elif enemy_total > user_total:
            if user_in_clan1:
                war["score2"] += 1
            else:
                war["score1"] += 1
            result_text = f"💀 {await get_name(enemy_id)} победил {await get_name(user_id)}!"
            winner = enemy_id
        else:
            result_text = f"🤝 Ничья между {await get_name(user_id)} и {await get_name(enemy_id)}!"
            winner = None
        
        war["battles"].append(result_text)
        war["turns"] += 1
        
        # Обновляем кулдаун
        self.battle_logs[battle_key] = datetime.now()
        
        # Награда за победу
        if winner:
            await add_coins(winner, 50)
        
        # Проверяем окончание войны
        if war["turns"] >= war["max_turns"] or war["score1"] >= 5 or war["score2"] >= 5:
            return await self.end_war(war_id)
        
        return {
            "success": True,
            "result": result_text,
            "user_power": user_power,
            "enemy_power": enemy_power,
            "user_rolls": user_rolls,
            "enemy_rolls": enemy_rolls,
            "user_total": user_total,
            "enemy_total": enemy_total,
            "score": f"{war['clan1_name']} {war['score1']} - {war['score2']} {war['clan2_name']}",
            "turns": war["turns"],
            "max_turns": war["max_turns"],
            "winner": winner
        }
    
    async def end_war(self, war_id: int) -> dict:
        """ЗАВЕРШИТЬ ВОЙНУ"""
        if war_id not in self.active_wars:
            return {"error": "Война не найдена!"}
        
        war = self.active_wars[war_id]
        
        # Определяем победителя
        if war["score1"] > war["score2"]:
            winner_id = war["clan1"]
            winner_name = war["clan1_name"]
            prize = war["score1"] * 1000
        elif war["score2"] > war["score1"]:
            winner_id = war["clan2"]
            winner_name = war["clan2_name"]
            prize = war["score2"] * 1000
        else:
            winner_id = None
            winner_name = "Ничья"
            prize = 0
        
        # Награждаем победителя
        if winner_id:
            await db.query(
                "UPDATE clans SET treasury = treasury + ? WHERE id = ?",
                (prize, winner_id)
            )
            
            # Награждаем всех участников
            clan = await clan_manager.get_clan_by_id(winner_id)
            if clan:
                members = clan["members"].split(",") if clan["members"] else []
                for member in members:
                    await add_coins(int(member), 100)
        
        war["status"] = "finished"
        war["winner"] = winner_id
        war["prize"] = prize
        war["ended"] = datetime.now().isoformat()
        
        # Сохраняем в историю
        self.war_history[war_id] = war
        
        # Удаляем из активных
        del self.active_wars[war_id]
        
        return {
            "success": True,
            "winner": winner_name,
            "prize": prize,
            "score": f"{war['clan1_name']} {war['score1']} - {war['score2']} {war['clan2_name']}",
            "battles": war["battles"][-10:],
            "ended": war["ended"]
        }
    
    # ============================================================
    # СТАТИСТИКА ВОЙН
    # ============================================================
    
    async def get_clan_war_stats(self, clan_id: int) -> dict:
        """ПОЛУЧИТЬ СТАТИСТИКУ ВОЙН КЛАНА"""
        wins = 0
        losses = 0
        draws = 0
        
        for war in self.war_history.values():
            if war["clan1"] == clan_id or war["clan2"] == clan_id:
                if war["winner"] == clan_id:
                    wins += 1
                elif war["winner"] is None:
                    draws += 1
                else:
                    losses += 1
        
        return {
            "wins": wins,
            "losses": losses,
            "draws": draws,
            "total": wins + losses + draws
        }
    
    async def get_global_war_stats(self) -> dict:
        """ПОЛУЧИТЬ ГЛОБАЛЬНУЮ СТАТИСТИКУ ВОЙН"""
        total_wars = len(self.war_history)
        active_wars = len([w for w in self.active_wars.values() if w["status"] == "active"])
        
        return {
            "total_wars": total_wars,
            "active_wars": active_wars,
            "clans_in_war": len(set([w["clan1"] for w in self.war_history.values()] + [w["clan2"] for w in self.war_history.values()]))
        }

