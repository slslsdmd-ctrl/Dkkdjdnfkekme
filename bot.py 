class InheritanceSystem:
    """СИСТЕМА НАСЛЕДСТВА МЕЖДУ ИГРОКАМИ"""
    
    def __init__(self):
        self.wills = {}
        self.inheritance_log = {}
    
    async def create_will(self, user_id: int, heir_id: int, items: list) -> dict:
        """СОЗДАТЬ ЗАВЕЩАНИЕ"""
        if user_id == heir_id:
            return {"error": "Нельзя назначить себя наследником!"}
        
        # Проверяем, есть ли предметы
        inventory = await get_inventory(user_id)
        for item in items:
            if item not in [inv[0] for inv in inventory]:
                return {"error": f"У тебя нет {item}!"}
        
        self.wills[user_id] = {
            "heir": heir_id,
            "items": items,
            "created": datetime.now().isoformat()
        }
        
        return {
            "success": True,
            "heir": heir_id,
            "items": items,
            "message": f"📜 Завещание создано! Наследник: {await get_name(heir_id)}"
        }
    
    async def execute_will(self, user_id: int) -> dict:
        """ВЫПОЛНИТЬ ЗАВЕЩАНИЕ (ПРИ СМЕРТИ ИГРОКА)"""
        if user_id not in self.wills:
            return {"error": "Завещание не найдено!"}
        
        will = self.wills[user_id]
        heir_id = will["heir"]
        items = will["items"]
        
        # Передаём предметы
        for item in items:
            quantity = await has_item(user_id, item)
            if quantity > 0:
                await remove_item(user_id, item, quantity)
                await add_item(heir_id, item, quantity)
        
        # Передаём монеты (50% от баланса)
        coins = await get_coins(user_id)
        inheritance = int(coins * 0.5)
        await remove_coins(user_id, inheritance)
        await add_coins(heir_id, inheritance)
        
        # Логируем
        self.inheritance_log[user_id] = {
            "heir": heir_id,
            "items": items,
            "coins": inheritance,
            "executed": datetime.now().isoformat()
        }
        
        del self.wills[user_id]
        
        return {
            "success": True,
            "heir": heir_id,
            "items": items,
            "coins": inheritance,
            "message": f"💰 Наследство передано {await get_name(heir_id)}!"
        }

inheritance_system = InheritanceSystem()

