async def get_target_user(message: types.Message):
    if message.reply_to_message: return message.reply_to_message.from_user.id
    args = message.text.split()
    if len(args) > 1:
        try:
            member = await message.chat.get_member(args[1].replace("@", "")); return member.user.id
        except: return None
    return None

