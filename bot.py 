async def handle_all_messages(message: types.Message):
    """ГЛАВНЫЙ ОБРАБОТЧИК ВСЕХ СООБЩЕНИЙ"""
    
    if not message.text:
        return
    
    try:
        text = message.text.strip()
        text_lower = text.lower()
        user_id = message.from_user.id
        chat_id = message.chat.id
        
