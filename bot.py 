BFG_RATING = {"новичок": 0, "боец": 100, "воин": 500, "герой": 1000, "легенда": 5000, "мифический": 10000, "бессмертный": 50000}

async def bfg_rating(user_id: int, chat_id: int) -> str:
    coins = await get_coins(user_id, chat_id)
    level = await get_role(user_id, chat_id)
    for rank, req in sorted(BFG_RATING.items(), key=lambda x: x[1], reverse=True):
        if coins >= req:
            current_rank = rank
            break
    else:
        current_rank = "новичок"
    rank_list = list(BFG_RATING.items())
    next_rank = None
    next_req = 0
    for i, (rank, req) in enumerate(rank_list):
        if rank == current_rank and i < len(rank_list) - 1:
            next_rank = rank_list[i+1][0]
            next_req = rank_list[i+1][1]
            break
    txt = f"🏆 **Рейтинг**\n\n⭐ Звание: **{current_rank.upper()}**\n💰 Монет: **{coins}**\n👤 Уровень: **{level}**\n"
    if next_rank:
        need = next_req - coins
        txt += f"\n📈 До {next_rank.upper()}: **{need}** монет"
