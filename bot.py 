async def work(user_id: int) -> str:
    """Работа"""
    job = await get_job(user_id)
    if not job:
        return "❌ У тебя нет работы! Напиши `устроиться [работа]`"
    
    if job not in JOBS:
        return "❌ Такой работы нет!"
    
    # Проверяем кулдаун
    if not await can_do(user_id, "last_work", JOBS[job]["cooldown"]):
        return f"⏳ Подожди {JOBS[job]['cooldown']} секунд!"
    
    data = JOBS[job]
    salary = random.randint(data["min"], data["max"])
    
    # Бонус от предметов
    buffs = await get_item_buffs(user_id)
    for item_name, item_data in RARE_ITEMS.items():
        if item_data.get("buff_job") == job:
            if await has_item(user_id, item_name) > 0:
                salary = int(salary * item_data.get("buff_x", 1))
                break
    
    await add_coins(user_id, salary)
    await add_job_stat(user_id, job, salary)
    await set_cooldown(user_id, "last_work")
    
    # Проверяем ачивки
    stats = await get_job_stats(user_id)
    for j, count, earned in stats:
        if j == job:
            ach = await unlock_job_achievement(user_id, job, count)
            if ach:
                return f"{data['emoji']} **{job.capitalize()}**: +{salary} монет! 💰\n\n{ach}"
            break
    
    return f"{data['emoji']} **{job.capitalize()}**: +{salary} монет! 💰"

