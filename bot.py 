async def bfg_buy_estate(user_id: int, chat_id: int, estate_name: str) -> str:
    if estate_name not in REAL_ESTATE:
        return "❌ Такой недвижимости нет!"
    data = REAL_ESTATE[estate_name]
    if await get_coins(user_id, chat_id) < data["price"]:
        return f"❌ Нужно {data['price']} монет!"
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT quantity FROM bfg_estate WHERE user_id = ? AND chat_id = ? AND estate = ?", (user_id, chat_id, estate_name))
    row = c.fetchone()
    await remove_coins(user_id, chat_id, data["price"])
    if row:
        c.execute("UPDATE bfg_estate SET quantity = quantity + 1 WHERE user_id = ? AND chat_id = ? AND estate = ?", (user_id, chat_id, estate_name))
        conn.commit()
        conn.close()
        return f"✅ Куплена ещё одна {data['emoji']} {estate_name.capitalize()}!"
    else:
        c.execute("INSERT INTO bfg_estate (user_id, chat_id, estate, quantity) VALUES (?,?,?,1)", (user_id, chat_id, estate_name))
        conn.commit()
        conn.close()
        return f"✅ Куплена {data['emoji']} {estate_name.capitalize()}! Доход: +{data['income']} монет/час"

