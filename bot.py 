# ==================== GROQ ИИ ====================
async def ask_groq(prompt: str) -> str:
    """Запрос к Groq API"""
    if not GROQ_API_KEY:
        return None
    
    try:
        async with aiohttp.ClientSession() as session:
            headers = {
                "Authorization": f"Bearer {GROQ_API_KEY}",
                "Content-Type": "application/json"
            }
            payload = {
                "model": "llama3-70b-8192",
                "messages": [
                    {"role": "system", "content": "Ты — Fable. Отвечай на русском языке, по делу, без шаблонов. Если не знаешь — скажи честно. Отвечай кратко, но информативно."},
                    {"role": "user", "content": prompt}
                ],
                "temperature": 0.9,
                "max_tokens": 500
            }
            async with session.post(
                "https://api.groq.com/openai/v1/chat/completions",
                json=payload,
                headers=headers,
                timeout=30
            ) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    reply = data["choices"][0]["message"]["content"]
                    reply = re.sub(r'@\w+', '', reply)
                    return reply.strip()
                else:
                    return None
    except Exception as e:
        print(f"Groq ошибка: {e}")
        return None

# ==================== ОСНОВНАЯ ФУНКЦИЯ ИИ ====================
async def ask_ai(prompt: str) -> str:
    """Сначала кэш, потом Groq, если нет — похожий из кэша"""
    
    # 1. Проверяем кэш
    cached = get_cached_answer(prompt)
    if cached:
        return cached
    
    # 2. Пробуем Groq
    if GROQ_API_KEY:
        try:
            reply = await ask_groq(prompt)
            if reply and len(reply) > 10:
                save_cached_answer(prompt, reply)
                return reply
        except Exception as e:
            print(f"Groq ошибка: {e}")
    
    # 3. Если Groq не работает — ищем похожий в кэше
    similar = get_cached_answer(prompt)
    if similar:
        return similar
    
    # 4. Если ничего нет
    return "❌ Не могу найти ответ. Попробуй переформулировать вопрос."

