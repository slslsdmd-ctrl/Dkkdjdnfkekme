class CryptoExchange:
    """КРИПТОВАЛЮТНАЯ БИРЖА"""
    
    def __init__(self):
        self.prices = {}
        self.history = {}
        self.last_update = datetime.now()
    
    async def update_prices(self):
        """ОБНОВЛЕНИЕ КУРСОВ КРИПТОВАЛЮТ"""
        try:
            async with aiohttp.ClientSession() as session:
                ids = ",".join([c.lower() for c in CRYPTO_SYMBOLS.keys()])
                url = f"https://api.coingecko.com/api/v3/simple/price?ids={ids}&vs_currencies=usd"
                async with session.get(url, timeout=5) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        for symbol in CRYPTO_SYMBOLS:
                            key = symbol.lower()
                            if key in data and 'usd' in data[key]:
                                self.prices[symbol] = data[key]['usd']
                        self.last_update = datetime.now()
                        return
        except:
            pass
        
        # Если API не работает - генерируем случайные курсы
        for symbol, data in CRYPTO_SYMBOLS.items():
            base_price = data['price']
            volatility = 0.05
            change = random.uniform(-volatility, volatility)
            self.prices[symbol] = base_price * (1 + change)
    
    async def get_price(self, symbol: str) -> float:
        """ПОЛУЧИТЬ КУРС КРИПТОВАЛЮТЫ"""
        if symbol not in CRYPTO_SYMBOLS:
            return None
        
        if not self.prices or (datetime.now() - self.last_update).seconds > 300:
            await self.update_prices()
        
        return self.prices.get(symbol, CRYPTO_SYMBOLS[symbol]['price'])
    
