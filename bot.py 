def normalize_text(text: str) -> str: return re.sub(r"\s+", " ", (text or "").strip())

def get_time_in_city(city: str) -> str:
    try:
        cl = city.lower().strip()
        if cl in TIMEZONES: return datetime.now(pytz.timezone(TIMEZONES[cl])).strftime('%H:%M')
        for tz in pytz.all_timezones:
            if cl in tz.lower(): return datetime.now(pytz.timezone(tz)).strftime('%H:%M')
        return None
    except: return None

def get_time_response(text: str) -> str:
    tl = text.lower()
    for pfx in ["время в ", "время по ", "часов в ", "который час в "]:
        if pfx in tl:
            city = tl.split(pfx, 1)[1].strip()
            if city and len(city) > 1:
                t = get_time_in_city(city)
                if t: return f"🕐 В **{city.title()}**: {t}"
    msk = get_time_in_city("москва")
    return f"🕐 По МСК: **{msk}**" if msk else "❌ Ошибка"

async def get_weather(city: str = "Москва") -> str:
    try:
        url = f"https://wttr.in/{urllib.parse.quote(city)}?format=%C+%t+%w&lang=ru"
        async with aiohttp.ClientSession() as s:
            async with s.get(url, timeout=10) as r:
                if r.status == 200:
                    t = (await r.text()).strip().split()
                    if len(t) >= 2: return f"🌤 **{city.title()}**\n🌡 {t[1]}\n💨 {t[2] if len(t) > 2 else 'Н/Д'}"
                    return f"🌤 **{city.title()}**: {' '.join(t)}"
    except: pass
    return "❌ Не удалось"

def analyze_message(prompt: str) -> str:
    pl = prompt.lower().strip()
    greetings = ["привет", "здравствуй", "здарова", "доброе утро", "добрый вечер", "добрый день", "прив", "hello", "hi", "хелло", "хай", "салют", "ку", "здоров", "здрасте", "приветствую", "йоу", "вечер в хату"]
    if any(pl.startswith(g) for g in greetings) or pl in greetings: return 'greeting'
    if any(w in pl for w in ["время", "часов", "который час"]): return 'time'
    if any(w in pl for w in ["погода", "weather"]): return 'weather'
    cmds = ["баланс", "бонус", "работа", "профиль", "кто я", "магазин", "инвентарь", "ограбить", "кубы", "деп", "команды", "рынок", "промо", "брак", "кланы", "варн", "стата", "помощь"]
    if any(pl == c or pl.startswith(c+" ") for c in cmds): return 'command'
    qw = ["кто", "что", "где", "когда", "почему", "зачем", "как", "сколько", "какой", "какая", "какие", "расскажи", "объясни", "найди"]
    if "?" in pl or any(pl.startswith(w) for w in qw): return 'question'
    insults = ["бля", "блять", "пизда", "пиздец", "хуй", "хуя", "хуйня", "хуета", "хуесос", "ебать", "ебаный", "ебан", "заебал", "уебан", "нахуй", "сука", "дурак", "тупой", "идиот", "деб", "дебил", "даун", "слабоумный", "кретин", "придурок", "мудак", "козел", "гандон", "пидор", "лох", "чмо", "мразь", "тварь", "говно", "дерьмо", "ублюдок", "сволочь", "падла", "гнида", "шлюха", "кал", "урод", "недоумок", "отморозок", "безмозглый", "ничтожество", "убогий", "заткнись", "убейся", "пошел на", "иди на", "отъебись", "съеби", "обделён", "обделен", "смехуятина", "хуятина"]
    if any(i in pl for i in insults): return 'insult'
    if any(w in pl for w in ["хаха", "ахах", "лол", "кек", "ору", "ржу", "угар", "ржака"]): return 'emotion'
    if len(pl.split()) > 3 and any(w in pl for w in ["как", "что", "где", "когда", "почему"]): return 'question'
    if len(pl.split()) > 5: return 'statement'
    if len(pl.split()) <= 2: return 'statement'
    return 'question'

