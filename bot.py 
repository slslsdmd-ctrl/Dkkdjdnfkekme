class PetManager:
    """УПРАВЛЕНИЕ ПИТОМЦАМИ"""
    
    def __init__(self):
        self.pet_cache = {}
        self.feed_cooldowns = {}
        self.train_cooldowns = {}
    
    # ============================================================
    # ОСНОВНЫЕ ФУНКЦИИ
    # ============================================================
    
    async def adopt_pet(self, user_id: int, pet_type: str, name: str) -> dict:
        """ЗАВЕСТИ ПИТОМЦА"""
        if pet_type not in PET_TYPES:
            return {'error': 'Такого типа питомца нет! Доступно: собака, кот, птица, дракон, змея, лиса'}
        
        # Проверяем, есть ли уже питомец
        existing = await db.query(
            "SELECT * FROM pets WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        if existing:
            return {'error': 'У тебя уже есть питомец!'}
        
        # Проверяем деньги (200 монет)
        coins = await db.get_coins(user_id)
        if coins < 200:
            return {'error': 'Недостаточно монет! Нужно 200 для питомца!'}
        
        await db.add_coins(user_id, -200)
        
        # Создаём питомца
        pet_data = PET_TYPES[pet_type]
        await db.query(
            """INSERT INTO pets (user_id, pet_name, pet_type, level, xp, happiness, attack, defense) 
               VALUES (?, ?, ?, ?, ?, ?, ?, ?)""",
            (user_id, name, pet_type, 1, 0, 100, pet_data['stats']['attack'], pet_data['stats']['defense'])
        )
        
        # Очищаем кэш
        self.get_pet.cache_clear()
        
        # Достижение
        await unlock_achievement(user_id, "first_pet")
        
        return {
            'success': True,
            'name': name,
            'type': pet_type,
            'emoji': pet_data['emoji']
        }
    
    async def get_pet(self, user_id: int) -> Optional[dict]:
        """ПОЛУЧЕНИЕ ПИТОМЦА"""
        result = await db.query(
            "SELECT * FROM pets WHERE user_id = ?",
            (user_id,),
            fetch_one=True,
            cache_ttl=30
        )
        return dict(result) if result else None
    
    async def feed_pet(self, user_id: int) -> dict:
        """ПОКОРМИТЬ ПИТОМЦА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return {'error': 'У тебя нет питомца!'}
        
        # Проверяем кулдаун (1 час)
        key = f"{user_id}_feed"
        if key in self.feed_cooldowns:
            last_feed = self.feed_cooldowns[key]
            if (datetime.now() - last_feed).seconds < 3600:
                return {'error': '⏳ Питомец сыт! Подожди 1 час!'}
        
        # Проверяем еду
        pet_type = pet['pet_type']
        food_options = PET_TYPES[pet_type]['food']
        food = random.choice(food_options)
        
        # Проверяем наличие еды в инвентаре
        has_food = await db.query(
            "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = ?",
            (user_id, food),
            fetch_one=True
        )
        
        if not has_food or has_food['quantity'] < 1:
            # Покупаем еду за 10 монет
            coins = await db.get_coins(user_id)
            if coins < 10:
                return {'error': f'Недостаточно монет! Нужно 10 для {food}'}
            await db.add_coins(user_id, -10)
        else:
            # Снимаем еду
            await db.query(
                "UPDATE inventory SET quantity = quantity - 1 WHERE user_id = ? AND item_name = ?",
                (user_id, food)
            )
        
        # Обновляем счастье
        new_happiness = min(100, pet['happiness'] + 15)
        await db.query(
            "UPDATE pets SET happiness = ? WHERE user_id = ?",
            (new_happiness, user_id)
        )
        
        # Добавляем опыт
        xp_gain = random.randint(5, 15)
        await db.query(
            "UPDATE pets SET xp = xp + ? WHERE user_id = ?",
            (xp_gain, user_id)
        )
        
        # Проверяем повышение уровня
        await self.check_level_up(user_id)
        
        # Обновляем кулдаун
        self.feed_cooldowns[key] = datetime.now()
        
        return {
            'success': True,
            'food': food,
            'happiness': new_happiness,
            'xp_gain': xp_gain
        }
    
    async def train_pet(self, user_id: int) -> dict:
        """ТРЕНИРОВАТЬ ПИТОМЦА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return {'error': 'У тебя нет питомца!'}
        
        if pet['happiness'] < 30:
            return {'error': '😢 Питомец слишком несчастен! Покорми его!'}
        
        # Проверяем кулдаун (30 минут)
        key = f"{user_id}_train"
        if key in self.train_cooldowns:
            last_train = self.train_cooldowns[key]
            if (datetime.now() - last_train).seconds < 1800:
                return {'error': '⏳ Питомец устал! Подожди 30 минут!'}
        
        # Тренировка
        stat = random.choice(['attack', 'defense'])
        gain = random.randint(1, 5)
        
        # Обновляем статистику
        current_stat = pet[stat]
        await db.query(
            f"UPDATE pets SET {stat} = {stat} + ? WHERE user_id = ?",
            (gain, user_id)
        )
        
        # Немного снижаем счастье
        new_happiness = max(0, pet['happiness'] - 5)
        await db.query(
            "UPDATE pets SET happiness = ? WHERE user_id = ?",
            (new_happiness, user_id)
        )
        
        # Добавляем опыт
        xp_gain = random.randint(10, 25)
        await db.query(
            "UPDATE pets SET xp = xp + ? WHERE user_id = ?",
            (xp_gain, user_id)
        )
        
        # Проверяем повышение уровня
        await self.check_level_up(user_id)
        
        # Обновляем кулдаун
        self.train_cooldowns[key] = datetime.now()
        
        return {
            'success': True,
            'stat': stat,
            'gain': gain,
            'new_value': current_stat + gain,
            'happiness': new_happiness,
            'xp_gain': xp_gain
        }
    
    async def check_level_up(self, user_id: int) -> Optional[dict]:
        """ПРОВЕРКА ПОВЫШЕНИЯ УРОВНЯ ПИТОМЦА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return None
        
        current_level = pet['level']
        current_xp = pet['xp']
        
        # Опыт для уровня: level * 50
        required_xp = current_level * 50
        
        new_level = current_level
        new_xp = current_xp
        
        while new_xp >= required_xp:
            new_xp -= required_xp
            new_level += 1
            required_xp = new_level * 50
        
        if new_level > current_level:
            # Повышаем уровень
            await db.query(
                "UPDATE pets SET level = ?, xp = ? WHERE user_id = ?",
                (new_level, new_xp, user_id)
            )
            
            # Бонус за уровень
            bonus = new_level * 10
            await db.add_coins(user_id, bonus)
            
            # Проверяем эволюцию
            evolution = await self.check_evolution(user_id, new_level)
            
            # Очищаем кэш
            self.get_pet.cache_clear()
            
            return {
                'success': True,
                'new_level': new_level,
                'bonus': bonus,
                'evolution': evolution
            }
        
        return None
    
    async def check_evolution(self, user_id: int, level: int) -> Optional[dict]:
        """ПРОВЕРКА ЭВОЛЮЦИИ ПИТОМЦА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return None
        
        pet_type = pet['pet_type']
        evolutions = PET_TYPES[pet_type]['evolutions']
        
        # Находим эволюцию для текущего уровня
        evolution = None
        for evo in evolutions:
            if level >= evo['level']:
                evolution = evo
        
        if evolution and evolution['level'] > 1:
            # Проверяем, не было ли уже этой эволюции
            current_name = pet.get('evolution_name', pet['pet_type'])
            if current_name != evolution['name']:
                # Эволюционируем
                await db.query(
                    "UPDATE pets SET evolution_name = ? WHERE user_id = ?",
                    (evolution['name'], user_id)
                )
                
                # Достижение
                await unlock_achievement(user_id, "pet_evo")
                
                # Бонус
                await db.add_coins(user_id, 100)
                
                self.get_pet.cache_clear()
                
                return {
                    'success': True,
                    'old_name': current_name,
                    'new_name': evolution['name'],
                    'emoji': evolution['emoji']
                }
        
        return None
    
    async def pet_stats(self, user_id: int) -> dict:
        """СТАТИСТИКА ПИТОМЦА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return {'error': 'У тебя нет питомца!'}
        
        pet_data = PET_TYPES[pet['pet_type']]
        evolutions = pet_data['evolutions']
        
        current_evo = None
        next_evo = None
        
        for i, evo in enumerate(evolutions):
            if pet['level'] >= evo['level']:
                current_evo = evo
            if pet['level'] < evo['level'] and not next_evo:
                next_evo = evo
        
        return {
            'success': True,
            'name': pet['pet_name'],
            'type': pet['pet_type'],
            'emoji': pet_data['emoji'],
            'level': pet['level'],
            'xp': pet['xp'],
            'next_level_xp': pet['level'] * 50,
            'happiness': pet['happiness'],
            'attack': pet['attack'],
            'defense': pet['defense'],
            'evolution': current_evo['name'] if current_evo else pet['pet_type'],
            'next_evolution': next_evo['name'] if next_evo else 'Максимум',
            'evolution_level': next_evo['level'] if next_evo else None
        }
    
    async def pet_protect(self, user_id: int) -> bool:
        """ПИТОМЕЦ ЗАЩИЩАЕТ ХОЗЯИНА"""
        pet = await self.get_pet(user_id)
        if not pet:
            return False
        
        if pet['happiness'] < 50:
            return False
        
        if pet['level'] < 3:
            return False
        
        # Шанс защиты = уровень * 3%
        chance = min(50, pet['level'] * 3)
        return random.random() < chance / 100

