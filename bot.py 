class Casino:
    """ПОЛНЫЙ КОМПЛЕКС КАЗИНО"""
    
    def __init__(self):
        self.games = {
            'слоты': slot_machine,
            'рулетка': roulette,
            'блэкджек': blackjack,
            'покер': poker
        }
        self.balance = {}
        self.vip = {}
    
    async def get_balance(self, user_id: int) -> int:
        """БАЛАНС В КАЗИНО"""
        if user_id not in self.balance:
            self.balance[user_id] = 0
        return self.balance[user_id]
    
    async def deposit(self, user_id: int, amount: int) -> dict:
        """ПОПОЛНЕНИЕ БАЛАНСА КАЗИНО"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        coins = await db.get_coins(user_id)
        if coins < amount:
            return {'error': f'Недостаточно монет! Есть {coins}'}
        
        await db.add_coins(user_id, -amount)
        self.balance[user_id] = self.balance.get(user_id, 0) + amount
        
        # VIP статус
        if self.balance[user_id] > 10000:
            self.vip[user_id] = {
                'level': min(5, self.balance[user_id] // 10000),
                'cashback': 0.05
            }
        
        return {
            'success': True,
            'deposit': amount,
            'balance': self.balance[user_id],
            'vip': user_id in self.vip
        }
    
    async def withdraw(self, user_id: int, amount: int) -> dict:
        """ВЫВОД ИЗ КАЗИНО"""
        if user_id not in self.balance or self.balance[user_id] < amount:
            return {'error': 'Недостаточно средств в казино!'}
        
        self.balance[user_id] -= amount
        await db.add_coins(user_id, amount)
        
        return {
            'success': True,
            'withdraw': amount,
            'balance': self.balance[user_id]
        }
    
    async def play(self, user_id: int, game: str, **kwargs) -> dict:
        """ИГРА В КАЗИНО"""
        if game not in self.games:
            return {'error': 'Такой игры нет в казино!'}
        
        # Проверяем баланс
        balance = await self.get_balance(user_id)
        bet = kwargs.get('bet', 0)
        
        if bet > balance:
            return {'error': f'Недостаточно средств в казино! Есть {balance}'}
        
        # Вычитаем ставку
        self.balance[user_id] -= bet
        
        # Запускаем игру
        if game == 'слоты':
            result = await slot_machine.spin(user_id, bet)
        elif game == 'рулетка':
            result = await roulette.spin(user_id, bet, kwargs.get('bet_type', 'число'), kwargs.get('value', '0'))
        elif game == 'блэкджек':
            result = await blackjack.start_game(user_id, bet)
        else:
            return {'error': 'Игра не поддерживается'}
        
        # Начисляем выигрыш
        if result.get('success') and result.get('win', 0) > 0:
            self.balance[user_id] += result['win']
        
        return result

