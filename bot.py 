@dp.message()
async def handle_all_messages(message: types.Message):
    if not message.text: return
    text = message.text.strip(); tl = text.lower()
    uid = message.from_user.id; cid = message.chat.id

    # Админка в ЛС
    if cid == uid and uid == YOUR_ID:
        if tl.startswith("+промокод"):
            args = text.split()
            if len(args) >= 4:
                try: uses = int(args[3])
                except: uses = 1
                coins = int(args[4]) if len(args) >= 5 and args[4].isdigit() else 0
                await create_promocode(args[1].upper(), uid, coins, args[2].lower(), uses)
                await message.reply(f"✅ Промокод **{args[1].upper()}** создан!\n🎁 {RARE_ITEMS.get(args[2].lower(),{}).get('name',args[2])}\n👥 {uses} исп.\n💰 {coins} монет")
            return
        if tl.startswith("+монеты"):
            args = text.split()
            if len(args) >= 3:
                try: await add_coins(int(args[1]), int(args[1]), int(args[2])); await message.reply("✅")
                except: pass
            return
        if tl.startswith("+дать"):
            args = text.split()
            if len(args) >= 3:
                try:
                    qty = int(args[3]) if len(args) >= 4 else 1
                    await add_item(int(args[1]), int(args[1]), args[2].lower(), qty); await message.reply("✅")
                except: pass
            return

    # Чат
    if message.chat.type in ["group", "supergroup"]:
        await add_coins(uid, cid, 1); await add_msg_count(uid, cid)
        st = await get_chat_settings(cid)
        if st["anti_spam"] and await is_spam(uid, cid):
            try: await bot.restrict_chat_member(cid, uid, ChatPermissions(can_send_messages=False), until_date=datetime.now()+timedelta(minutes=10))
            except: pass
            return
        if st["anti_links"] and re.search(r'https?://|t\.me/', text) and await get_role(uid, cid) < 5:
            try: await message.delete()
            except: pass
            return

    try:
        for admin in await bot.get_chat_administrators(cid): await set_role(admin.user.id, cid, 10)
    except: pass
    if uid == YOUR_ID: await set_role(uid, cid, 10)

    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id: await bot.send_message(cid, f"👑 **{BOT_NAME} активирован!**\nКоманды: `команды`", parse_mode=ParseMode.MARKDOWN); continue
        return

    is_reply = message.reply_to_message and message.reply_to_message.from_user.id == bot.id
    is_fable = "фабле" in tl or "fable" in tl
    is_mention = f"@{BOT_USERNAME}" in tl

    if is_reply or is_fable or is_mention:
        clean = text
        if is_mention: clean = re.sub(rf"@{BOT_USERNAME}", "", clean, flags=re.IGNORECASE).strip()
        else: clean = re.sub(r"(?i)\bфабле\b|\bfable\b", "", clean).strip()
        cl = clean.lower()

        if cl.startswith(("сгенерируй","нарисуй","фото","покажи")):
            for pfx in ["сгенерируй","нарисуй","фото","покажи"]:
                if cl.startswith(pfx): prompt = clean[len(pfx):].strip(); break
            if prompt:
                await bot.send_chat_action(cid, "upload_photo")
                img = await generate_image(prompt)
                if img:
                    try: await bot.send_photo(cid, img, caption=f"🎨 {prompt}")
                    except: await message.reply(f"❌ Ошибка!\n{img}")
                else: await message.reply("❌ Не удалось")
                return

        if any(w in cl for w in ["время","часов","который час"]):
            await message.reply(get_time_response(cl), parse_mode=ParseMode.MARKDOWN); return

        if any(w in cl for w in ["дата","число","какое сегодня"]):
            await message.reply(f"📅 **{datetime.now().strftime('%d.%m.%Y')}**", parse_mode=ParseMode.MARKDOWN); return

