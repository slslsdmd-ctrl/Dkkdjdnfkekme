class BattleSystem:
    """СИСТЕМА БИТВ МЕЖДУ ИГРОКАМИ"""
    
    def __init__(self):
        self.duels = {}
        self.arena_stats = {}
        self.duel_id = 0
    
    async def start_duel(self, user_id: int, target_id: int, bet: int) -> dict:
        """НАЧАТЬ ДУЭЛЬ"""
        if user_id == target_id:
            return {"error": "Нельзя с самим собой!"}
        
        if bet <= 0:
            return {"error": "Ставка должна быть больше 0!"}
        
        coins = await get_coins(user_id)
        if coins < bet:
            return {"error": f"У тебя нет {bet} монет!"}
        
        coins2 = await get_coins(target_id)
        if coins2 < bet:
            return {"error": f"У {await get_name(target_id)} нет {bet} монет!"}
        
        self.duel_id += 1
        duel_id = self.duel_id
        
        self.duels[duel_id] = {
            "user1": user_id,
            "user2": target_id,
            "bet": bet,
            "status": "waiting",
            "started": datetime.now().isoformat(),
            "winner": None
        }
        
        return {
            "success": True,
            "duel_id": duel_id,
            "user1": user_id,
            "user2": target_id,
            "bet": bet,
            "message": f"⚔️ {await get_name(user_id)} вызывает {await get_name(target_id)} на дуэль! Ставка: {bet} монет!"
        }
    
    async def accept_duel(self, duel_id: int, user_id: int) -> dict:
        """ПРИНЯТЬ ДУЭЛЬ"""
        if duel_id not in self.duels:
            return {"error": "Дуэль не найдена!"}
        
        duel = self.duels[duel_id]
        if duel["user2"] != user_id:
            return {"error": "Это не тебя вызывают!"}
        
        if duel["status"] != "waiting":
            return {"error": "Дуэль уже завершена!"}
        
        # Снимаем ставки
        await remove_coins(duel["user1"], duel["bet"])
        await remove_coins(duel["user2"], duel["bet"])
        
        duel["status"] = "active"
        
        # Проводим бой
        result = await self.fight(duel_id)
        
        return result
    
    async def fight(self, duel_id: int) -> dict:
        """ПРОВЕСТИ БОЙ"""
        if duel_id not in self.duels:
            return {"error": "Дуэль не найдена!"}
        
        duel = self.duels[duel_id]
        
        user1_power = random.randint(1, 20)
        user2_power = random.randint(1, 20)
        
