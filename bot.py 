async def get_target_user(message: types.Message):
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    args = message.text.split()
    if len(args) > 1:
        target = args[1].replace("@", "")
        try:
            member = await message.chat.get_member((await bot.get_chat_member(message.chat.id, target)).user.id)
            return member.user.id
        except:
            return None
    return None

async def roulette_shoot(chat_id, player_id, opponent_id):
    player_name = await get_name(player_id)
    opponent_name = await get_name(opponent_id)
    if player_id not in roulette_games or opponent_id not in roulette_games:
        await bot.send_message(chat_id, "Игра уже завершена!")
        return
    game_data = roulette_games[player_id]
    bullets = game_data.get("bullets", [])
    if not bullets:
        await bot.send_message(chat_id, "Патроны кончились! Ничья!")
        roulette_games.pop(player_id, None)
        roulette_games.pop(opponent_id, None)
        return
    shot = bullets.pop(0)
    if shot == 1:
        roulette_games.pop(player_id, None)
        roulette_games.pop(opponent_id, None)
        await bot.send_message(chat_id, f"**{player_name}** нажал на курок...\n\n**БОЕВОЙ ПАТРОН!**\n\n **{player_name}** убит!\n\n**Победитель:** {opponent_name}!", parse_mode=ParseMode.MARKDOWN)
        return
    else:
        next_player = opponent_id
        if len(bullets) == 0:
            await bot.send_message(chat_id, f"**{player_name}** нажал на курок...\n\n**ХОЛОСТОЙ!** Повезло!\n\nПатроны кончились! Ничья!", parse_mode=ParseMode.MARKDOWN)
            roulette_games.pop(player_id, None)
            roulette_games.pop(opponent_id, None)
            return
        await bot.send_message(chat_id, f"**{player_name}** нажал на курок...\n\n**ХОЛОСТОЙ!** Повезло!\n\nТеперь очередь **{opponent_name}**...\nОсталось патронов: {len(bullets)}", parse_mode=ParseMode.MARKDOWN)
        roulette_games[player_id]["turn"] = next_player
        roulette_games[player_id]["bullets"] = bullets
        roulette_games[opponent_id]["turn"] = next_player
        roulette_games[opponent_id]["bullets"] = bullets
        keyboard = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="ВЫСТРЕЛИТЬ", callback_data=f"roulette_shoot_{chat_id}_{next_player}_{player_id}")]
        ])
        await bot.send_message(chat_id, f"**{opponent_name}**, твой ход! Нажми на кнопку, чтобы выстрелить:", parse_mode=ParseMode.MARKDOWN, reply_markup=keyboard)
        return

