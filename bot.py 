async def get_target_user(message: types.Message):
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    if not message.text:
        return None
    args = message.text.split()
    if len(args) > 1:
        try:
            if args[1].isdigit():
                return int(args[1])
            username = args[1].replace("@", "").strip()
            if username:
                try:
                    member = await message.chat.get_member(username)
                    return member.user.id
                except Exception:
                    try:
                        user = await bot.get_chat(username)
                        return user.id
                    except Exception:
                        pass
        except Exception:
            pass
    return None

