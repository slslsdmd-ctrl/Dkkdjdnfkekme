async def can_do(user_id: int, action: str, seconds: int) -> bool:
    """Проверяет, может ли пользователь выполнить действие"""
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute(f"SELECT {action} FROM users WHERE user_id = ?", (user_id,))
        row = c.fetchone()
        conn.close()
        
        if not row or not row[0]:
            return True
        
        last = datetime.fromisoformat(row[0])
        elapsed = (datetime.now() - last).total_seconds()
        return elapsed >= seconds
    except Exception as e:
