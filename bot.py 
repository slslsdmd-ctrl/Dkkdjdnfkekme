async def ask_groq(messages) -> str:
    """Отправляет запрос в Groq AI"""
    if not GROQ_API_KEY:
        return None
    
    try:
        async with aiohttp.ClientSession() as session:
            headers = {
                "Authorization": f"Bearer {GROQ_API_KEY}",
                "Content-Type": "application/json"
            }
            payload = {
                "model": "llama3-70b-8192",
                "messages": messages,
                "temperature": 0.8,
                "max_tokens": 500
            }
            
            async with session.post(
                "https://api.groq.com/openai/v1/chat/completions",
                json=payload,
                headers=headers,
                timeout=30
            ) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return data["choices"][0]["message"]["content"].strip()
    except Exception as e:
        print(f"Groq error: {e}")
    
    return None


async def ask_pollinations(messages) -> str:
    """Отправляет запрос в Pollinations AI"""
    try:
        headers = {"Content-Type": "application/json"}
        if POLLINATIONS_API_KEY:
            headers["Authorization"] = f"Bearer {POLLINATIONS_API_KEY}"
        
        payload = {
            "model": "openai",
            "messages": messages,
            "temperature": 0.8,
            "max_tokens": 500
        }
        
        async with aiohttp.ClientSession() as session:
            async with session.post(
                "https://gen.pollinations.ai/v1/chat/completions",
                json=payload,
                headers=headers,
                timeout=30
            ) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    return data["choices"][0]["message"]["content"].strip()
    except Exception as e:
        print(f"Pollinations error: {e}")
    
    return None


async def ask_llm(prompt: str, reference_context: str = None, chat_id: int = None) -> str:
    """Основная функция общения с AI"""
    mode = await get_bot_mode(chat_id) if chat_id else 'normal'
    messages = build_ai_messages(prompt, reference_context, chat_id, mode)
    
    reply = await ask_groq(messages)
    if reply and len(reply) > 5:
        return reply
    
    reply = await ask_pollinations(messages)
    if reply and len(reply) > 5:
        return reply
    
    return None


def get_cached_answer(question: str) -> str:
    """Получает ответ из кэша"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    q_hash = hashlib.md5(question.lower().encode()).hexdigest()
    c.execute("SELECT answer FROM ai_cache WHERE question_hash = ?", (q_hash,))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None


def save_cached_answer(question: str, answer: str):
    """Сохраняет ответ в кэш"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    q_hash = hashlib.md5(question.lower().encode()).hexdigest()
    now = datetime.now().isoformat()
    c.execute(
        "INSERT OR REPLACE INTO ai_cache (question_hash, question, answer, timestamp) VALUES (?, ?, ?, ?)",
        (q_hash, question, answer, now)
    )
    conn.commit()
    conn.close()


async def ask_ai(prompt: str, chat_id: int = None, user_id: int = None) -> str:
    """Главная функция обработки сообщений через AI"""
    prompt = normalize_text(prompt)
    prompt_lower = prompt.lower()
    msg_type = analyze_message(prompt)
    
    print(f"📝 [{msg_type}] {prompt}")
    
    if chat_id and user_id:
        await save_dialog(chat_id, user_id, "user", prompt)
    
    # Локальные ответы
    smart_local = get_local_smart_answer(prompt)
    if smart_local:
        return smart_local
    
    # Приветствия
    if msg_type == 'greeting':
        replies = [
            "👋 Привет! Чем могу помочь?",
            "👋 Здравствуй! Как дела?",
            "😊 Привет-привет! Рад тебя видеть!",
            "👋 Доброго времени суток!"
        ]
        return random.choice(replies)
    
    # Время
    if msg_type == 'time':
        return get_time_response(prompt_lower)
    
    # Погода
    if msg_type == 'weather':
        city = "Москва"
        for prefix in ["погода в ", "погода "]:
            if prompt_lower.startswith(prefix):
                city = prompt_lower[len(prefix):].strip() or "Москва"
                break
        return await get_weather(city)
    
    # Оскорбления — НЕ ИЩЕМ В ВИКИПЕДИИ!
    if msg_type == 'insult':
        replies = [
            "😅 Сам такой!",
            "🤷‍♂️ Ок, как скажешь",
            "😏 И это всё на что ты способен?",
            "🙃 Я не обижаюсь, я же бот",
            "😊 Давай лучше о чём-то интересном поговорим!",
            "🤖 Мой процессор не воспринимает оскорбления, но мне всё равно обидно!",
            "😎 Твои оскорбления мне как комплименты!",
            "🤔 Серьёзно? И это всё?",
            "😴 Скучно. Придумай что-то пооригинальнее!",
            "🤖 Я бот, у меня нет чувств. Но осадочек остался..."
        ]
        return random.choice(replies)
    
    # Эмоции — НЕ ИЩЕМ!
    if msg_type == 'emotion':
        if any(w in prompt_lower for w in ["хаха", "ахах", "лол", "кек", "ору", "ржу"]):
            return "😄 Ахах, понимаю! Самому смешно!"
        if any(w in prompt_lower for w in ["грустно", "печаль", "жаль"]):
            return "😊 Не грусти! Всё будет хорошо! Держись!"
        return "🤔 Понимаю твои чувства!"
    
    # Кэш
    cached = get_cached_answer(prompt)
    if cached:
        return cached
    
    # ВСЕГДА сначала пробуем AI, а не поиск
    try:
        reply = await ask_llm(prompt, chat_id=chat_id)
        if reply and len(reply) > 5:
            save_cached_answer(prompt, reply)
            if chat_id:
                await save_dialog(chat_id, 0, "assistant", reply)
            return reply
    except:
        pass
    
    # Только если AI не ответил и это ВОПРОС — ищем в интернете
    if msg_type == 'question' and len(prompt_lower.split()) >= 3:
        search_result = await smart_web_search(prompt)
        if search_result and search_result.get('extract'):
            result = f"🔍 {search_result.get('source', '')}:\n{search_result['extract'][:1500]}"
            return result
    
    return "Я не совсем понял. Можешь переформулировать? 🤔"


