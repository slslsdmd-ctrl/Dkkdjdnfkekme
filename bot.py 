async def clan_war_start(chat_id: int, user_id: int, clan1_id: int, clan2_id: int) -> str:
    """Начинает войну между кланами"""
    user_clan = await get_user_clan(user_id, chat_id)
    if not user_clan:
        return "❌ Ты не в клане!"
    
    if user_clan[0] != clan1_id and user_clan[3] != clan1_id:
        return "❌ Ты не являешься лидером клана!"
    
    if chat_id in CLAN_WARS:
        return "❌ В этом чате уже идет война!"
    
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    c.execute("SELECT name, members FROM clans WHERE id = ? AND chat_id = ?", (clan1_id, chat_id))
    clan1 = c.fetchone()
    
    c.execute("SELECT name, members FROM clans WHERE id = ? AND chat_id = ?", (clan2_id, chat_id))
    clan2 = c.fetchone()
    
    if not clan1 or not clan2:
        conn.close()
        return "❌ Один из кланов не найден!"
    
    CLAN_WARS[chat_id] = {
        'clan1': clan1_id,
        'clan2': clan2_id,
        'clan1_name': clan1[0],
        'clan2_name': clan2[0],
        'status': 'active',
        'score1': 0,
        'score2': 0,
        'battles': []
    }
    
    conn.close()
    return f"⚔️ **ВОЙНА МЕЖДУ КЛАНАМИ!**\n"
    f"🏰 {clan1[0]} VS {clan2[0]}\n"
    f"📝 `война битва` — начать битву"

async def clan_war_battle(chat_id: int, user_id: int) -> str:
    """Битва в войне кланов"""
    if chat_id not in CLAN_WARS:
        return "❌ Нет активной войны!"
    
    war = CLAN_WARS[chat_id]
    
    # Проверяем, принадлежит ли игрок одному из кланов
    user_clan = await get_user_clan(user_id, chat_id)
    if not user_clan:
        return "❌ Ты не в клане!"
    
    if user_clan[0] not in [war['clan1'], war['clan2']]:
        return "❌ Твой клан не участвует в войне!"
    
    # Находим противника из другого клана
    conn = sqlite3.connect("fable_bot.db")
