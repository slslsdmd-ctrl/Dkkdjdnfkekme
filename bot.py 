async def open_case(user_id, chat_id):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT item_name, rarity FROM case_items WHERE chat_id = ? ORDER BY RANDOM() LIMIT 1", (chat_id,))
    row = c.fetchone()
    conn.close()
    if row:
        await add_item(user_id, chat_id, row[0])
        return row[0], row[1]
