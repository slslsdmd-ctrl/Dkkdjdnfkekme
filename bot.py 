    row = c.fetchone()
    if row and row[0] >= quantity:
        new_qty = row[0] - quantity
        if new_qty <= 0: c.execute("DELETE FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?", (user_id, chat_id, item_name))
        else: c.execute("UPDATE inventory SET quantity = ? WHERE user_id = ? AND chat_id = ? AND item_name = ?", (new_qty, user_id, chat_id, item_name))
        conn.commit(); conn.close(); return True
    conn.close(); return False

async def get_item_buffs(user_id, chat_id):
    items = await get_inventory(user_id, chat_id)
    buffs = {"buff_x": 1, "bonus_chance": 0, "bonus_amount": 0, "cooldown_reduce": 0, "protect_chance": 0, "rob_bonus": 0, "business_x": 1, "business_discount": 0, "msg_bonus": 0, "passive_income": 0}
    for item_name, qty in items:
        if item_name in RARE_ITEMS:
            data = RARE_ITEMS[item_name]
            for key in buffs:
                if key in data:
                    if key in ["buff_x", "business_x"]: buffs[key] = max(buffs[key], data[key])
                    else: buffs[key] += data[key] * qty
    return buffs

