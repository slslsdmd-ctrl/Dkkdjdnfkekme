            2: {"name": "🥈 Серебряный VIP", "price": 50000, "bonus": 1.10, "perks": ["daily_bonus_x3", "work_bonus"]},
            3: {"name": "🥇 Золотой VIP", "price": 100000, "bonus": 1.20, "perks": ["daily_bonus_x5", "work_bonus", "no_tax"]},
