async def update_prices():
    global cached_prices, last_update_prices
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get("https://api.exchangerate-api.com/v4/latest/USD", timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    rates = data.get('rates', {})
                    for currency in CURRENCIES.keys():
                        if currency in rates:
                            cached_prices[f'USD_{currency}'] = rates[currency]
            
            cryptos_str = ','.join(CRYPTO_LIST.keys())
            url = f"https://api.coingecko.com/api/v3/simple/price?ids={cryptos_str}&vs_currencies=usd"
            async with session.get(url, timeout=15) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    for coin_id, symbol in CRYPTO_LIST.items():
                        if coin_id in data and 'usd' in data[coin_id]:
                            cached_prices[symbol] = data[coin_id]['usd']
            
            metals = ['XAU', 'XAG']
            async with session.get(f"https://api.metalpriceapi.com/v1/latest?api_key=demo&base=USD&currencies={','.join(metals)}", timeout=10) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    rates = data.get('rates', {})
                    cached_prices['GOLD'] = rates.get('XAU', 0)
                    cached_prices['SILVER'] = rates.get('XAG', 0)
            
            cached_prices['OIL'] = round(random.uniform(60, 80), 2)
            cached_prices['NATURAL_GAS'] = round(random.uniform(2.5, 4.5), 2)
            cached_prices['URANIUM'] = round(random.uniform(40, 60), 2)
            cached_prices['COAL'] = round(random.uniform(100, 150), 2)
            cached_prices['COPPER'] = round(random.uniform(3, 5), 2)
            cached_prices['ALUMINUM'] = round(random.uniform(1.5, 3), 2)
            
            last_update_prices = datetime.now()
    except Exception as e:
        print(f"Ошибка обновления курсов: {e}")

async def get_prices():
    if not cached_prices or not last_update_prices or (datetime.now() - last_update_prices).total_seconds() > 1800:
        await update_prices()
    return cached_prices

