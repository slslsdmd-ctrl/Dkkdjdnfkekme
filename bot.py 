@dp.callback_query(lambda c: c.data.startswith("duel_shoot_"))
async def duel_shoot(callback: types.CallbackQuery):
    data = callback.data.split("_")
    if len(data) < 4:
        await callback.answer("Ошибка в данных!", show_alert=True)
        return
    _, chat_id, turn_id = data[0], int(data[1]), int(data[2])
    chat_id = int(chat_id)
    turn_id = int(turn_id)
    if callback.from_user.id != turn_id:
        await callback.answer("Сейчас не твой ход!", show_alert=True)
        return
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT challenger, opponent, aim_bonus FROM duels WHERE chat_id = ?", (chat_id,))
    row = c.fetchone()
    conn.close()
    if not row:
        await callback.answer("Дуэль уже завершена!", show_alert=True)
        return
    challenger, opponent, aim_bonus = row
    chance = 10 + (aim_bonus * 10)
    shot = random.randint(1, 100)
    hit = shot <= chance
    if hit:
        winner = callback.from_user.id
        loser = challenger if winner == opponent else opponent
        await end_duel(chat_id, winner, loser, f"**ПОПАЛ!** {await get_name(winner)} выстрелил и попал!")
        await callback.answer("Попал!")
    else:
        await callback.answer("Промах!")
        new_turn = challenger if callback.from_user.id == opponent else opponent
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("UPDATE duels SET turn = ?, aim_bonus = 0 WHERE chat_id = ?", (new_turn, chat_id))
        conn.commit()
        conn.close()
        await bot.send_message(chat_id, f"**{await get_name(callback.from_user.id)}** промахнулся!\nТеперь ход {await get_name(new_turn)}")
        await send_duel_turn(chat_id, challenger, opponent, 0, new_turn)

