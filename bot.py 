@dp.callback_query(lambda c: c.data.startswith("myes_"))
async def marry_yes(cb: types.CallbackQuery):
    try:
        _, cid, tid, pid = cb.data.split("_")
        cid, tid, pid = int(cid), int(tid), int(pid)
        if cb.from_user.id != tid:
            await cb.answer("❌ Это не тебе предлагают!", show_alert=True)
            return
        await set_marriage(tid, cid, pid)
        await set_marriage(pid, cid, tid)
        await cb.message.edit_text(f"💍 Поздравляем! {await get_name(pid)} и {await get_name(tid)} теперь в браке!")
        ach = await unlock_achievement(tid, cid, "first_marriage")
        if ach:
            await bot.send_message(cid, ach, parse_mode=ParseMode.MARKDOWN)
    except Exception as e:
        log_error(e, "marry_yes")

@dp.callback_query(lambda c: c.data.startswith("mno_"))
async def marry_no(cb: types.CallbackQuery):
    try:
        _, cid, tid, pid = cb.data.split("_")
        cid, tid = int(cid), int(tid)
        if cb.from_user.id != tid:
            await cb.answer("❌ Это не тебе предлагают!", show_alert=True)
            return
        await cb.message.edit_text("❌ Предложение отклонено!")
    except Exception as e:
        log_error(e, "marry_no")

