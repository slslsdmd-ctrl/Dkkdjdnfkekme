    await asyncio.sleep(1); await bot.send_message(cid, f"🎲 {await get_name(oid)}: {', '.join(map(str,r2))} = **{t2}**")
    if t1 > t2: await add_coins(cid2, cid, 50); await bot.send_message(cid, f"🏆 {await get_name(cid2)}!")
    elif t2 > t1: await add_coins(oid, cid, 50); await bot.send_message(cid, f"🏆 {await get_name(oid)}!")

