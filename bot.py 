async def upgrade_business(user_id: int, chat_id: int, name: str):
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT level, income FROM businesses WHERE user_id = ? AND chat_id = ? AND name = ?", (user_id, chat_id, name))
        row = c.fetchone()
        if not row:
            conn.close()
            return None, None
        level, income = row
        data = BUSINESSES[name]
        if level >= data["max_level"]:
            conn.close()
            return "max", None
        new_level = level + 1
        new_income = income + data["upgrade_income"]
        c.execute("UPDATE businesses SET level = ?, income = ? WHERE user_id = ? AND chat_id = ? AND name = ?", (new_level, new_income, user_id, chat_id, name))
        conn.commit()
        conn.close()
        return new_level, new_income
    except Exception as e:
        log_error(e, "upgrade_business")
        return None, None

