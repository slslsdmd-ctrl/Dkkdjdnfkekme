async def withdraw_bank(user_id: int, chat_id: int, amount: int) -> bool:
    """Снимает деньги из банка"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT balance FROM bank WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    if row and row[0] >= amount:
        c.execute(
            "UPDATE bank SET balance = balance - ? WHERE user_id = ? AND chat_id = ?",
            (amount, user_id, chat_id)
        )
        conn.commit()
        conn.close()
        await add_coins(user_id, chat_id, amount)
        return True
    conn.close()
    return False


