async def buy_stock(user_id: int, stock: str, quantity: int) -> dict:
    """ПОКУПКА АКЦИЙ"""
    if stock not in STOCKS:
        return {'error': 'Акция не найдена!'}
    
    if quantity <= 0:
        return {'error': 'Количество должно быть больше 0!'}
    
    price = await margin_trader.get_stock_price(stock)
    if not price:
        return {'error': 'Не удалось получить цену'}
    
    total_cost = int(price * quantity)
    current_coins = await db.get_coins(user_id)
    
    if current_coins < total_cost:
        return {'error': f'Недостаточно монет! Нужно {total_cost}'}
    
    # Снимаем монеты
    await db.add_coins(user_id, -total_cost)
    
    # Добавляем акции
    await db.query(
        """INSERT INTO stocks (user_id, stock_name, quantity, avg_price) 
           VALUES (?, ?, ?, ?) 
           ON CONFLICT(user_id, stock_name) 
           DO UPDATE SET 
           quantity = quantity + ?,
           avg_price = ((avg_price * quantity) + ?) / (quantity + ?)""",
        (user_id, stock, quantity, price, quantity, total_cost, quantity)
    )
    
    return {
        'success': True,
        'stock': stock,
        'quantity': quantity,
        'price': price,
        'total': total_cost
    }

async def sell_stock(user_id: int, stock: str, quantity: int) -> dict:
    """ПРОДАЖА АКЦИЙ"""
    if stock not in STOCKS:
        return {'error': 'Акция не найдена!'}
    
    if quantity <= 0:
        return {'error': 'Количество должно быть больше 0!'}
    
    # Проверяем наличие
    current = await db.query(
        "SELECT quantity, avg_price FROM stocks WHERE user_id = ? AND stock_name = ?",
        (user_id, stock),
        fetch_one=True
    )
    
    if not current or current['quantity'] < quantity:
        return {'error': f'Недостаточно акций! Есть {current["quantity"] if current else 0}'}
    
    price = await margin_trader.get_stock_price(stock)
    if not price:
        return {'error': 'Не удалось получить цену'}
    
    total_value = int(price * quantity)
    profit = total_value - (current['avg_price'] * quantity)
    
    # Удаляем акции
    new_quantity = current['quantity'] - quantity
    if new_quantity == 0:
        await db.query(
            "DELETE FROM stocks WHERE user_id = ? AND stock_name = ?",
            (user_id, stock)
        )
    else:
        await db.query(
            "UPDATE stocks SET quantity = ? WHERE user_id = ? AND stock_name = ?",
            (new_quantity, user_id, stock)
        )
    
    # Добавляем монеты
    await db.add_coins(user_id, total_value)
    
    return {
        'success': True,
        'stock': stock,
        'quantity': quantity,
        'price': price,
        'total': total_value,
        'profit': int(profit)
    }

async def get_stocks(user_id: int) -> List[dict]:
    """ПОЛУЧЕНИЕ АКЦИЙ ПОЛЬЗОВАТЕЛЯ"""
    result = await db.query(
        "SELECT * FROM stocks WHERE user_id = ?",
        (user_id,),
        fetch_all=True,
        cache_ttl=30
    )
    return result or []

