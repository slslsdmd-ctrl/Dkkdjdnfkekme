async def set_reminder(uid, cid, text, minutes):
    """Устанавливает напоминание"""
    remind_time = datetime.now() + timedelta(minutes=minutes)
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO reminders (user_id, chat_id, text, remind_time) VALUES (?,?,?,?)",
              (uid, cid, text, remind_time.isoformat()))
    conn.commit()
    conn.close()
    await asyncio.sleep(minutes * 60)
    try:
        await bot.send_message(cid, f"⏰ **Напоминание для {await get_name(uid)}**\n\n{text}")
        c.execute("UPDATE reminders SET completed=1 WHERE user_id=? AND chat_id=? AND text=?",
                  (uid, cid, text))
        conn.commit()
    except:
        pass


