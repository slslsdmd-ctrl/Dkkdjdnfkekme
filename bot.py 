    c.execute("SELECT COUNT(DISTINCT chat_id) FROM messages")
    chats = c.fetchone()[0]
    c.execute("SELECT COUNT(DISTINCT user_id) FROM messages")
    users = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM messages")
    msgs = c.fetchone()[0]
    conn.close()
    return chats, users, msgs

