    player_name = await get_name(player_id)
    opponent_name = await get_name(opponent_id)
    if player_id not in roulette_games or opponent_id not in roulette_games:
        await bot.send_message(chat_id, "❌ Игра завершена!"); return
    bullets = roulette_games[player_id].get("bullets", [])
    if not bullets:
        await bot.send_message(chat_id, "🤝 Ничья!"); roulette_games.clear(); return
    shot = bullets.pop(0)
    if shot == 1:
        roulette_games.clear()
