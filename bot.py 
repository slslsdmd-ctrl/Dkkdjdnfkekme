def normalize_text(text: str) -> str:
    """Убирает лишние пробелы из текста"""
    return re.sub(r"\s+", " ", (text or "").strip())


def get_time_in_city(city_name: str) -> str:
    """Получает текущее время в указанном городе"""
    try:
        city_lower = city_name.lower().strip()
        if city_lower in TIMEZONES:
            tz = pytz.timezone(TIMEZONES[city_lower])
            return datetime.now(tz).strftime('%H:%M')
        for tz_name in pytz.all_timezones:
            if city_lower in tz_name.lower():
                tz = pytz.timezone(tz_name)
                return datetime.now(tz).strftime('%H:%M')
        return None
    except:
        return None


def get_time_response(text: str) -> str:
    """Формирует ответ на запрос времени"""
    text_lower = text.lower()
    
    prefixes = [
        "сколько время в ", "сколько время по ",
        "время в ", "время по ",
        "который час в ", "который час по ",
        "часов в "
    ]
    
    city_name = None
    for prefix in prefixes:
        if prefix in text_lower:
            city_name = text_lower.split(prefix, 1)[1].strip()
            break
    
    if not city_name:
        for word in ["в ", "по "]:
            if word in text_lower:
                parts = text_lower.split(word)
                if len(parts) > 1:
                    possible_city = parts[-1].strip()
                    if len(possible_city) > 2:
                        city_name = possible_city
                        break
    
    if city_name and len(city_name) > 1:
        time_result = get_time_in_city(city_name)
        if time_result:
            return f"🕐 В **{city_name.title()}**: {time_result}"
    
    msk = get_time_in_city("москва")
    if msk:
        return f"🕐 По МСК: **{msk}**"
    
    return "❌ Не могу определить время"


async def get_weather(city: str = "Москва") -> str:
    """Получает погоду через бесплатный API wttr.in"""
    try:
        encoded_city = urllib.parse.quote(city)
        url = f"https://wttr.in/{encoded_city}?format=%C+%t+%w&lang=ru"
        
        async with aiohttp.ClientSession() as session:
            async with session.get(url, timeout=10) as resp:
                if resp.status == 200:
                    weather_text = (await resp.text()).strip()
                    parts = weather_text.split()
                    
                    if len(parts) >= 2:
                        condition = parts[0]
                        temp = parts[1]
                        wind = parts[2] if len(parts) > 2 else "Н/Д"
                        
                        return (
                            f"🌤 **{city.title()}**\n\n"
                            f"🌡 Температура: **{temp}**\n"
                            f"💨 Ветер: **{wind}**\n"
                            f"☁️ {condition}"
                        )
                    
                    return f"🌤 **{city.title()}**: {weather_text}"
        
        return f"❌ Город '{city}' не найден"
    except Exception as e:
        print(f"Ошибка погоды: {e}")
        return "❌ Не удалось получить погоду"


def analyze_message(prompt: str) -> str:
    """
    Анализирует тип сообщения:
    - greeting: приветствие
    - question: вопрос
    - statement: утверждение
    - insult: оскорбление
    - emotion: эмоция
    - time: запрос времени
    - weather: запрос погоды
    - command: команда
    """
    prompt_lower = prompt.lower().strip()
    
    # Приветствия
    greetings = [
        "привет", "здравствуй", "здарова", "доброе утро",
        "добрый вечер", "добрый день", "прив", "hello", "hi",
        "хелло", "хай", "салют", "ку", "здоров", "здрасте",
        "приветствую", "йоу", "вечер в хату"
    ]
    if any(prompt_lower.startswith(g) for g in greetings) or prompt_lower in greetings:
        return 'greeting'
    
    # Время
    if any(word in prompt_lower for word in ["время", "часов", "который час", "сколько время"]):
        return 'time'
    
    # Погода
    if any(word in prompt_lower for word in ["погода", "погод", "weather"]):
        return 'weather'
    
    # Команды
    commands = [
        "баланс", "бонус", "работа", "профиль", "кто я", "магазин",
        "инвентарь", "ограбить", "перевод", "купить", "продать",
        "рынок", "кланы", "брак", "кубы", "деп", "команды",
        "помощь", "help", "удалить", "бан", "мут", "варн", "стата"
    ]
    if any(prompt_lower == cmd or prompt_lower.startswith(cmd + " ") for cmd in commands):
        return 'command'
    
    # Вопросы
    question_words = [
        "кто", "что", "где", "когда", "почему", "зачем", "как",
        "сколько", "какой", "какая", "какие", "чей", "чья", "чье",
        "ли", "расскажи", "объясни", "найди", "поищи"
    ]
    
    if "?" in prompt_lower or any(prompt_lower.startswith(w) for w in question_words):
        return 'question'
    
    # Оскорбления
    insults = [
        "бля", "блять", "блядь", "блядина", "блядун", "блядский",
        "пизда", "пиздец", "пиздос", "пиздатый", "пиздливый",
        "хуй", "хуя", "хуе", "хую", "хуйня", "хуета", "хуятина",
        "хуйло", "хуесос", "хуеплет", "хуево", "хуевый",
        "ебать", "ебаный", "ебанный", "ёбаный", "ебан", "еблан",
        "заебал", "заебало", "наебать", "уебище", "уебан",
        "нахуй", "нахуя", "схуя", "схуяли", "похуй",
        "сука", "сукин", "сучара", "сучий", "сучище",
        "дурак", "дура", "дурачок", "дурень", "тупой", "тупая",
        "тупица", "тупорылый", "идиот", "идиотка", "дебил",
        "дебилка", "даун", "слабоумный", "кретин", "придурок",
        "мудак", "мудачина", "козел", "козлина", "гандон", "гондон",
        "пидор", "пидорас", "лох", "лошара", "чмо", "чмошник",
        "мразь", "тварь", "говно", "дерьмо", "ублюдок",
        "сволочь", "падла", "гнида", "шлюха", "кал", "скотина",
        "урод", "выродок", "недоумок", "отморозок", "безмозглый",
        "ничтожество", "убогий", "заткнись", "завали", "убейся",
        "пошел на", "пошёл на", "иди на", "отъебись", "отвали",
        "съеби", "соси", "выеби", "обделён", "обделен",
        "смехуятина",
    ]
    if any(insult in prompt_lower for insult in insults):
        return 'insult'
    
    # Эмоции
    if any(word in prompt_lower for word in ["хаха", "ахах", "лол", "кек", "ору", "ржу", "😂", "🤣", "ыыы", "угар", "ржака", "угараю"]):
        return 'emotion'
    
    if any(word in prompt_lower for word in ["грустно", "печаль", "жаль", "плохо", "😢", "😭"]):
        return 'emotion'
    
    # Утверждения (длинные сообщения)
    if len(prompt_lower.split()) > 5:
        return 'statement'
    
    # Если короткое и не вопрос - утверждение
    if len(prompt_lower.split()) >= 2:
        return 'question'
    
    return 'statement'


def get_local_smart_answer(prompt: str) -> str:
    """Локальные умные ответы"""
    prompt_lower = normalize_text(prompt).lower()
    
    # Монетка
    if "монетк" in prompt_lower or "орел или решка" in prompt_lower:
        return f"🪙 Выпало: **{random.choice(['Орёл', 'Решка'])}**"
    
    # Выбор
    if prompt_lower.startswith("выбери ") or prompt_lower.startswith("что выбрать"):
        choices = re.split(r"\s+или\s+|,", prompt_lower)
        choices = [c.strip() for c in choices if c.strip() and c not in ["выбери", "что выбрать"]]
        if len(choices) >= 2:
            return f"🤔 Я выбираю: **{random.choice(choices)}**"
    
    # Случайное число
    if prompt_lower.startswith("рандом") or prompt_lower.startswith("случайное"):
        numbers = re.findall(r'\d+', prompt_lower)
        if len(numbers) >= 2:
            left = int(numbers[0])
            right = int(numbers[1])
            return f"🎲 Случайное число: **{random.randint(left, right)}**"
    
    return None


