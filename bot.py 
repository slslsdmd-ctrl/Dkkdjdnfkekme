    def _migrate_database(self, cursor):
        """ДОБАВЛЕНИЕ НЕДОСТАЮЩИХ СТОЛБЦОВ"""
        migrations = [
            ("users", "chat_id", "INTEGER"),
            ("users", "experience", "INTEGER DEFAULT 0"),
            ("users", "level", "INTEGER DEFAULT 1"),
            ("businesses", "marketing_level", "INTEGER DEFAULT 0"),
            ("businesses", "brand_level", "INTEGER DEFAULT 0"),
            ("businesses", "is_monopoly", "BOOLEAN DEFAULT 0"),
            ("businesses", "franchise_price", "INTEGER DEFAULT 0"),
            ("businesses", "partner_id", "INTEGER"),
        ]
        
        for table, column, col_type in migrations:
            try:
                cursor.execute(f"ALTER TABLE {table} ADD COLUMN {column} {col_type}")
            except:
                pass
    
    def _preload_data(self):
        """ПРЕДЗАГРУЗКА ВАЖНЫХ ДАННЫХ В КЭШ"""
        try:
            # Загружаем топ-100 пользователей
            conn = self._get_connection_sync()
            cursor = conn.cursor()
            cursor.execute("SELECT user_id, coins FROM users ORDER BY coins DESC LIMIT 100")
            top_users = cursor.fetchall()
            self.cache['top_users'] = top_users
            self.cache_times['top_users'] = time.time()
            self._return_connection_sync(conn)
            
            # Загружаем настройки всех чатов
            conn = self._get_connection_sync()
            cursor = conn.cursor()
            cursor.execute("SELECT chat_id, anti_spam, anti_links, captcha FROM settings")
            settings = cursor.fetchall()
            self.cache['settings'] = settings
            self.cache_times['settings'] = time.time()
            self._return_connection_sync(conn)
            
            print(f"✅ ПРЕДЗАГРУЖЕНО: {len(top_users)} пользователей, {len(settings)} чатов")
        except Exception as e:
            print(f"⚠️ Ошибка предзагрузки: {e}")
    
    # ============================================================
    # РАБОТА С ПУЛОМ КОННЕКШЕНОВ
    # ============================================================
    
    def _get_connection_sync(self):
        """СИНХРОННОЕ ПОЛУЧЕНИЕ КОННЕКШЕНА"""
        if self.connections:
            return self.connections.pop()
        
        conn = sqlite3.connect(
            self.db_path,
            timeout=3,
            check_same_thread=False,
            isolation_level=None
        )
        conn.execute("PRAGMA journal_mode=WAL")
        conn.execute("PRAGMA synchronous=NORMAL")
        conn.execute("PRAGMA cache_size=100000")
        conn.execute("PRAGMA temp_store=MEMORY")
        conn.row_factory = sqlite3.Row
        return conn
    
    def _return_connection_sync(self, conn):
        """СИНХРОННОЕ ВОЗВРАЩЕНИЕ КОННЕКШЕНА"""
        if len(self.connections) < self.max_connections:
            self.connections.append(conn)
        else:
            conn.close()
    
    async def get_connection(self):
        """АСИНХРОННОЕ ПОЛУЧЕНИЕ КОННЕКШЕНА"""
        async with self.connection_lock:
            if self.connections:
                conn = self.connections.pop()
                try:
                    conn.execute("SELECT 1")
                    return conn
                except:
                    pass
            
            return self._get_connection_sync()
    
    async def return_connection(self, conn):
        """АСИНХРОННОЕ ВОЗВРАЩЕНИЕ КОННЕКШЕНА"""
        async with self.connection_lock:
            self._return_connection_sync(conn)
    
    # ============================================================
    # БЫСТРЫЕ ЗАПРОСЫ С КЭШЕМ
    # ============================================================
    
    async def query(self, sql: str, params: tuple = (), fetch_one: bool = False, 
                   fetch_all: bool = False, cache_ttl: int = 0) -> Any:
        """ОПТИМИЗИРОВАННЫЙ ЗАПРОС С КЭШЕМ"""
        self.stats['queries'] += 1
        
        # Проверяем кэш
        cache_key = f"{sql}:{params}"
        if cache_ttl > 0 and cache_key in self.cache:
            cache_time = self.cache_times.get(cache_key, 0)
            if time.time() - cache_time < cache_ttl:
                self.stats['hits'] += 1
                return self.cache[cache_key]
        
        self.stats['misses'] += 1
        
        conn = await self.get_connection()
        try:
            cursor = conn.cursor()
            cursor.execute(sql, params)
            
            if fetch_one:
                result = cursor.fetchone()
            elif fetch_all:
                result = cursor.fetchall()
            else:
                conn.commit()
                result = cursor.rowcount
            
            # Сохраняем в кэш
            if cache_ttl > 0:
                self.cache[cache_key] = result
                self.cache_times[cache_key] = time.time()
            
            await self.return_connection(conn)
            return result
            
        except Exception as e:
            await self.return_connection(conn)
            raise e
    
