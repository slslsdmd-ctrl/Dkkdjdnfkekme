# ==================== КАЛЬКУЛЯТОР ====================
def calculate_expression(expr):
    """Безопасный калькулятор"""
    try:
        allowed = set("0123456789+-*/().%^ ")
        if not all(c in allowed for c in expr):
            return "❌ Недопустимые символы!"
        result = eval(expr)
        return f"🧮 {expr} = **{result}**"
    except:
        return "❌ Ошибка в выражении!"


