        """ПОЛУЧЕНИЕ СТАТИСТИКИ БИЗНЕСА"""
        businesses = await self.get_businesses(user_id)
        
        if not businesses:
            return {'error': 'У тебя нет бизнесов!'}
        
        total_income = 0
        total_level = 0
        categories = {}
        
        for b in businesses:
            total_income += b['income']
            total_level += b['level']
            
            data = BUSINESSES.get(b['name'], {})
            category = data.get('category', 'other')
            categories[category] = categories.get(category, 0) + 1
        
        return {
            'total_businesses': len(businesses),
            'total_income': total_income,
            'avg_level': total_level / len(businesses),
            'categories': categories,
            'monopolies': sum(1 for b in businesses if b.get('is_monopoly'))
        }

