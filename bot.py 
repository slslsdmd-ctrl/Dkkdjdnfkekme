@dp.callback_query(lambda c: c.data.startswith("cyes_"))
async def cube_yes(cb: types.CallbackQuery):
    _, cid, cid2, oid, dice_count = cb.data.split("_")
    cid, cid2, oid = int(cid), int(cid2), int(oid)
    dice_count = int(dice_count)
    if cb.from_user.id != oid:
        await cb.answer("❌ Не тебе!")
        return
    await cb.message.delete()
    
    msg = await bot.send_message(cid, f"🎲 {await get_name(cid2)} бросает...")
    rolls1 = [random.randint(1, 6) for _ in range(dice_count)]
    total1 = sum(rolls1)
    await asyncio.sleep(1.5)
    await msg.edit_text(f"🎲 {await get_name(cid2)}: {', '.join(map(str, rolls1))} = **{total1}**")
    
    await asyncio.sleep(1.5)
    msg2 = await bot.send_message(cid, f"🎲 {await get_name(oid)} бросает...")
    await asyncio.sleep(1.5)
    rolls2 = [random.randint(1, 6) for _ in range(dice_count)]
    total2 = sum(rolls2)
    await msg2.edit_text(f"🎲 {await get_name(oid)}: {', '.join(map(str, rolls2))} = **{total2}**")
    
    await asyncio.sleep(1)
    if total1 > total2:
        await add_coins(cid2, cid, 50)
        await bot.send_message(cid, f"🏆 **{await get_name(cid2)}** победил! (+50)")
    elif total2 > total1:
        await add_coins(oid, cid, 50)
        await bot.send_message(cid, f"🏆 **{await get_name(oid)}** победил! (+50)")
    else:
        await bot.send_message(cid, f"🤝 Ничья!")
    
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("DELETE FROM game_states WHERE chat_id = ? AND game_type = ?", (cid, f"cubes_{cid2}_{oid}"))
    conn.commit()
    conn.close()

