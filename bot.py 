class MarginTrader:
    """СИСТЕМА МАРЖИНАЛЬНОЙ ТОРГОВЛИ С КРЕДИТНЫМ ПЛЕЧОМ"""
    
    def __init__(self):
        self.positions = {}
        self.liquidation_prices = {}
    
    async def open_position(self, user_id: int, stock: str, amount: int, leverage: int = 2) -> dict:
        """ОТКРЫТИЕ ПОЗИЦИИ С ПЛЕЧОМ"""
        if leverage < 1 or leverage > 10:
            return {'error': 'Плечо должно быть от 1 до 10'}
        
        price = await self.get_stock_price(stock)
        if not price:
            return {'error': 'Акция не найдена'}
        
        total_value = amount * leverage
        current_coins = await db.get_coins(user_id)
        
        if current_coins < amount:
            return {'error': f'Недостаточно монет! Нужно {amount}'}
        
        # Снимаем монеты
        await db.add_coins(user_id, -amount)
        
        # Создаём позицию
        position_id = f"{user_id}_{stock}_{datetime.now().timestamp()}"
        self.positions[position_id] = {
            'user_id': user_id,
            'stock': stock,
            'amount': amount,
            'leverage': leverage,
            'entry_price': price,
            'current_price': price,
            'total_value': total_value,
            'open_date': datetime.now().isoformat(),
            'liquidation_price': price * (1 - 0.2 / leverage)  # 20% просадка
        }
        
        return {
            'success': True,
            'position_id': position_id,
            'stock': stock,
            'amount': amount,
            'leverage': leverage,
            'entry_price': price,
            'total_value': total_value,
            'liquidation_price': self.positions[position_id]['liquidation_price']
        }
    
    async def close_position(self, position_id: str) -> dict:
        """ЗАКРЫТИЕ ПОЗИЦИИ"""
        if position_id not in self.positions:
            return {'error': 'Позиция не найдена'}
        
        pos = self.positions[position_id]
        current_price = await self.get_stock_price(pos['stock'])
        
        if not current_price:
            return {'error': 'Не удалось получить цену'}
        
        # Расчёт прибыли/убытка
        price_change = (current_price - pos['entry_price']) / pos['entry_price']
        profit = pos['total_value'] * price_change
        
        # Возвращаем деньги с прибылью или убытком
        total_return = pos['amount'] + profit
        await db.add_coins(pos['user_id'], int(total_return))
        
        # Проверяем ликвидацию
        if current_price <= pos['liquidation_price']:
            profit = -pos['amount'] * 0.9  # 90% потеря
        
        result = {
            'success': True,
            'stock': pos['stock'],
            'entry_price': pos['entry_price'],
            'exit_price': current_price,
            'profit': int(profit),
            'total_return': int(total_return)
        }
        
        # Удаляем позицию
        del self.positions[position_id]
        return result
    
    async def get_stock_price(self, stock: str) -> Optional[float]:
        """ПОЛУЧЕНИЕ ЦЕНЫ АКЦИИ"""
        if stock not in STOCKS:
            return None
        
        base_price = STOCKS[stock]['base_price']
        volatility = STOCKS[stock]['volatility']
        
        # Добавляем случайные колебания
        change = random.uniform(-volatility * 3, volatility * 3)
        price = base_price * (1 + change)
        
        return max(1, price)
    
    async def check_liquidations(self):
        """ПРОВЕРКА ЛИКВИДАЦИЙ"""
        to_remove = []
        
        for pos_id, pos in self.positions.items():
            current_price = await self.get_stock_price(pos['stock'])
            if not current_price:
                continue
            
            # Проверка ликвидации
            if current_price <= pos['liquidation_price']:
                await self.close_position(pos_id)
                to_remove.append(pos_id)
        
        return to_remove

