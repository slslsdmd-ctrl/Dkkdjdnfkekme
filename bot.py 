class CasinoComplex:
    """ПОЛНЫЙ КОМПЛЕКС КАЗИНО"""
    
    def __init__(self):
        self.balances = {}
        self.vip = {}
        self.bonuses = {}
    
    async def get_balance(self, user_id: int) -> int:
        """БАЛАНС В КАЗИНО"""
        if user_id not in self.balances:
            self.balances[user_id] = 0
        return self.balances[user_id]
    
    async def deposit(self, user_id: int, amount: int) -> dict:
        """ПОПОЛНИТЬ БАЛАНС"""
        if amount <= 0:
            return {"error": "Сумма должна быть больше 0!"}
        
        coins = await get_coins(user_id)
        if coins < amount:
            return {"error": f"Недостаточно монет! Есть {coins}"}
        
        await remove_coins(user_id, amount)
        self.balances[user_id] = self.balances.get(user_id, 0) + amount
        
        # Бонус за пополнение
        bonus = int(amount * 0.05)  # 5% бонус
        self.balances[user_id] += bonus
        
        # VIP статус
        if self.balances[user_id] > 100000:
            self.vip[user_id] = {
                "level": min(5, self.balances[user_id] // 100000),
                "cashback": 0.05,
                "bonus_multiplier": 1.1
            }
        
        return {
            "success": True,
            "deposit": amount,
            "bonus": bonus,
            "balance": self.balances[user_id],
            "vip": user_id in self.vip
        }
    
    async def withdraw(self, user_id: int, amount: int) -> dict:
        """ВЫВЕСТИ ИЗ КАЗИНО"""
        balance = await self.get_balance(user_id)
        if balance < amount:
            return {"error": f"Недостаточно средств в казино! Есть {balance}"}
        
        self.balances[user_id] -= amount
        await add_coins(user_id, amount)
        
        return {
            "success": True,
            "withdraw": amount,
            "balance": self.balances[user_id]
        }
    
    async def play_slots(self, user_id: int, bet: int) -> dict:
        """ИГРАТЬ В СЛОТЫ"""
        balance = await self.get_balance(user_id)
        if balance < bet:
            return {"error": f"Недостаточно средств в казино! Есть {balance}"}
        
        # Проверяем VIP бонус
        vip_bonus = 1
        if user_id in self.vip:
            vip_bonus = self.vip[user_id].get("bonus_multiplier", 1)
        
        self.balances[user_id] -= bet
        
        symbols = ["🍒", "🍋", "🍊", "🍇", "💎", "🎰", "⭐", "🔥"]
        result = [random.choice(symbols) for _ in range(3)]
        win = 0
        
        if result[0] == result[1] == result[2]:
            if result[0] == "🎰":
                win = bet * 20
            elif result[0] == "💎":
                win = bet * 15
            else:
                win = bet * 10
        elif result[0] == result[1] or result[1] == result[2]:
            win = bet * 2
        
        win = int(win * vip_bonus)
        self.balances[user_id] += win
        
        return {
            "success": True,
            "result": result,
            "win": win,
            "bet": bet,
            "balance": self.balances[user_id]
        }

