    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("UPDATE duels SET turn = ?, aim_bonus = ? WHERE chat_id = ?", (new_turn, new_aim_bonus, chat_id))
    conn.commit()
    conn.close()
    await bot.send_message(chat_id, f"🎯 **{await get_name(callback.from_user.id)}** прицелился!\nШанс следующего выстрела: +{new_aim_bonus*10}%")
    await callback.answer("🎯 Прицелился!")
    await send_duel_turn(chat_id, challenger, opponent, new_aim_bonus, new_turn)

