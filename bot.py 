class QuestManager:
    """УПРАВЛЕНИЕ КВЕСТАМИ"""
    
    def __init__(self):
        self.quest_progress = {}
        self.quest_completed = {}
        self.daily_reset = None
        self.weekly_reset = None
    
    async def get_daily_quests(self, user_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ ЕЖЕДНЕВНЫХ КВЕСТОВ"""
        # Проверяем сброс
        if not self.daily_reset or (datetime.now() - self.daily_reset).days >= 1:
            self.daily_reset = datetime.now()
            # Сбрасываем прогресс
            await db.query(
                "DELETE FROM quest_progress WHERE type = 'daily' AND user_id = ?",
                (user_id,)
            )
        
        # Получаем прогресс
        progress = await db.query(
            "SELECT quest_id, progress FROM quest_progress WHERE user_id = ? AND type = 'daily'",
            (user_id,),
            fetch_all=True
        )
        progress_dict = {p['quest_id']: p['progress'] for p in progress}
        
        # Формируем квесты
        quests = []
        for quest in QUESTS['daily']:
            current_progress = progress_dict.get(quest['id'], 0)
            completed = current_progress >= quest['goal']
            
            quests.append({
                'id': quest['id'],
                'name': quest['name'],
                'desc': quest['desc'],
                'progress': current_progress,
                'goal': quest['goal'],
                'reward': quest['reward'],
                'completed': completed
            })
        
        return quests
    
    async def update_progress(self, user_id: int, quest_id: str, amount: int = 1) -> Optional[dict]:
        """ОБНОВЛЕНИЕ ПРОГРЕССА КВЕСТА"""
        # Находим квест
        quest = None
        for q in QUESTS['daily']:
            if q['id'] == quest_id:
                quest = q
                break
        
        if not quest:
            return None
        
        # Проверяем, не завершён ли уже
        completed = await db.query(
            "SELECT * FROM quest_completed WHERE user_id = ? AND quest_id = ? AND date > datetime('now', '-1 day')",
            (user_id, quest_id),
            fetch_one=True
        )
        if completed:
            return None
        
        # Обновляем прогресс
        current = await db.query(
            "SELECT progress FROM quest_progress WHERE user_id = ? AND quest_id = ? AND type = 'daily'",
            (user_id, quest_id),
            fetch_one=True
        )
        
        new_progress = (current['progress'] if current else 0) + amount
        
        if current:
            await db.query(
                "UPDATE quest_progress SET progress = ? WHERE user_id = ? AND quest_id = ? AND type = 'daily'",
                (new_progress, user_id, quest_id)
            )
        else:
            await db.query(
                "INSERT INTO quest_progress (user_id, quest_id, type, progress) VALUES (?, ?, 'daily', ?)",
                (user_id, quest_id, new_progress)
            )
        
        # Проверяем завершение
        if new_progress >= quest['goal']:
            # Завершаем квест
            await db.query(
                "INSERT INTO quest_completed (user_id, quest_id, date) VALUES (?, ?, ?)",
                (user_id, quest_id, datetime.now().isoformat())
            )
            
            # Награда
            await db.add_coins(user_id, quest['reward'])
            
            return {
                'success': True,
                'quest': quest['name'],
                'reward': quest['reward']
            }
        
        return {
            'success': True,
            'quest': quest['name'],
            'progress': new_progress,
            'goal': quest['goal']
        }

