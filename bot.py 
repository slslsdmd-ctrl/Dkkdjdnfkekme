            (','.join(members), clan['id'])
        )
        
        await unlock_achievement(user_id, "join_clan")
        
        return {
            'success': True,
            'clan': clan['name'],
            'members': len(members)
        }
    
    async def leave_clan(self, user_id: int, chat_id: int) -> dict:
        """ВЫХОД ИЗ КЛАНА"""
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        if clan['owner_id'] == user_id:
            return {'error': 'Лидер не может выйти! Передай клан другому участнику.'}
        
        members = clan['members'].split(',') if clan['members'] else []
        members.remove(str(user_id))
        
        await db.query(
            "UPDATE clans SET members = ? WHERE id = ?",
            (','.join(members), clan['id'])
        )
        
        return {
            'success': True,
            'clan': clan['name']
        }
    
    async def get_clan_info(self, user_id: int, chat_id: int) -> dict:
        """ИНФОРМАЦИЯ О КЛАНЕ"""
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        members = clan['members'].split(',') if clan['members'] else []
        
        member_names = []
        for uid in members[:10]:
            try:
                name = await get_name(int(uid))
                member_names.append(name)
            except:
                member_names.append(f"id{uid}")
        
        return {
            'success': True,
            'name': clan['name'],
            'owner_id': clan['owner_id'],
            'owner_name': await get_name(clan['owner_id']),
            'members': len(members),
            'member_names': member_names,
            'treasury': clan['treasury'],
            'level': clan.get('level', 1)
        }
    
    async def donate_treasury(self, user_id: int, chat_id: int, amount: int) -> dict:
        """ПОПОЛНЕНИЕ КЛАНОВОЙ КАЗНЫ"""
        if amount <= 0:
            return {'error': 'Сумма должна быть больше 0!'}
        
        clan = await self.get_clan(user_id, chat_id)
        if not clan:
            return {'error': 'Ты не в клане!'}
        
        coins = await get_coins(user_id)
        if coins < amount:
            return {'error': f'Недостаточно монет! Есть {coins}'}
        
        await remove_coins(user_id, amount)
        
        await db.query(
            "UPDATE clans SET treasury = treasury + ? WHERE id = ?",
            (amount, clan['id'])
        )
        
        return {
            'success': True,
            'clan': clan['name'],
            'amount': amount,
            'treasury': clan['treasury'] + amount
        }

