class EconomicCrisis:
    """УМНАЯ СИСТЕМА ЭКОНОМИЧЕСКОГО КРИЗИСА"""
    
    def __init__(self):
        self.crises = {}
        self.inflation_rates = {}
        self.economic_indexes = {}
        self.last_update = datetime.now()
        
    async def update(self, chat_id: int):
        """ОБНОВЛЕНИЕ ЭКОНОМИЧЕСКОЙ СИТУАЦИИ"""
        now = datetime.now()
        
        # Проверяем кризис
        crisis = await db.get_crisis_status(chat_id)
        if crisis and crisis.get('active'):
            # Кризис активен - усугубляем или ослабляем
            severity = crisis.get('severity', 0)
            duration = (now - datetime.fromisoformat(crisis.get('start_date'))).days
            
            # Чем дольше кризис - тем слабее
            if duration > 7:
                severity = max(0, severity - 0.1)
                if severity < 0.5:
                    await db.end_crisis(chat_id)
                    self.crises[chat_id] = None
                    return
            
            # Обновляем мультипликатор
            multiplier = 0.7 + (severity * 0.05)
            await db.query(
                "UPDATE crisis SET multiplier = ?, severity = ? WHERE chat_id = ?",
                (multiplier, severity, chat_id)
            )
            
            self.crises[chat_id] = {
                'active': True,
                'severity': severity,
                'multiplier': multiplier,
                'inflation': crisis.get('inflation_rate', 0.05)
            }
        else:
            # Кризиса нет - может начаться случайно
            if random.random() < 0.001:  # 0.1% шанс в день
                severity = random.uniform(1, 10)
                inflation = random.uniform(0.02, 0.15)
                await db.start_crisis(chat_id, severity, inflation)
                self.crises[chat_id] = {
                    'active': True,
                    'severity': severity,
                    'multiplier': 0.7 + (severity * 0.05),
                    'inflation': inflation
                }
                return
        
        # Обновляем инфляцию
        inflation_rate = 0.02  # Базовая 2%
        if chat_id in self.crises and self.crises[chat_id].get('active'):
            inflation_rate += self.crises[chat_id].get('inflation', 0)
        
        # Случайные колебания
        inflation_rate += random.uniform(-0.005, 0.005)
        inflation_rate = max(0, inflation_rate)
        
        self.inflation_rates[chat_id] = inflation_rate
        
        # Обновляем экономический индекс
        await self.update_economic_index(chat_id)
        
        self.last_update = now
    
    async def update_economic_index(self, chat_id: int):
        """ОБНОВЛЕНИЕ ЭКОНОМИЧЕСКОГО ИНДЕКСА"""
        crisis = await db.get_crisis_status(chat_id)
        
        if crisis and crisis.get('active'):
            severity = crisis.get('severity', 0)
            index = max(0, 100 - (severity * 10))
        else:
            index = 100
        
        # Добавляем случайные колебания
        index += random.uniform(-5, 5)
        index = max(0, min(100, index))
        
        self.economic_indexes[chat_id] = index
    
    def get_multiplier(self, chat_id: int) -> float:
        """ПОЛУЧЕНИЕ ЭКОНОМИЧЕСКОГО МУЛЬТИПЛИКАТОРА"""
        if chat_id in self.crises and self.crises[chat_id].get('active'):
            return self.crises[chat_id].get('multiplier', 1.0)
        return 1.0
    
    def get_inflation(self, chat_id: int) -> float:
        """ПОЛУЧЕНИЕ УРОВНЯ ИНФЛЯЦИИ"""
        return self.inflation_rates.get(chat_id, 0.02)
    
    def get_index(self, chat_id: int) -> int:
        """ПОЛУЧЕНИЕ ЭКОНОМИЧЕСКОГО ИНДЕКСА"""
        return self.economic_indexes.get(chat_id, 100)
    
    def is_crisis_active(self, chat_id: int) -> bool:
        """ПРОВЕРКА АКТИВНОСТИ КРИЗИСА"""
        crisis = self.crises.get(chat_id, {})
        return crisis.get('active', False)

