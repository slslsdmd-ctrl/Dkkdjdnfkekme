    # РАССЫЛКИ
    # ============================================================
    
    async def broadcast(self, admin_id: int, message: str, target: str = "all") -> dict:
        """СДЕЛАТЬ РАССЫЛКУ"""
        if not message or len(message.strip()) < 1:
            return {"error": "Сообщение не может быть пустым!"}
        
        # Получаем список чатов
        if target == "all":
            chats = await db.query(
                "SELECT DISTINCT chat_id FROM users WHERE chat_id IS NOT NULL",
                fetch_all=True
            )
        elif target == "active":
            chats = await db.query(
                "SELECT DISTINCT chat_id FROM users WHERE chat_id IS NOT NULL AND datetime(last_daily) > datetime('now', '-7 day')",
                fetch_all=True
            )
        else:
            return {"error": "Неизвестный тип рассылки! Доступно: all, active"}
        
        if not chats:
            return {"error": "Нет чатов для рассылки!"}
        
        # Сохраняем в историю
        broadcast_id = len(self.broadcast_history) + 1
        self.broadcast_history.append({
            "id": broadcast_id,
            "admin_id": admin_id,
            "message": message[:100],
            "target": target,
            "total_chats": len(chats),
            "date": datetime.now().isoformat(),
            "status": "sent"
        })
        
        # Отправляем сообщения
        sent_count = 0
        for chat in chats:
            try:
                await bot.send_message(chat["chat_id"], message, parse_mode=ParseMode.MARKDOWN)
                sent_count += 1
                await asyncio.sleep(0.1)  # Защита от спама
            except:
                pass
        
        return {
            "success": True,
            "broadcast_id": broadcast_id,
            "total_chats": len(chats),
            "sent_count": sent_count,
            "message": message[:100]
        }
    
    # ============================================================
    # ПЛАНИРОВЩИК ЗАДАЧ
    # ============================================================
    
    async def schedule_task(self, task_type: str, params: dict, schedule: str) -> dict:
        """ЗАПЛАНИРОВАТЬ ЗАДАЧУ"""
        task_id = len(self.scheduled_tasks) + 1
        
        self.scheduled_tasks.append({
            "id": task_id,
            "type": task_type,
            "params": params,
            "schedule": schedule,
            "created": datetime.now().isoformat(),
            "status": "scheduled"
        })
        
        return {
            "success": True,
            "task_id": task_id,
            "message": f"✅ Задача #{task_id} запланирована!"
        }
    
    async def run_scheduled_tasks(self):
        """ЗАПУСТИТЬ ЗАПЛАНИРОВАННЫЕ ЗАДАЧИ"""
        while True:
            try:
                now = datetime.now()
                for task in self.scheduled_tasks:
                    if task["status"] != "scheduled":
                        continue
                    
                    if task["schedule"] == "daily" and now.hour == 0 and now.minute == 0:
                        await self._execute_task(task)
                    elif task["schedule"] == "hourly" and now.minute == 0:
                        await self._execute_task(task)
                    elif task["schedule"] == "weekly" and now.weekday() == 0 and now.hour == 0:
                        await self._execute_task(task)
                
                await asyncio.sleep(60)  # Проверяем каждую минуту
            except Exception as e:
                log_error(e, "run_scheduled_tasks")
                await asyncio.sleep(60)
    
    async def _execute_task(self, task: dict):
        """ВЫПОЛНИТЬ ЗАДАЧУ"""
        task["status"] = "running"
        task["last_run"] = datetime.now().isoformat()
        
        if task["type"] == "daily_bonus":
            # Выдать ежедневный бонус всем
            users = await db.query(
                "SELECT user_id FROM users WHERE last_daily IS NULL OR datetime(last_daily) < datetime('now', '-1 day')",
                fetch_all=True
            )
            for user in users:
                await add_coins(user["user_id"], 100)
        
        elif task["type"] == "tax_collect":
            # Собрать налоги
            users = await db.query("SELECT user_id FROM users", fetch_all=True)
            for user in users:
                await collect_taxes(user["user_id"])
        
        elif task["type"] == "reset_quests":
            # Сбросить квесты
            await db.query("DELETE FROM quest_progress", ())
        
        task["status"] = "completed"
        task["completed_at"] = datetime.now().isoformat()

