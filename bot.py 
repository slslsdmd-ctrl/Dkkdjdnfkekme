class GiftManager:
    """УПРАВЛЕНИЕ ПОДАРКАМИ"""
    
    async def send_gift(self, user_id: int, target_id: int, item_name: str, quantity: int = 1) -> dict:
        """ОТПРАВКА ПОДАРКА"""
        if user_id == target_id:
            return {'error': 'Нельзя отправить подарок себе!'}
        
        # Проверяем наличие предмета
        has_item = await db.query(
            "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = ?",
            (user_id, item_name),
            fetch_one=True
        )
        
        if not has_item or has_item['quantity'] < quantity:
            return {'error': f'У тебя нет {item_name}!'}
        
        # Снимаем у отправителя
        await db.query(
            "UPDATE inventory SET quantity = quantity - ? WHERE user_id = ? AND item_name = ?",
            (quantity, user_id, item_name)
        )
        
        # Добавляем получателю
        await db.query(
            "INSERT INTO inventory (user_id, item_name, quantity) VALUES (?, ?, ?) ON CONFLICT(user_id, item_name) DO UPDATE SET quantity = quantity + ?",
            (target_id, item_name, quantity, quantity)
        )
        
        # Логируем подарок
        await db.query(
            "INSERT INTO gifts (from_user, to_user, chat_id, item_name, quantity, date) VALUES (?, ?, ?, ?, ?, ?)",
            (user_id, target_id, 0, item_name, quantity, datetime.now().isoformat())
        )
        
        return {
            'success': True,
            'from': user_id,
            'to': target_id,
            'item': item_name,
            'quantity': quantity
        }
    
    async def get_gifts_history(self, user_id: int, limit: int = 10) -> List[dict]:
        """ПОЛУЧЕНИЕ ИСТОРИИ ПОДАРКОВ"""
        result = await db.query(
            "SELECT * FROM gifts WHERE from_user = ? OR to_user = ? ORDER BY date DESC LIMIT ?",
            (user_id, user_id, limit),
            fetch_all=True,
            cache_ttl=60
        )
        return result or []

gift_manager = GiftManager()

