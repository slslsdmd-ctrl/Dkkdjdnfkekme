        else:
            c.execute(
                "UPDATE spam_log SET message_count = 1, last_message = ? WHERE user_id = ? AND chat_id = ?",
                (now.isoformat(), user_id, chat_id)
            )
    else:
        c.execute(
            "INSERT INTO spam_log (user_id, chat_id, message_count, last_message) VALUES (?,?,1,?)",
