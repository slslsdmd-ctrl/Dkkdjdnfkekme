class CaptchaSystem:
    """СИСТЕМА ЗАЩИТЫ ОТ БОТОВ"""
    
    def __init__(self):
        self.captcha_cache = {}
        self.captcha_timeout = 300  # 5 минут
    
    async def generate_captcha(self, user_id: int) -> dict:
        """СГЕНЕРИРОВАТЬ КАПЧУ"""
        num1 = random.randint(1, 10)
        num2 = random.randint(1, 10)
        operation = random.choice(["+", "-", "*"])
        
        if operation == "+":
            answer = num1 + num2
        elif operation == "-":
            answer = num1 - num2
        else:
            answer = num1 * num2
        
        captcha_id = f"captcha_{user_id}_{int(datetime.now().timestamp())}"
        self.captcha_cache[captcha_id] = {
            "user_id": user_id,
            "answer": answer,
            "created": datetime.now().isoformat(),
            "attempts": 0
        }
        
        return {
            "captcha_id": captcha_id,
            "question": f"Сколько будет {num1} {operation} {num2}?",
            "timeout": self.captcha_timeout
        }
    
    async def verify_captcha(self, captcha_id: str, answer: int) -> dict:
        """ПРОВЕРИТЬ КАПЧУ"""
        if captcha_id not in self.captcha_cache:
            return {"error": "Капча не найдена!"}
        
        captcha = self.captcha_cache[captcha_id]
        
        # Проверяем время
        created = datetime.fromisoformat(captcha["created"])
        if (datetime.now() - created).seconds > self.captcha_timeout:
            del self.captcha_cache[captcha_id]
            return {"error": "Время истекло!"}
        
        captcha["attempts"] += 1
        
        if captcha["attempts"] >= 5:
            del self.captcha_cache[captcha_id]
            return {"error": "Слишком много попыток!"}
        
        if answer == captcha["answer"]:
            del self.captcha_cache[captcha_id]
            return {"success": True, "message": "✅ Капча пройдена!"}
        else:
            return {"error": f"❌ Неверно! Осталось попыток: {5 - captcha['attempts']}"}

captcha_system = CaptchaSystem()

