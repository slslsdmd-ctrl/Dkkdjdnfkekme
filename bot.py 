async def bfg_crypto_market() -> str:
    global CRYPTO_CURRENCIES
    for currency in CRYPTO_CURRENCIES:
        change = random.uniform(-CRYPTO_CURRENCIES[currency]["volatility"], CRYPTO_CURRENCIES[currency]["volatility"])
