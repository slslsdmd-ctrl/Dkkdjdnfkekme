def get_message_tags(text: str) -> list:
    text_lower = text.lower()
    found_tags = []
    for tag, keywords in TAG_KEYWORDS.items():
        score = 0
        for keyword in keywords:
            if keyword in text_lower:
                score += 1
        if score > 0:
            found_tags.append(tag)
    if not found_tags:
        found_tags.append("общение")
    return found_tags

async def save_message_tags(user_id: int, chat_id: int, message_text: str, response_text: str = "") -> list:
    try:
        tags = get_message_tags(message_text)
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute(
            "INSERT INTO message_tags (user_id, chat_id, message_text, tags, response, timestamp) VALUES (?, ?, ?, ?, ?, ?)",
            (user_id, chat_id, message_text[:500], ",".join(tags), response_text[:500], datetime.now().isoformat())
        )
        conn.commit()
        conn.close()
        return tags
    except Exception as e:
        print(f"Ошибка сохранения тегов: {e}")
        return []

