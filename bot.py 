    async def report_user(self, user_id: int, reported_id: int, reason: str, chat_id: int) -> dict:
        """ПОЖАЛОВАТЬСЯ НА ПОЛЬЗОВАТЕЛЯ"""
        self.report_id += 1
        report_id = self.report_id
        
        self.reports[report_id] = {
            "id": report_id,
            "user_id": user_id,
            "reported_id": reported_id,
            "reason": reason,
            "chat_id": chat_id,
            "date": datetime.now().isoformat(),
            "status": "pending"
        }
        
        return {
            "success": True,
            "report_id": report_id,
            "message": f"📋 Жалоба на {await get_name(reported_id)} отправлена! ID: {report_id}"
        }
    
    async def resolve_report(self, report_id: int, action: str, admin_id: int) -> dict:
        """РАССМОТРЕТЬ ЖАЛОБУ"""
        if report_id not in self.reports:
            return {"error": "Жалоба не найдена!"}
        
        report = self.reports[report_id]
        if report["status"] != "pending":
            return {"error": "Жалоба уже рассмотрена!"}
        
        report["status"] = "resolved"
        report["resolved_by"] = admin_id
        report["resolved_at"] = datetime.now().isoformat()
        report["resolution"] = action
        
        if action == "ban":
            await self.ban_user(report["reported_id"], report["reason"])
        elif action == "mute":
            await self.mute_user(report["reported_id"], 60)
        elif action == "warn":
            await db.query(
                "INSERT INTO warns (user_id, chat_id, warned_by, reason, date) VALUES (?, ?, ?, ?, ?)",
                (report["reported_id"], report["chat_id"], admin_id, report["reason"], datetime.now().isoformat())
            )
        
        return {
            "success": True,
            "report_id": report_id,
            "action": action,
            "message": f"✅ Жалоба #{report_id} рассмотрена! Действие: {action}"
        }
    
