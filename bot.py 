                return
            target_id = message.reply_to_message.from_user.id
            if target_id == uid:
                await message.reply("❌ Нельзя с самим собой!")
                return
            phrase = random.choice(RP_ACTIONS[action]).format(user=await get_name(uid), target=await get_name(target_id))
            await message.reply(phrase)
