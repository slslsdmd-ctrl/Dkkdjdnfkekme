async def update_stock_prices():
    """Обновляет цены акций"""
    for symbol, data in STOCKS.items():
        change = random.uniform(-data["volatility"], data["volatility"])
        data["price"] = max(10, data["price"] * (1 + change))
        data["price"] = round(data["price"], 2)

async def buy_stock(uid, cid, symbol, quantity):
    """Покупает акции"""
    if symbol not in STOCKS:
        return "❌ Неизвестный тикер"
    price = STOCKS[symbol]["price"]
    total = int(price * quantity)
    if await get_coins(uid, cid) < total:
        return "❌ Мало монет!"
    await remove_coins(uid, cid, total)
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO stocks_portfolio VALUES(?,?,?,?) ON CONFLICT(user_id,chat_id,symbol) DO UPDATE SET quantity=quantity+?", 
              (uid, cid, symbol, quantity, quantity))
    conn.commit()
    conn.close()
    return f"✅ Куплено {quantity} акций **{STOCKS[symbol]['name']}** за {total} монет!"

