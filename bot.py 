async def clan_create(chat_id: int, user_id: int, name: str) -> str:
    """Создание клана"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    if c.execute("SELECT id FROM clans WHERE chat_id = ? AND name = ?", (chat_id, name)).fetchone():
        conn.close()
        return "❌ Клан с таким названием уже существует!"
    
    if c.execute("SELECT id FROM clans WHERE chat_id = ? AND members LIKE ?", (chat_id, f"%{user_id}%")).fetchone():
        conn.close()
        return "❌ Ты уже состоишь в клане!"
    
    c.execute("INSERT INTO clans (chat_id, name, owner_id, members) VALUES (?,?,?,?)", 
              (chat_id, name, user_id, str(user_id)))
    conn.commit()
    conn.close()
    
    await unlock_achievement(user_id, "create_clan")
    return f"✅ Клан **{name}** создан!"

async def clan_join(chat_id: int, user_id: int, name_or_id: str) -> str:
    """Вступление в клан"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    c.execute("SELECT id, name, members FROM clans WHERE chat_id = ?", (chat_id,))
    all_clans = c.fetchall()
    
    if not all_clans:
        conn.close()
        return "❌ В этом чате нет кланов! Создай: `создать клан Название`"
    
    found_clan = None
    search = name_or_id.strip().lower()
    
    for clan in all_clans:
        clan_id, clan_name, members = clan
        if str(clan_id) == search or clan_name.lower() == search or search in clan_name.lower():
            found_clan = clan
            break
    
    if not found_clan:
        clan_names = "\n".join([f"• {c[1]} (ID: {c[0]})" for c in all_clans])
        conn.close()
        return f"❌ Клан '{name_or_id}' не найден!\n\n📋 **Доступные кланы:**\n{clan_names}"
    
    cid, cname, members = found_clan[0], found_clan[1], found_clan[2].split(",") if found_clan[2] else []
    
    if str(user_id) in members:
        conn.close()
        return "❌ Ты уже в этом клане!"
    
    if c.execute("SELECT id FROM clans WHERE chat_id = ? AND members LIKE ?", (chat_id, f"%{user_id}%")).fetchone():
        conn.close()
        return "❌ Ты уже состоишь в другом клане! Выйди сначала: `выйти из клана`"
    
    members.append(str(user_id))
    c.execute("UPDATE clans SET members = ? WHERE id = ?", (",".join(members), cid))
    conn.commit()
    conn.close()
    
    await unlock_achievement(user_id, "join_clan")
    return f"✅ Ты вступил в клан **{cname}**! 🎉"

async def clan_leave(chat_id: int, user_id: int) -> str:
    """Выход из клана"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    
    row = c.execute("SELECT id, name, members, owner_id FROM clans WHERE chat_id = ? AND members LIKE ?", 
                    (chat_id, f"%{user_id}%")).fetchone()
    
    if not row:
        conn.close()
        return "❌ Ты не в клане!"
    
    cid, cname, members, owner = row[0], row[1], row[2].split(",") if row[2] else [], row[3]
    
    if owner == user_id:
        conn.close()
        return "❌ Лидер не может выйти! Передай клан другому участнику."
    
    members.remove(str(user_id))
    c.execute("UPDATE clans SET members = ? WHERE id = ?", (",".join(members), cid))
    conn.commit()
    conn.close()
    
    return f"✅ Ты вышел из клана **{cname}**!"

