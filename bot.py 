async def save_message(chat_id, user_id, username, text):
    if not text or len(text) > 1000: return
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT INTO messages (chat_id, user_id, username, text, date) VALUES (?,?,?,?,?)", (chat_id, user_id, username, text[:500], datetime.now().isoformat()))
    today = datetime.now().strftime("%Y-%m-%d")
    c.execute("INSERT INTO message_stats (user_id, chat_id, date, count) VALUES (?,?,?,1) ON CONFLICT(user_id, chat_id, date) DO UPDATE SET count = count + 1", (user_id, chat_id, today))
    conn.commit()
    conn.close()

