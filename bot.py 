async def ask_groq(messages) -> str:
    if not GROQ_API_KEY:
        return None
    for attempt in range(3):
        try:
            async with aiohttp.ClientSession() as session:
                headers = {"Authorization": f"Bearer {GROQ_API_KEY}", "Content-Type": "application/json"}
                payload = {"model": "llama3-70b-8192", "messages": messages, "temperature": 0.9, "max_tokens": 500}
                async with session.post("https://api.groq.com/openai/v1/chat/completions", json=payload, headers=headers, timeout=30) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        return data["choices"][0]["message"]["content"].strip()
                    elif resp.status == 429:
                        await asyncio.sleep(2 ** attempt)
                        continue
                    else:
                        return None
        except Exception as e:
            log_error(e, f"ask_groq_attempt_{attempt}")
            await asyncio.sleep(1)
    return None

