def get_belief(topic: str) -> str:
    """Возвращает мнение бота по теме"""
    for key, data in BELIEFS.items():
        if key in topic.lower():
            return f"Я считаю что {key} — {data['opinion']}. Уверен на {data['confidence']}% 💯"
    return None

