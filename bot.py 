class RouletteGame:
    """ЕВРОПЕЙСКАЯ РУЛЕТКА С ПОЛНЫМИ СТАВКАМИ"""
    
    def __init__(self):
        self.numbers = list(range(0, 37))
        self.red = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36]
        self.black = [2,4,6,8,10,11,13,15,17,20,22,24,26,28,29,31,33,35]
        self.green = [0]
        self.bet_types = {
            "число": {"multiplier": 35, "desc": "Угадать точное число"},
            "цвет": {"multiplier": 2, "desc": "Красный/Черный"},
            "четность": {"multiplier": 2, "desc": "Четное/Нечетное"},
            "диапазон": {"multiplier": 3, "desc": "1-12, 13-24, 25-36"},
            "ряд": {"multiplier": 2, "desc": "1-34, 2-35, 3-36"},
            "дюжина": {"multiplier": 3, "desc": "1-12, 13-24, 25-36"},
            "колонка": {"multiplier": 3, "desc": "1-34, 2-35, 3-36"},
            "соседи": {"multiplier": 35, "desc": "Соседние числа"},
        }
        self.history = []
    
    async def spin(self, user_id: int, bet: int, bet_type: str, value: str) -> dict:
        """ВРАЩЕНИЕ РУЛЕТКИ"""
        if bet <= 0:
            return {"error": "Ставка должна быть больше 0!"}
        
        if bet > 100000:
            return {"error": "Максимальная ставка 100,000 монет!"}
        
        coins = await get_coins(user_id)
        if coins < bet:
            return {"error": f"Недостаточно монет! Есть {coins}"}
        
        if not await can_do(user_id, "roulette"):
            remaining = await get_cooldown_time(user_id, "roulette")
            return {"error": f"⏳ Подожди {remaining} секунд!"}
        
        await remove_coins(user_id, bet)
        await set_cooldown(user_id, "roulette")
        
        number = random.choice(self.numbers)
        color = "зеленый" if number == 0 else "красный" if number in self.red else "черный"
        
        self.history.append({"number": number, "color": color})
        if len(self.history) > 50:
            self.history.pop(0)
        
        win = 0
        multiplier = 0
        bet_type_lower = bet_type.lower()
        
        if bet_type_lower == "число" and value.isdigit():
            if int(value) == number:
                multiplier = 35
                win = bet * multiplier
        
        elif bet_type_lower == "цвет":
            if value.lower() == color:
                multiplier = 2 if color != "зеленый" else 35
                win = bet * multiplier
        
        elif bet_type_lower == "четность":
            is_even = number % 2 == 0 and number != 0
            if value.lower() == "четное" and is_even:
                multiplier = 2
                win = bet * multiplier
            elif value.lower() == "нечетное" and not is_even and number != 0:
                multiplier = 2
                win = bet * multiplier
        
        elif bet_type_lower in ["диапазон", "дюжина"]:
            ranges = {"1-12": range(1,13), "13-24": range(13,25), "25-36": range(25,37)}
            if value in ranges and number in ranges[value]:
                multiplier = 3
                win = bet * multiplier
        
        elif bet_type_lower in ["ряд", "колонка"]:
            rows = {"1-34": [1,4,7,10,13,16,19,22,25,28,31,34],
                    "2-35": [2,5,8,11,14,17,20,23,26,29,32,35],
                    "3-36": [3,6,9,12,15,18,21,24,27,30,33,36]}
            if value in rows and number in rows[value]:
                multiplier = 3
                win = bet * multiplier
        
        if win > 0:
            await add_coins(user_id, win)
            await unlock_achievement(user_id, "first_game")
        
        return {
            "success": True,
            "number": number,
            "color": color,
            "win": win,
            "bet": bet,
            "multiplier": multiplier,
            "bet_type": bet_type,
            "bet_value": value,
            "history": self.history[-5:]
        }
    
    async def get_stats(self) -> dict:
        """ПОЛУЧИТЬ СТАТИСТИКУ РУЛЕТКИ"""
        if not self.history:
            return {"message": "Нет данных для статистики"}
        
        numbers = [h["number"] for h in self.history]
        colors = [h["color"] for h in self.history]
        
        return {
            "total_spins": len(self.history),
            "most_common_number": max(set(numbers), key=numbers.count),
            "red_count": colors.count("красный"),
            "black_count": colors.count("черный"),
            "green_count": colors.count("зеленый"),
            "last_number": self.history[-1]["number"],
            "last_color": self.history[-1]["color"]
        }

