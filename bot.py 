    if amount <= 0:
        return "❌ Сумма должна быть больше 0!"
    try:
        rate = CRYPTO[crypto_type]["price"] * CRYPTO_TO_COINS
        coins = int(amount * rate)
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
