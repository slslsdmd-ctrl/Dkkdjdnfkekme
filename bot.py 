async def translate_text(text: str, target: str) -> str:
    try:
        url = f"https://api.mymemory.translated.net/get?q={urllib.parse.quote(text)}&langpair={'ru|en' if target == 'en' else 'en|ru'}"
        async with aiohttp.ClientSession() as session:
