async def add_coins(user_id: int, chat_id: int, amount: int):
    if amount <= 0:
        return
    for attempt in range(3):
        try:
            conn = sqlite3.connect("fable_bot.db", timeout=10)
            c = conn.cursor()
            c.execute("SELECT coins FROM users WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
            row = c.fetchone()
            if row:
                new_amount = row[0] + amount
                c.execute("UPDATE users SET coins = ? WHERE user_id = ? AND chat_id = ?", (new_amount, user_id, chat_id))
            else:
                c.execute("INSERT INTO users (user_id, chat_id, coins) VALUES (?, ?, ?)", (user_id, chat_id, amount))
            conn.commit()
            conn.close()
            return
        except sqlite3.OperationalError as e:
            if "database is locked" in str(e):
                await asyncio.sleep(0.5)
            else:
                log_error(e, "add_coins")
                return
        except Exception as e:
            log_error(e, "add_coins")
            return

