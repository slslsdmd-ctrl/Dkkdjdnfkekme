async def get_item_buffs(user_id, chat_id):
    items = await get_inventory(user_id, chat_id)
    buffs = {"buff_x": 1, "bonus_chance": 0, "bonus_amount": 0, "cooldown_reduce": 0, 
             "protect_chance": 0, "rob_bonus": 0, "bank_bonus": 0, "business_x": 1,
             "business_discount": 0, "msg_bonus": 0, "instant_cooldown": False,
             "cooldown_boost": 1, "reset_all": False, "passive_income": 0, "auto_work": False}
    for item_name, qty in items:
        if item_name in RARE_ITEMS:
            data = RARE_ITEMS[item_name]
            for key in buffs:
                if key in data:
                    if key in ["buff_x", "business_x", "cooldown_boost"]:
                        buffs[key] = max(buffs[key], data[key])
                    elif key in ["instant_cooldown", "reset_all", "auto_work"]:
                        buffs[key] = buffs[key] or data[key]
                    else:
                        buffs[key] += data[key] * qty
    return buffs

