async def bfg_sell_estate(user_id: int, chat_id: int, estate_name: str, quantity: int = 1) -> str:
    if estate_name not in REAL_ESTATE:
        return "❌ Такой недвижимости нет!"
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT quantity FROM bfg_estate WHERE user_id = ? AND chat_id = ? AND estate = ?", (user_id, chat_id, estate_name))
    row = c.fetchone()
    if not row or row[0] < quantity:
        conn.close()
        return f"❌ У тебя нет {quantity} {estate_name}!"
    data = REAL_ESTATE[estate_name]
    price = int(data["price"] * 0.7)
    if row[0] == quantity:
        c.execute("DELETE FROM bfg_estate WHERE user_id = ? AND chat_id = ? AND estate = ?", (user_id, chat_id, estate_name))
    else:
        c.execute("UPDATE bfg_estate SET quantity = quantity - ? WHERE user_id = ? AND chat_id = ? AND estate = ?", (quantity, user_id, chat_id, estate_name))
    total = price * quantity
    await add_coins(user_id, chat_id, total)
    conn.commit()
    conn.close()
    return f"✅ Продано {data['emoji']} {estate_name.capitalize()} x{quantity} за **{total}** монет!"

