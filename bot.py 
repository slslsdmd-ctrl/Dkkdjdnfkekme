        buffs = {"buff_x": 1, "bonus_chance": 0, "bonus_amount": 0, "cooldown_reduce": 0, "protect_chance": 0, "rob_bonus": 0, "business_x": 1, "business_discount": 0, "passive_income": 0, "msg_bonus": 0, "cooldown_boost": 1}
        for item_name, qty in items:
            if item_name in RARE_ITEMS:
                data = RARE_ITEMS[item_name]
                for key in buffs:
                    if key in data:
                        if key in ["buff_x", "business_x", "cooldown_boost"]:
                            buffs[key] = max(buffs[key], data[key])
                        else:
                            buffs[key] += data[key] * qty
        return buffs
    except Exception as e:
