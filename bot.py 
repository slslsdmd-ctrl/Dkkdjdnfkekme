async def translate_text(text, target_lang):
    try:
        async with aiohttp.ClientSession() as session:
            url = "https://libretranslate.com/translate"
            payload = {"q": text, "target": target_lang, "format": "text"}
            async with session.post(url, json=payload) as resp:
                data = await resp.json()
                return data.get("translatedText", "❌ Ошибка перевода")
    except:
        return "❌ Сервис перевода временно недоступен"

def calculate(expression):
    try:
        if not re.match(r'^[\d+\-*/().\s]+$', expression):
            return "❌ Недопустимые символы!"
        result = eval(expression)
        return f"✅ {expression} = **{result}**"
    except ZeroDivisionError:
        return "❌ Деление на ноль!"
    except:
        return "❌ Ошибка в выражении!"

async def get_new_year_countdown():
    now = datetime.now()
    ny = datetime(now.year + 1, 1, 1, 0, 0, 0)
    diff = ny - now
    days = diff.days
    hours = diff.seconds // 3600
    minutes = (diff.seconds % 3600) // 60
    seconds = diff.seconds % 60
    return days, hours, minutes, seconds

async def add_warn(user_id, chat_id, reason, warned_by, duration=None):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT COUNT(*) FROM warns WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    count = c.fetchone()[0] + 1
    until_date = None
    if duration:
        until_date = (datetime.now() + timedelta(seconds=duration)).isoformat()
    c.execute("INSERT INTO warns (user_id, chat_id, count, reason, date, warned_by, until_date) VALUES (?,?,?,?,?,?,?)", (user_id, chat_id, count, reason, datetime.now().isoformat(), warned_by, until_date))
    conn.commit()
    conn.close()
    if count >= 5:
        await bot.ban_chat_member(chat_id, user_id)
        return f"⚠️ {count}/5 варнов. Пользователь исключён."
    if duration:
        return f"⚠️ Предупреждение {count}/5: {reason} (снимется через {duration//60} мин.)"
    return f"⚠️ Предупреждение {count}/5: {reason}"

