def init_db():
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("""CREATE TABLE IF NOT EXISTS messages
                 (id INTEGER PRIMARY KEY, chat_id INTEGER, user_id INTEGER, 
                  username TEXT, text TEXT, date TEXT, coins INTEGER DEFAULT 0, daily_coins INTEGER DEFAULT 0)""")
    c.execute("""CREATE TABLE IF NOT EXISTS warns
                 (user_id INTEGER, chat_id INTEGER, count INTEGER, 
                  reason TEXT, date TEXT, warned_by INTEGER, until_date TIMESTAMP)""")
    c.execute("""CREATE TABLE IF NOT EXISTS rp_roles
                 (user_id INTEGER, chat_id INTEGER, level INTEGER DEFAULT 1,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS user_join_date
                 (user_id INTEGER, chat_id INTEGER, join_date TEXT,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS duels
                 (chat_id INTEGER, challenger INTEGER, opponent INTEGER, turn INTEGER, aim_bonus INTEGER, message_id INTEGER)""")
    c.execute("""CREATE TABLE IF NOT EXISTS chat_stats
                 (chat_id INTEGER PRIMARY KEY, msg_count INTEGER DEFAULT 0, last_auto_time TIMESTAMP)""")
    c.execute("""CREATE TABLE IF NOT EXISTS settings
                 (chat_id INTEGER PRIMARY KEY, welcome_text TEXT, rules_text TEXT)""")
    c.execute("""CREATE TABLE IF NOT EXISTS bans
                 (user_id INTEGER, chat_id INTEGER, until_date TIMESTAMP)""")
    c.execute("""CREATE TABLE IF NOT EXISTS awards
                 (user_id INTEGER, chat_id INTEGER, award_name TEXT, given_by INTEGER, date TEXT)""")
    c.execute("""CREATE TABLE IF NOT EXISTS reputation
                 (user_id INTEGER, chat_id INTEGER, rep INTEGER DEFAULT 0,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS marriages
                 (user_id INTEGER, chat_id INTEGER, spouse_id INTEGER, date TEXT,
                  PRIMARY KEY (user_id, chat_id))""")
    c.execute("""CREATE TABLE IF NOT EXISTS clans
                 (id INTEGER PRIMARY KEY AUTOINCREMENT, chat_id INTEGER, name TEXT, owner_id INTEGER, members TEXT)""")
