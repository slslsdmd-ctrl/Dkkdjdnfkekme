        nq=r[0]-qty
        if nq<=0:c.execute("DELETE FROM inventory WHERE user_id=? AND chat_id=? AND item_name=?",(uid,cid,item))
        else:c.execute("UPDATE inventory SET quantity=? WHERE user_id=? AND chat_id=? AND item_name=?",(nq,uid,cid,item))
        conn.commit();conn.close();return True
    conn.close();return False

async def get_item_buffs(uid,cid):
    items=await get_inventory(uid,cid)
    buffs={"buff_x":1,"bonus_chance":0,"bonus_amount":0,"cooldown_reduce":0,"protect_chance":0,"rob_bonus":0,"business_x":1,"business_discount":0,"passive_income":0}
    for iname,qty in items:
        if iname in RARE_ITEMS:
            d=RARE_ITEMS[iname]
            for k in buffs:
                if k in d:
                    if k in["buff_x","business_x"]:buffs[k]=max(buffs[k],d[k])
                    else:buffs[k]+=d[k]*qty
    return buffs

