async def ask_ai(message, username):
    try:
        async with aiohttp.ClientSession() as session:
            payload = {
                "messages": [
                    {"role": "assistant", "content": f"Ты {BOT_NAME} - русский бот. Отвечай кратко с эмодзи."},
                    {"role": "user", "content": message}
                ],
                "prompt": message,
                "model": "gpt-3.5-turbo"
            }
            async with session.post("https://nexra.aryahcr.cc/api/chat/gpt", json=payload, timeout=20) as resp:
                if resp.status == 200:
                    text = await resp.text()
                    try:
                        data = json.loads(text)
                        if "gpt" in data:
                            return data["gpt"][:800]
                    except:
                        return text[:800] if len(text) > 10 else None
    except:
        pass
    try:
        async with aiohttp.ClientSession() as session:
            encoded = urllib.parse.quote(f"Ответь на русском: {message}")
            async with session.get(f"https://text.pollinations.ai/{encoded}", timeout=15) as resp:
                if resp.status == 200:
                    text = await resp.text()
                    if text and len(text) > 5:
                        return text[:800]
    except:
        pass
    msg = message.lower()
    if re.search(r'\d+\s*[\+\-\*\/]\s*\d+', msg):
        try:
            return f"🧮 {eval(re.search(r'(\d+\s*[\+\-\*\/]\s*\d+)', msg).group())}"
        except:
            pass
    if "шутк" in msg or "анекдот" in msg:
        return random.choice(["😂 Колобок повесился.", "🤣 Прогеры путают Хэллоуин и Рождество? OCT 31 = DEC 25!", "😆 Ёжик: «Мама!»"])
    if "?" in msg:
        return random.choice(["✅ Да!", "❌ Нет!", "🎲 50/50", "🤔 Сложно..."])
    return random.choice([f"💬 Слушаю, @{username}!", "😄 Интересно!", "🔥 Продолжай!"])

async def generate_image(prompt):
    try:
        encoded = urllib.parse.quote(prompt)
        return f"https://image.pollinations.ai/prompt/{encoded}?width=768&height=768&nologo=true"
    except:
        return None

