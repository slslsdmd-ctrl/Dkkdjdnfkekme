@dp.message()
async def handle_all_messages(message: types.Message):
    if not message.text:
        if message.voice or message.video_note:
            await message.reply("🎤 Распознавание речи пока недоступно.")
        return
    
    text = message.text.strip()
    text_lower = text.lower()
    
    if message.chat.type in ["group", "supergroup"]:
        await save_message(message.chat.id, message.from_user.id, message.from_user.username, text)
        await add_coins(message.from_user.id, message.chat.id, 1)
    
    # Права создателю и админам
    try:
        chat = await bot.get_chat(message.chat.id)
        if hasattr(chat, 'creator') and chat.creator:
            await set_role(chat.creator.id, message.chat.id, 10)
    except:
        pass
    if message.from_user.id == YOUR_ID:
        await set_role(message.from_user.id, message.chat.id, 10)
    try:
        admins = await bot.get_chat_administrators(message.chat.id)
        for admin in admins:
            await set_role(admin.user.id, message.chat.id, 10)
    except:
        pass
    
    # Новые участники
    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id:
                await set_role(message.from_user.id, message.chat.id, 10)
                await bot.send_message(message.chat.id, f"👑 **{BOT_NAME} активирован!**\nКоманды: `команды`", parse_mode=ParseMode.MARKDOWN)
                continue
            if user.id == YOUR_ID:
                await set_role(user.id, message.chat.id, 10)
                continue
            await save_join_date(user.id, message.chat.id)
            welcome_text = await get_welcome(message.chat.id)
            if welcome_text:
                await message.reply(welcome_text.replace("{имя}", user.first_name), parse_mode=ParseMode.MARKDOWN)
        return

    # ========== ГЕНЕРАЦИЯ ФОТО ==========
    for cmd in ["сгенерируй", "нарисуй", "фото "]:
        if text_lower.startswith(cmd):
            if cmd == "сгенерируй":
                prompt = text[11:].strip()
            elif cmd == "нарисуй":
                prompt = text[8:].strip()
            else:
                prompt = text[5:].strip()
            if not prompt:
                await message.reply("ℹ️ `сгенерируй описание`")
                return
            await bot.send_chat_action(message.chat.id, "upload_photo")
            msg = await message.reply(f"🎨 Генерирую: **{prompt}**...", parse_mode=ParseMode.MARKDOWN)
            image_url = await generate_image(prompt)
            if image_url:
                try:
                    await bot.send_photo(message.chat.id, image_url, caption=f"🎨 {prompt}", reply_to_message_id=message.message_id)
                    await msg.delete()
                except:
                    await msg.edit_text(f"❌ Ошибка!\n🔗 {image_url}")
            else:
                await msg.edit_text("❌ Ошибка генерации!")
            return

    # ========== ИИ ОТВЕТЫ ==========
    if f"@{BOT_NAME.lower()}" in text_lower:
        clean = text_lower.replace(f"@{BOT_NAME.lower()}", "").strip()
        if clean.startswith(("сгенерируй", "нарисуй")):
            prompt = clean[11:].strip() if clean.startswith("сгенерируй") else clean[8:].strip()
            if prompt:
                await bot.send_chat_action(message.chat.id, "upload_photo")
                image_url = await generate_image(prompt)
                if image_url:
                    await bot.send_photo(message.chat.id, image_url, caption=f"🎨 {prompt}", reply_to_message_id=message.message_id)
                else:
                    await message.reply("❌ Ошибка!")
                return
        if clean:
            await bot.send_chat_action(message.chat.id, "typing")
            reply = await ask_ai(clean, message.from_user.username or message.from_user.first_name)
            if reply:
                await message.reply(reply)
            return
    
    if text_lower.startswith("бот ") and len(text) > 4:
        clean = text[4:].strip()
        if clean:
            await bot.send_chat_action(message.chat.id, "typing")
            reply = await ask_ai(clean, message.from_user.username or message.from_user.first_name)
            if reply:
                await message.reply(reply)
            return
    
    if message.reply_to_message and message.reply_to_message.from_user.id == bot.id:
        if text and not text.startswith("/"):
            await bot.send_chat_action(message.chat.id, "typing")
            reply = await ask_ai(text, message.from_user.username or message.from_user.first_name)
            if reply:
                await message.reply(reply)
            return

    # ========== КУРСЫ ВАЛЮТ ==========
