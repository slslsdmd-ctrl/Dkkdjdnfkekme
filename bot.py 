async def add_coins(user_id, chat_id, amount):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT coins FROM messages WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    if row:
        new_amount = row[0] + amount
        c.execute("UPDATE messages SET coins = ? WHERE user_id = ? AND chat_id = ?", (new_amount, user_id, chat_id))
    else:
        c.execute("INSERT INTO messages (user_id, chat_id, coins) VALUES (?,?,?)", (user_id, chat_id, amount))
    conn.commit()
    conn.close()

