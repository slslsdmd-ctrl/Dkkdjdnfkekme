                        data = await resp.json()
                        if symbol.lower() in data:
                            price = data[symbol.lower()]['usd']
                            CRYPTO_PRICES[symbol] = price
                            return price
        except:
            pass
        
        # Если не получилось - используем кэшированный курс с колебаниями
        base_price = CRYPTO_PRICES.get(symbol, 1)
        volatility = 0.05  # 5% волатильность
        change = random.uniform(-volatility, volatility)
        price = base_price * (1 + change)
        
        # Обновляем кэш
        CRYPTO_PRICES[symbol] = price
        
        return max(0.0001, price)
    
