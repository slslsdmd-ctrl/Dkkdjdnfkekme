async def get_bank_projection(user_id: int, days: int = 30) -> dict:
    """Прогноз роста банковского счета"""
    balance = await get_bank_balance(user_id)
    rate = await get_bank_interest_rate(user_id)
    
    projection = []
    current = balance
    for day in range(1, days + 1):
        current = int(current * (1 + rate / 24))  # Начисление каждый час
        projection.append(current)
    
    return {
        "current": balance,
        "rate": rate * 100,
        "projection": projection,
        "final": projection[-1] if projection else balance
    }

