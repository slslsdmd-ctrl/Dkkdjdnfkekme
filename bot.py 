            5: {"name": "👑 Императорский VIP", "price": 1000000, "bonus": 1.50, "perks": ["daily_bonus_x20", "work_bonus", "no_tax", "free_rent", "all_boost"]},
        }
        self.vip_members = {}
    
    async def upgrade_vip(self, user_id: int, level: int) -> dict:
        """ПОВЫСИТЬ VIP УРОВЕНЬ"""
        if level not in self.vip_levels:
            return {"error": "Такого VIP уровня нет!"}
        
        # Проверяем, не выше ли уже уровень
        current = self.vip_members.get(user_id, {}).get("level", 0)
        if current >= level:
            return {"error": f"У тебя уже {self.vip_levels[current]['name']} или выше!"}
        
        vip_data = self.vip_levels[level]
        price = vip_data["price"]
        
        coins = await get_coins(user_id)
        if coins < price:
            return {"error": f"Недостаточно монет! Нужно {price}"}
        
        await remove_coins(user_id, price)
        
        self.vip_members[user_id] = {
            "level": level,
            "started": datetime.now().isoformat(),
            "expires": (datetime.now() + timedelta(days=30)).isoformat()
        }
        
        return {
            "success": True,
            "level": level,
            "name": vip_data["name"],
            "bonus": vip_data["bonus"],
            "perks": vip_data["perks"]
        }
    
    async def get_vip_info(self, user_id: int) -> dict:
        """ПОЛУЧИТЬ VIP ИНФОРМАЦИЮ"""
        if user_id not in self.vip_members:
            return {"level": 0, "name": "Обычный игрок"}
        
        vip = self.vip_members[user_id]
        level = vip["level"]
        data = self.vip_levels[level]
        
        expires = datetime.fromisoformat(vip["expires"])
        days_left = (expires - datetime.now()).days
        
        return {
            "level": level,
            "name": data["name"],
            "bonus": data["bonus"],
            "perks": data["perks"],
            "days_left": days_left
        }
    
    async def get_vip_bonus(self, user_id: int) -> float:
        """ПОЛУЧИТЬ VIP БОНУС"""
        if user_id not in self.vip_members:
            return 1.0
        
        vip = self.vip_members[user_id]
        level = vip["level"]
        data = self.vip_levels[level]
        
        # Проверяем истечение
        expires = datetime.fromisoformat(vip["expires"])
        if expires < datetime.now():
            return 1.0
        
        return data["bonus"]
    
    async def check_vip_perk(self, user_id: int, perk: str) -> bool:
        """ПРОВЕРИТЬ НАЛИЧИЕ PERK У VIP"""
        if user_id not in self.vip_members:
            return False
        
        vip = self.vip_members[user_id]
        level = vip["level"]
        data = self.vip_levels[level]
        
        # Проверяем истечение
        expires = datetime.fromisoformat(vip["expires"])
        if expires < datetime.now():
            return False
        
        return perk in data["perks"]

