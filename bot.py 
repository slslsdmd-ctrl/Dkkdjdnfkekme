def normalize_text(text: str) -> str:
    return re.sub(r"\s+", " ", (text or "").strip())

def get_time_in_city(city_name: str) -> str:
    try:
        city_lower = city_name.lower().strip()
        if city_lower in TIMEZONES:
            tz = pytz.timezone(TIMEZONES[city_lower])
            return datetime.now(tz).strftime('%H:%M')
        for tz_name in pytz.all_timezones:
            if city_lower in tz_name.lower():
                tz = pytz.timezone(tz_name)
                return datetime.now(tz).strftime('%H:%M')
        return None
    except Exception as e:
        log_error(e, "get_time_in_city")
        return None

def get_time_response(text: str) -> str:
    text_lower = text.lower()
    prefixes = [
        "сколько время в ", "сколько время по ",
        "время в ", "время по ",
        "который час в ", "который час по ",
        "часов в ", "часов по ",
    ]
    city_name = None
    for prefix in prefixes:
        if prefix in text_lower:
            city_name = text_lower.split(prefix, 1)[1].strip()
            break
    if not city_name:
        for word in ["в ", "по "]:
            if word in text_lower:
                parts = text_lower.split(word)
                if len(parts) > 1:
                    possible_city = parts[-1].strip()
                    if len(possible_city) > 2:
                        city_name = possible_city
                        break
    if city_name and len(city_name) > 1:
        time_result = get_time_in_city(city_name)
        if time_result:
            return f"🕐 В **{city_name.title()}**: {time_result}"
    msk_time = get_time_in_city("москва")
    if msk_time:
        return f"🕐 По МСК: **{msk_time}**"
    return "❌ Не могу определить время"

async def get_weather(city: str = "Москва") -> str:
    try:
        encoded_city = urllib.parse.quote(city)
        url = f"https://wttr.in/{encoded_city}?format=%C+%t+%w&lang=ru"
        async with aiohttp.ClientSession() as session:
            async with session.get(url, timeout=10) as resp:
                if resp.status == 200:
                    weather_text = (await resp.text()).strip()
                    parts = weather_text.split()
                    if len(parts) >= 2:
                        condition = parts[0]
                        temp = parts[1]
                        wind = parts[2] if len(parts) > 2 else "Н/Д"
                        return f"🌤 **{city.title()}**\n\n🌡 Температура: **{temp}**\n💨 Ветер: **{wind}**\n☁️ {condition}"
                    return f"🌤 **{city.title()}**: {weather_text}"
        return f"❌ Город '{city}' не найден"
    except Exception as e:
        log_error(e, "get_weather")
        return "❌ Не удалось получить погоду"

