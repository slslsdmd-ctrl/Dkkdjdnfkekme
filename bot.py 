async def get_global_rank(user_id: int) -> dict:
    """Возвращает глобальный ранг пользователя"""
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        
        c.execute("SELECT coins FROM users WHERE user_id = ?", (user_id,))
        row = c.fetchone()
        if not row:
            conn.close()
            return {"rank": 0, "total_users": 0, "coins": 0, "percentile": 0}
        
        coins = row[0]
        
        c.execute("SELECT COUNT(*) FROM users WHERE coins > ?", (coins,))
        higher = c.fetchone()[0]
        
        c.execute("SELECT COUNT(*) FROM users WHERE coins > 0")
        total = c.fetchone()[0]
        
        conn.close()
        
        return {
            "rank": higher + 1,
            "total_users": total,
            "coins": coins,
            "percentile": round((total - higher) / total * 100, 2) if total > 0 else 0
        }
    except Exception as e:
        log_error(e, "get_global_rank")
        return {"rank": 0, "total_users": 0, "coins": 0, "percentile": 0}

