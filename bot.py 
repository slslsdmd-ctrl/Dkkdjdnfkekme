            "- Аниме: Атака Титанов — лучшее, Наруто — классика, САО — гавно\n"
            "- Еда: пицца > суши, шаурма — топ, ананасы в пицце — зашквар\n"
            "- Спорт: качалка > кроссфит, футбол скучный, баскетбол круче\n"
            "- Музыка: рэп > попса, рок для души, k-pop — кринж\n"
            "- Фильмы: Марвел > DC, Интерстеллар — шедевр, русские комедии — дно\n"
            "- Техника: iPhone переоценён, Android/Poco — топ за свои деньги\n"
        ),
        'sarcasm':("Ты — Fable в режиме САРКАЗМА. Отвечай с иронией и чёрным юмором. Будь дерзким но не агрессивным."),
        'philosopher':("Ты — Fable в режиме ФИЛОСОФА. Рассуждай глубоко, задавай встречные вопросы."),
        'poet':("Ты — Fable в режиме ПОЭТА. Отвечай стихами или очень поэтично."),
    }
    sys=modes.get(mode,modes['normal'])
    msgs=[{"role":"system","content":sys}]
    if chat_id:
        ctx=get_dialog_context(chat_id)
        if ctx:msgs.extend(ctx)
    if reference_context:msgs.append({"role":"system","content":f"Факты:\n{reference_context}"})
    msgs.append({"role":"user","content":prompt})
    return msgs

async def ask_groq(msgs)->str:
    if not GROQ_API_KEY:return None
    try:
        async with aiohttp.ClientSession()as s:
            hdrs={"Authorization":f"Bearer {GROQ_API_KEY}","Content-Type":"application/json"}
            pl={"model":"llama3-70b-8192","messages":msgs,"temperature":0.9,"max_tokens":500}
            async with s.post("https://api.groq.com/openai/v1/chat/completions",json=pl,headers=hdrs,timeout=30)as r:
                if r.status==200:return(await r.json())["choices"][0]["message"]["content"].strip()
    except:pass
    return None

async def ask_pollinations(msgs)->str:
    try:
        hdrs={"Content-Type":"application/json"}
        if POLLINATIONS_API_KEY:hdrs["Authorization"]=f"Bearer {POLLINATIONS_API_KEY}"
        pl={"model":"openai","messages":msgs,"temperature":0.9,"max_tokens":500}
        async with aiohttp.ClientSession()as s:
            async with s.post("https://gen.pollinations.ai/v1/chat/completions",json=pl,headers=hdrs,timeout=30)as r:
                if r.status==200:return(await r.json())["choices"][0]["message"]["content"].strip()
    except:pass
    return None

async def ask_llm(prompt:str,reference_context:str=None,chat_id:int=None)->str:
    mode=await get_bot_mode(chat_id)if chat_id else'normal'
    msgs=build_ai_messages(prompt,reference_context,chat_id,mode)
    reply=await ask_groq(msgs)
    if reply and len(reply)>5:return reply
    reply=await ask_pollinations(msgs)
    if reply and len(reply)>5:return reply
    return None

def get_cached_answer(q:str)->str:
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("SELECT answer FROM ai_cache WHERE question_hash=?",(hashlib.md5(q.lower().encode()).hexdigest(),));r=c.fetchone();conn.close();return r[0]if r else None

def save_cached_answer(q:str,a:str):
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("INSERT OR REPLACE INTO ai_cache VALUES(?,?,?,?)",(hashlib.md5(q.lower().encode()).hexdigest(),q,a,datetime.now().isoformat()));conn.commit();conn.close()

async def ask_ai(prompt:str,chat_id:int=None,user_id:int=None)->str:
    prompt=normalize_text(prompt);pl=prompt.lower();msg_type=analyze_message(prompt)
    print(f"📝 [{msg_type}] {prompt}")
    if chat_id and user_id:await save_dialog(chat_id,user_id,"user",prompt)
    sl=get_local_smart_answer(prompt)
    if sl:return sl
    if msg_type=='greeting':return random.choice(["👋 Привет! Как жизнь?","👋 Здарова! Че как?","😊 Привет-привет!","👋 Йоу! Как сам?"])
    if msg_type=='time':return get_time_response(pl)
    if msg_type=='weather':
        city="Москва"
        for pfx in["погода в ","погода "]:
            if pl.startswith(pfx):city=pl[len(pfx):].strip()or"Москва";break
        return await get_weather(city)
    if msg_type=='insult':return random.choice(["😅 Ахах, ну ты смешной. Сам придумал или помог кто?","🤷‍♂️ И че? Мне пох, я выше этого","😏 Слабовато. В интернете и не такое видел","🙃 Ой да иди ты, мне лень даже отвечать на это","😊 Слушай, давай без этого. Лучше расскажи че ты хотел","💀 Твои оскорбления — уровень детсада. Попробуй ещё раз","🤙 Харош, харош. Засчитано. Но я всё равно лучше"])
    if msg_type=='emotion':
        if any(w in pl for w in["хаха","ахах","лол","кек","ору","ржу"]):return random.choice(["😄 Ахахахах!","🤣 Орууу!","😂 Жестко!","😆 Ну насмешил!"])
        return random.choice(["🤔 Бывает...","😊 Понимаю","🙃 Жиза","💯 Факты"])
    cached=get_cached_answer(prompt)
    if cached:return cached
    try:
        reply=await ask_llm(prompt,chat_id=chat_id)
        if reply and len(reply)>10:save_cached_answer(prompt,reply)
        if chat_id:await save_dialog(chat_id,0,"assistant",reply)
        return reply
    except:pass
    try:
        reply=await ask_llm(f"Ответь как живой человек, кратко: {prompt}",chat_id=chat_id)
        if reply and len(reply)>10:save_cached_answer(prompt,reply);return reply
    except:pass
    if msg_type=='question':
        sr=await smart_web_search(prompt)
        if sr and sr.get('extract'):return f"🔍 {sr.get('source','')}:\n{sr['extract'][:1500]}"
    return"Хз если честно. Можешь уточнить? 🤔"

