# Поиск
async def search_google_scrape(query:str)->list:
    eq=urllib.parse.quote(query);url=f"https://www.google.com/search?q={eq}&num=5&hl=ru"
    hdrs={'User-Agent':random.choice(USER_AGENTS),'Accept':'text/html','Accept-Language':'ru-RU,ru;q=0.9'}
    try:
        async with aiohttp.ClientSession()as s:
            await asyncio.sleep(random.uniform(0.5,1.5))
            async with s.get(url,headers=hdrs,timeout=15)as r:
                if r.status==200:
                    soup=BeautifulSoup(await r.text(),'lxml');res=[]
                    for item in soup.select('div.g')[:5]:
                        try:
                            t=item.select_one('h3');sn=item.select_one('div.VwiC3b')
                            if t and sn:res.append({'title':html.unescape(t.get_text()),'snippet':html.unescape(sn.get_text()),'source':'Google'})
                        except:continue
                    return res
    except:pass
    return[]

async def search_wikipedia(query:str)->str:
    try:
        async with aiohttp.ClientSession(headers=HTTP_HEADERS)as s:
            for lang in("ru","en"):
                url=f"https://{lang}.wikipedia.org/w/api.php?action=query&list=search&format=json&utf8=1&srlimit=3&srsearch={urllib.parse.quote(query)}"
                async with s.get(url,timeout=10)as r:
                    if r.status!=200:continue
                    data=await r.json()
                    for page in data.get("query",{}).get("search",[]):
                        title=page.get("title","")
                        surl=f"https://{lang}.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title)}"
                        async with s.get(surl,timeout=10)as r2:
                            if r2.status==200:
                                ext=(await r2.json()).get("extract","")
                                if ext and len(ext)>50:return f"{title}\n{ext[:2000]}"
    except:pass
    return None

async def smart_web_search(query:str)->dict:
    ck=hashlib.md5(f"s_{query}".encode()).hexdigest()
    conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
    c.execute("SELECT result,timestamp FROM search_cache WHERE key=?",(ck,));r=c.fetchone();conn.close()
    if r:
        res=json.loads(r[0])
        if datetime.now()-datetime.fromisoformat(r[1])<timedelta(hours=24):return res
    result=None
    wiki=await search_wikipedia(query)
    if wiki:result={'extract':wiki,'source':'Wikipedia'}
    if not result:
        google=await search_google_scrape(query)
        if google:result={'extract':google[0]['snippet'],'source':'Google'}
    if result:
        conn=sqlite3.connect("fable_bot.db");c=conn.cursor()
        c.execute("INSERT OR REPLACE INTO search_cache VALUES(?,?,?)",(ck,json.dumps(result,ensure_ascii=False),datetime.now().isoformat()));conn.commit();conn.close()
    return result

