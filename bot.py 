    if any(i in prompt_lower for i in insults):
        return 'insult'
    if any(w in prompt_lower for w in ["хаха", "ахах", "лол", "кек", "ору", "ржу", "угар"]):
        return 'emotion'
    if any(w in prompt_lower for w in ["грустно", "печаль", "жаль", "плохо", "😢", "😭"]):
