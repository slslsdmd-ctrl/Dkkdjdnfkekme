async def search_google_scrape(query: str) -> list:
    try:
        encoded_query = urllib.parse.quote(query)
        url = f"https://www.google.com/search?q={encoded_query}&num=5&hl=ru"
        headers = {'User-Agent': random.choice([
            'Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0 Safari/537.36',
            'Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7) Chrome/120.0.0.0 Safari/537.36',
        ]), 'Accept': 'text/html', 'Accept-Language': 'ru-RU,ru;q=0.9'}
        async with aiohttp.ClientSession() as session:
            await asyncio.sleep(random.uniform(0.5, 1.5))
            async with session.get(url, headers=headers, timeout=15) as response:
                if response.status == 200:
                    soup = BeautifulSoup(await response.text(), 'lxml')
                    results = []
                    for item in soup.select('div.g')[:5]:
                        try:
                            title_elem = item.select_one('h3')
                            snippet_elem = item.select_one('div.VwiC3b')
                            if title_elem and snippet_elem:
                                results.append({'title': html.unescape(title_elem.get_text()), 'snippet': html.unescape(snippet_elem.get_text()), 'source': 'Google'})
                        except Exception as e:
                            continue
                    return results
    except Exception as e:
        log_error(e, "search_google_scrape")
    return []

async def search_wikipedia(query: str) -> str:
    try:
        async with aiohttp.ClientSession(headers={"User-Agent": "FableBot/1.0"}, timeout=aiohttp.ClientTimeout(total=15)) as session:
            for lang in ("ru", "en"):
                try:
                    search_url = f"https://{lang}.wikipedia.org/w/api.php?action=query&list=search&format=json&utf8=1&srlimit=3&srsearch={urllib.parse.quote(query)}"
                    async with session.get(search_url) as resp:
                        if resp.status != 200:
                            continue
                        data = await resp.json()
                        pages = data.get("query", {}).get("search", [])
                        if not pages:
                            continue
                        for page in pages[:3]:
                            title = page.get("title", "")
                            if not title:
                                continue
                            summary_url = f"https://{lang}.wikipedia.org/api/rest_v1/page/summary/{urllib.parse.quote(title)}"
                            try:
                                async with session.get(summary_url) as resp2:
                                    if resp2.status == 200:
                                        data2 = await resp2.json()
                                        extract = data2.get("extract", "")
                                        if extract and len(extract) > 50:
                                            return f"📖 **{title}**\n\n{extract[:2000]}"
                            except Exception as e:
                                continue
                except Exception as e:
                    continue
    except Exception as e:
        log_error(e, "search_wikipedia")
    return None

async def smart_web_search(query: str) -> dict:
    try:
        cache_key = hashlib.md5(f"search_{query}".encode()).hexdigest()
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT result, timestamp FROM search_cache WHERE key = ?", (cache_key,))
        row = c.fetchone()
        conn.close()
        if row:
            result = json.loads(row[0])
            if datetime.now() - datetime.fromisoformat(row[1]) < timedelta(hours=6):
                return result
        result = None
        wiki_result = await search_wikipedia(query)
        if wiki_result:
            result = {'title': '', 'extract': wiki_result, 'url': '', 'source': 'Wikipedia'}
        if not result:
            google_results = await search_google_scrape(query)
            if google_results:
                result = {'title': google_results[0]['title'], 'extract': google_results[0]['snippet'], 'url': '', 'source': 'Google'}
        if result:
            conn = sqlite3.connect("fable_bot.db")
            c = conn.cursor()
            c.execute("INSERT OR REPLACE INTO search_cache (key, result, timestamp) VALUES (?, ?, ?)", (cache_key, json.dumps(result, ensure_ascii=False), datetime.now().isoformat()))
            conn.commit()
            conn.close()
        return result
    except Exception as e:
        log_error(e, "smart_web_search")
        return None

