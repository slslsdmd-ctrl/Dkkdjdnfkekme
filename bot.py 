@dp.callback_query(lambda c: c.data.startswith("cyes_"))
async def cube_yes(cb: types.CallbackQuery):
    """Обработка принятия игры в кубы"""
    _, cid, cid2, oid, dice_count = cb.data.split("_")
    cid, cid2, oid = int(cid), int(cid2), int(oid)
    dice_count = int(dice_count)
    
    if cb.from_user.id != oid:
        await cb.answer("❌ Это не тебя вызывают!", show_alert=True)
        return
    
    await cb.message.delete()
    
    # Бросок первого игрока
    msg = await bot.send_message(cid, f"🎲 {await get_name(cid2)} бросает {dice_count} кости...")
    rolls1 = [random.randint(1, 6) for _ in range(dice_count)]
    total1 = sum(rolls1)
    await asyncio.sleep(1.5)
    await msg.edit_text(f"🎲 {await get_name(cid2)}: {', '.join(map(str, rolls1))} = **{total1}**")
    
    # Бросок второго игрока
    await asyncio.sleep(1.5)
    msg2 = await bot.send_message(cid, f"🎲 {await get_name(oid)} бросает {dice_count} кости...")
    await asyncio.sleep(1.5)
    rolls2 = [random.randint(1, 6) for _ in range(dice_count)]
    total2 = sum(rolls2)
    await msg2.edit_text(f"🎲 {await get_name(oid)}: {', '.join(map(str, rolls2))} = **{total2}**")
    
    # Определение победителя
    await asyncio.sleep(1)
    if total1 > total2:
        winner = cid2
        await add_coins(winner, cid, 50)
        await bot.send_message(cid, f"🏆 **{await get_name(winner)}** победил! ({total1} vs {total2}) +50 монет!")
    elif total2 > total1:
        winner = oid
        await add_coins(winner, cid, 50)
        await bot.send_message(cid, f"🏆 **{await get_name(winner)}** победил! ({total2} vs {total1}) +50 монет!")
    else:
        await bot.send_message(cid, f"🤝 Ничья! ({total1} vs {total2})")


