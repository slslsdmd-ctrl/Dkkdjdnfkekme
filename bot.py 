async def get_target_user(message: types.Message):
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    if not message.text:
        return None
    args = message.text.split()
    if len(args) > 1:
        try:
            if args[1].isdigit():
                return int(args[1])
            username = args[1].replace("@", "").strip()
            if username:
                try:
                    member = await message.chat.get_member(username)
                    return member.user.id
                except Exception:
                    try:
                        user = await bot.get_chat(username)
                        return user.id
                    except Exception:
                        pass
        except Exception:
            pass
    return None

async def get_rank(user_id: int, chat_id: int) -> str:
    coins = await get_coins(user_id, chat_id)
    for rank, req in sorted(RANKS.items(), key=lambda x: x[1], reverse=True):
        if coins >= req:
            return rank
    return "Новичок"

async def slots(user_id: int, chat_id: int, bet: int) -> str:
    if bet <= 0:
        return "❌ Ставка должна быть больше 0!"
    if await get_coins(user_id, chat_id) < bet:
        return f"❌ Не хватает монет! Нужно {bet}"
    symbols = ["🍒", "🍋", "🍊", "🍇", "💎", "🎰", "⭐", "🔥"]
    result = [random.choice(symbols) for _ in range(3)]
    await remove_coins(user_id, chat_id, bet)
    win = 0
    if result[0] == result[1] == result[2]:
        win = bet * 10
        msg = "🎉 **ДЖЕКПОТ!** 🎉"
    elif result[0] == result[1] or result[1] == result[2]:
        win = bet * 3
        msg = "💰 Хороший выигрыш!"
    elif result[0] == result[2]:
        win = bet * 2
        msg = "💵 Неплохо!"
    else:
        msg = "😔 Не повезло..."
    if win > 0:
        await add_coins(user_id, chat_id, win)
        msg += f"\n[{result[0]}][{result[1]}][{result[2]}]\n+{win} монет!"
    else:
        msg += f"\n[{result[0]}][{result[1]}][{result[2]}]\n-{bet} монет"
    return msg

async def fishing(user_id: int, chat_id: int) -> str:
    if not await can_do(user_id, chat_id, "last_fish", 60):
        return "⏳ Рыба ушла! Подожди 1 минуту."
    fishes = {"окунь": {"rarity": "обычная", "weight": 0.5, "coins": 5}, "карп": {"rarity": "обычная", "weight": 1.0, "coins": 10}, "щука": {"rarity": "редкая", "weight": 2.0, "coins": 25}, "сом": {"rarity": "редкая", "weight": 5.0, "coins": 50}, "осётр": {"rarity": "эпическая", "weight": 10.0, "coins": 100}, "золотая рыбка": {"rarity": "легендарная", "weight": 0.1, "coins": 500}}
    fish = random.choices(list(fishes.keys()), weights=[fish["weight"] for fish in fishes.values()])[0]
    data = fishes[fish]
    await add_coins(user_id, chat_id, data["coins"])
    await set_cooldown(user_id, chat_id, "last_fish")
    return f"🎣 Ты поймал **{fish}** ({data['rarity']})!\n+{data['coins']} монет!"

async def shoot(user_id: int, chat_id: int) -> str:
    if not await can_do(user_id, chat_id, "last_shoot", 30):
        return "⏳ Отдохни 30 секунд!"
    target = random.randint(1, 10)
    shot = random.randint(1, 10)
    diff = abs(target - shot)
    await set_cooldown(user_id, chat_id, "last_shoot")
    if diff == 0:
        win = 50
        await add_coins(user_id, chat_id, win)
        return f"🎯 **ЯБЛОЧКО!**\nЦель: {target}, Вы: {shot}\n+{win} монет! 🎉"
    elif diff <= 2:
        win = 20
        await add_coins(user_id, chat_id, win)
        return f"🎯 Хороший выстрел!\nЦель: {target}, Вы: {shot}\n+{win} монет!"
    elif diff <= 4:
        return f"🎯 Почти попал!\nЦель: {target}, Вы: {shot}"
    else:
        return f"🎯 Мимо!\nЦель: {target}, Вы: {shot}"

async def buy_house(user_id: int, chat_id: int, house_type: str) -> str:
    if house_type not in HOUSES:
        return "❌ Нет такого дома!"
    data = HOUSES[house_type]
    if await get_coins(user_id, chat_id) < data["price"]:
        return f"❌ Нужно {data['price']} монет!"
    await remove_coins(user_id, chat_id, data["price"])
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("INSERT OR REPLACE INTO houses (user_id, chat_id, house_type) VALUES (?,?,?)", (user_id, chat_id, house_type))
    conn.commit()
    conn.close()
    return f"✅ Куплен {house_type}! {data['emoji']} Доход: {data['income']} монет/час"

async def leaderboard(chat_id: int) -> str:
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT user_id, coins FROM users WHERE chat_id = ? ORDER BY coins DESC LIMIT 5", (chat_id,))
    top_coins = c.fetchall()
    c.execute("SELECT user_id, wins FROM pvp_stats WHERE chat_id = ? ORDER BY wins DESC LIMIT 5", (chat_id,))
    top_pvp = c.fetchall()
    conn.close()
    txt = "🏆 **Турнирная таблица**\n\n💰 **Топ богачей:**\n"
    for i, (uid, coins) in enumerate(top_coins, 1):
        txt += f"{i}. {await get_name(uid)} — {coins} монет\n"
    txt += "\n⚔️ **Топ воинов:**\n"
    for i, (uid, wins) in enumerate(top_pvp, 1):
        txt += f"{i}. {await get_name(uid)} — {wins} побед\n"
    return txt

