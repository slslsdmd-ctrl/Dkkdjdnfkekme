        if new_qty <= 0: c.execute("DELETE FROM inventory WHERE user_id = ? AND chat_id = ? AND item_name = ?", (user_id, chat_id, item_name))
        else: c.execute("UPDATE inventory SET quantity = ? WHERE user_id = ? AND chat_id = ? AND item_name = ?", (new_qty, user_id, chat_id, item_name))
        conn.commit(); conn.close()
        return True
    conn.close()
    return False

