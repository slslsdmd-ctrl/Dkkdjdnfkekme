    c.execute("SELECT coins FROM messages WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    row = c.fetchone()
    if row:
        new_amount = max(0, row[0] - amount)
        c.execute("UPDATE messages SET coins = ? WHERE user_id = ? AND chat_id = ?", (new_amount, user_id, chat_id))
