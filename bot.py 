async def get_target_user(message: types.Message) -> Optional[int]:
    """ПОЛУЧЕНИЕ ЦЕЛЕВОГО ПОЛЬЗОВАТЕЛЯ ИЗ СООБЩЕНИЯ"""
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    
    if not message.text:
        return None
    
    args = message.text.split()
    if len(args) > 1:
        try:
            if args[1].isdigit():
                return int(args[1])
            username = args[1].replace("@", "").strip()
            if username:
                try:
                    member = await message.chat.get_member(username)
                    return member.user.id
                except:
                    pass
        except:
            pass
    
    return None

async def get_args(message: types.Message) -> List[str]:
    """ПОЛУЧЕНИЕ АРГУМЕНТОВ КОМАНДЫ"""
    if not message.text:
        return []
    return message.text.split()[1:]

