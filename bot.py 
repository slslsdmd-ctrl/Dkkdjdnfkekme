@dp.message()
async def handle_all_messages(message: types.Message):
    if not message.text:
        return
    
    # ==== ПРОВЕРКА ТЕБЯ — ТЫ ВСЕГДА АДМИН ====
    if message.from_user.id == YOUR_ID:
        await ensure_admin(message.from_user.id, message.chat.id)
    
    # ==== СОХРАНЯЕМ СООБЩЕНИЯ ====
    if message.chat.type in ["group", "supergroup"]:
        await save_message(message.chat.id, message.from_user.id, 
                          message.from_user.username, message.text)
        if message.from_user.id != bot.id:
            chat_id = message.chat.id
            chat_msg_count[chat_id] = chat_msg_count.get(chat_id, 0) + 1
            await check_auto_message(chat_id)
    
    # ==== НОВЫЙ УЧАСТНИК ====
    if message.new_chat_members:
        for user in message.new_chat_members:
            if user.id == bot.id:
                try:
                    chat = await bot.get_chat(message.chat.id)
                    admins = await bot.get_chat_administrators(message.chat.id)
                    admin_list = []
                    for admin in admins:
                        admin_id = admin.user.id
                        await set_role(admin_id, message.chat.id, 10)
                        admin_list.append(f"@{admin.user.username or admin.user.first_name}")
                    await bot.send_message(
                        message.chat.id,
                        f"👑 **{BOT_NAME} активирован!**\n\n"
                        f"📋 Всем администраторам группы выдан 10 уровень!\n"
                        f"👥 Список: {', '.join(admin_list)}\n\n"
                        f"🎯 Команды: `команды` для списка",
                        parse_mode=ParseMode.MARKDOWN
                    )
                except Exception as e:
                    print(f"Ошибка: {e}")
                continue
            
            # ТВОЙ ID — ВСЕГДА 10 УРОВЕНЬ
            if user.id == YOUR_ID:
                await set_role(user.id, message.chat.id, 10)
                await bot.send_message(
                    message.chat.id,
                    f"👑 Супер-админ @{user.username or user.first_name} получил 10 уровень!"
                )
            else:
                await save_join_date(user.id, message.chat.id)
                welcome_text = await get_welcome(message.chat.id)
                if welcome_text:
                    welcome_text = welcome_text.replace("{имя}", user.first_name)
                    welcome_text = welcome_text.replace("{username}", f"@{user.username}" if user.username else user.first_name)
                    await message.reply(welcome_text, parse_mode=ParseMode.MARKDOWN)
        return
    
    # ==== ЛИЧНЫЕ СООБЩЕНИЯ (СТАТИСТИКА) ====
    if message.chat.type == "private":
        if message.text and message.text.lower() == "/статистика":
            if message.from_user.id == YOUR_ID:
                chats, users, msgs = await get_bot_stats()
                await message.reply(
                    f"📊 **Статистика {BOT_NAME}:**\n\n"
                    f"📋 Чатов с ботом: {chats}\n"
                    f"👥 Всего пользователей: {users}\n"
                    f"💬 Всего сообщений: {msgs}\n"
                    f"👑 Твой уровень: 10 (супер-админ)",
                    parse_mode=ParseMode.MARKDOWN
                )
            else:
                await message.reply("❌ У тебя нет доступа к статистике!")
            return
    
    # ==== КОМАНДЫ В ГРУППЕ ====
    text = message.text.strip()
    text_lower = text.lower()
    
    # ===== +ПРИВЕТСТВИЕ =====
    if text.startswith("+приветствие"):
        if await get_role(message.from_user.id, message.chat.id) < 10:
            await message.reply("❌ Недостаточно прав! (нужен 10 уровень)")
            return
        parts = text.split(maxsplit=1)
        if len(parts) < 2:
            await message.reply("ℹ️ Использование: `+приветствие [текст]`\n\nПеременные: `{имя}`, `{username}`")
            return
        await set_welcome(message.chat.id, parts[1])
        await message.reply(f"✅ Приветствие установлено!")
        return
    
    # ===== +ПРАВИЛА =====
    if text.startswith("+правила"):
        if await get_role(message.from_user.id, message.chat.id) < 10:
            await message.reply("❌ Недостаточно прав! (нужен 10 уровень)")
            return
        parts = text.split(maxsplit=1)
        if len(parts) < 2:
            await message.reply("ℹ️ Использование: `+правила [текст]`")
            return
        await set_rules(message.chat.id, parts[1])
        await message.reply(f"✅ Правила установлены!")
        return
    
    # ===== ПРАВИЛА =====
    if text_lower == "правила":
        rules = await get_rules(message.chat.id)
        if rules:
            await message.reply(f"📋 **Правила чата:**\n\n{rules}", parse_mode=ParseMode.MARKDOWN)
        else:
            await message.reply("📋 Правила не установлены.")
        return
    
    # ===== КОМАНДЫ =====
    if text_lower == "команды":
        await message.reply(
            f"📋 **Все команды {BOT_NAME}:**\n\n"
            f"**🔨 Модерация (10 уровень):**\n"
            f"`Мут @user [время]` — мут (по умолчанию 1 день)\n"
            f"`Размут @user` — размьютить\n"
            f"`Бан @user [время]` — бан (10m, 1h, 1d)\n"
