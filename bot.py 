    async def create_clan(self, chat_id: int, user_id: int, name: str) -> dict:
        """СОЗДАНИЕ КЛАНА"""
        # Проверяем, есть ли уже клан с таким именем
        existing = await db.query(
            "SELECT id FROM clans WHERE chat_id = ? AND name = ?",
            (chat_id, name),
            fetch_one=True
        )
        if existing:
            return {'error': 'Клан с таким названием уже существует!'}
        
        # Проверяем, не в клане ли уже
        in_clan = await db.query(
            "SELECT id FROM clans WHERE chat_id = ? AND members LIKE ?",
            (chat_id, f'%{user_id}%'),
            fetch_one=True
        )
        if in_clan:
            return {'error': 'Ты уже в клане!'}
        
        # Проверяем деньги (500 монет)
        coins = await db.get_coins(user_id)
        if coins < 500:
            return {'error': 'Недостаточно монет! Нужно 500 для создания клана!'}
        
        await db.add_coins(user_id, -500)
        
        # Создаём клан
        await db.query(
            "INSERT INTO clans (chat_id, name, owner_id, members, treasury) VALUES (?, ?, ?, ?, ?)",
            (chat_id, name, user_id, str(user_id), 0)
        )
        
        # Очищаем кэш
        self.get_clan.cache_clear()
        
        # Достижение
        await unlock_achievement(user_id, "create_clan")
        
        return {
            'success': True,
            'name': name,
            'owner': user_id,
            'members': 1
        }
    
