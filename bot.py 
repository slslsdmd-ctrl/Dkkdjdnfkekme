async def update_currency_rates():
    """Обновляет курсы валют раз в час"""
    while True:
        try:
            await asyncio.sleep(3600)
            for currency in CURRENCY_RATES:
                change = random.uniform(-0.05, 0.05)
                CURRENCY_RATES[currency] = max(1, CURRENCY_RATES[currency] * (1 + change))
            
            conn = sqlite3.connect("fable_bot.db")
            c = conn.cursor()
            now = datetime.now().isoformat()
            for currency, rate in CURRENCY_RATES.items():
                c.execute("INSERT OR REPLACE INTO currency_rates (currency, rate, last_update) VALUES (?,?,?)", (currency, rate, now))
            conn.commit()
            conn.close()
        except Exception as e:
            log_error(e, "update_currency_rates")
            await asyncio.sleep(60)

async def get_currency_rates() -> str:
    """Возвращает строку с текущими курсами валют"""
    txt = "💱 **КУРСЫ ВАЛЮТ**\n\n"
