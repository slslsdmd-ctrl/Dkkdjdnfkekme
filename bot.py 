    txt = f"📊 **Статистика**\n\n⭐ Уровень: {level}\n💰 Монет: {coins}\n💬 Сообщений: {msg_count}\n🏆 Достижений: {len(achievements)}\n💼 Работ: {work[0] if work else 0}\n⚔️ PVP побед: {pvp[0] if pvp else 0}\n"
    return txt

