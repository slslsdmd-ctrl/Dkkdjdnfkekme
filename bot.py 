async def get_target_user(message: types.Message):
    """Получает ID целевого пользователя из реплая или упоминания"""
    if message.reply_to_message:
        return message.reply_to_message.from_user.id
    
    args = message.text.split()
    if len(args) > 1:
        try:
            member = await message.chat.get_member(args[1].replace("@", ""))
            return member.user.id
        except:
            return None
    
    return None


async def add_award(user_id: int, chat_id: int, award_name: str):
    """Добавляет награду пользователю"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    now = datetime.now().isoformat()
    c.execute(
        "INSERT INTO awards (user_id, chat_id, award_name, date) VALUES (?,?,?,?)",
        (user_id, chat_id, award_name, now)
    )
    conn.commit()
    conn.close()


