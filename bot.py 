    c.execute("INSERT OR REPLACE INTO promocodes (code, creator_id, chat_id, reward_coins, reward_item, max_uses, expires, created) VALUES (?,?,?,?,?,?,?,?)",
              (code.upper(), creator_id, 0, reward_coins, reward_item, max_uses, expires, datetime.now().isoformat()))
    conn.commit()
    conn.close()

async def use_promocode(code: str, user_id: int, chat_id: int) -> str:
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT * FROM promocodes WHERE code = ? AND (chat_id = ? OR chat_id = 0)", (code.upper(), chat_id))
    promo = c.fetchone()
    if not promo:
        conn.close()
        return "❌ Промокод не найден!"
    _, creator_id, _, reward_coins, reward_item, max_uses, used_count, expires, _ = promo
    if datetime.now() > datetime.fromisoformat(expires):
        conn.close()
        return "❌ Промокод истёк!"
    if used_count >= max_uses:
        conn.close()
        return "❌ Промокод больше не действует!"
    c.execute("SELECT id FROM promo_uses WHERE code = ? AND user_id = ? AND chat_id = ?", (code.upper(), user_id, chat_id))
    if c.fetchone():
        conn.close()
        return "❌ Ты уже использовал этот промокод!"
    if reward_coins > 0:
        await add_coins(user_id, chat_id, reward_coins)
    if reward_item:
        await add_item(user_id, chat_id, reward_item)
    c.execute("INSERT INTO promo_uses (code, user_id, chat_id, used_at) VALUES (?,?,?,?)", (code.upper(), user_id, chat_id, datetime.now().isoformat()))
    c.execute("UPDATE promocodes SET used_count = used_count + 1 WHERE code = ?", (code.upper(),))
    conn.commit()
    conn.close()
    result = "🎉 Промокод активирован!"
    if reward_coins > 0:
        result += f"\n💰 +{reward_coins} монет"
    if reward_item:
        item_name = RARE_ITEMS.get(reward_item, {}).get("name", reward_item)
        result += f"\n🎁 +{item_name}"
    return result

