    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        now = datetime.now().isoformat()
        c.execute("INSERT INTO warns (user_id, chat_id, warned_by, reason, date) VALUES (?,?,?,?,?)", (user_id, chat_id, warned_by, reason, now))
