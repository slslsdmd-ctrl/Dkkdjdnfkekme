async def check_achievements_2(user_id: int, chat_id: int):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    c.execute("SELECT ach_name FROM achievements_2 WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
    existing = [row[0] for row in c.fetchall()]
    coins = await get_coins(user_id, chat_id)
    msg_count = await get_msg_count(user_id, chat_id)
    for key, data in ACHIEVEMENTS_2.items():
        if key in existing:
            continue
        completed = False
        if key == "millionaire" and coins >= 1000000:
            completed = True
        elif key == "billionaire" and coins >= 1000000000:
            completed = True
        elif key == "chat_legend" and msg_count >= 100000:
            completed = True
        if completed:
            c.execute("INSERT INTO achievements_2 (user_id, chat_id, ach_name, unlocked) VALUES (?,?,?,?)", (user_id, chat_id, key, datetime.now().isoformat()))
            await add_coins(user_id, chat_id, data["reward"])
            conn.commit()
            conn.close()
            return f"🏆 **{data['name']}**!\n{data['desc']}\n💰 +{data['reward']} монет"
    conn.close()
    return None

