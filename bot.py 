async def get_chart_data(cid, days=7):
    """Получает данные для графиков"""
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    data = []
    for i in range(days):
        date = (datetime.now() - timedelta(days=i)).strftime("%Y-%m-%d")
