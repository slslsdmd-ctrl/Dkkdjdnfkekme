    async def upgrade_business(self, user_id: int, business_name: str) -> dict:
        """УЛУЧШЕНИЕ БИЗНЕСА"""
        business = await db.query(
            "SELECT * FROM businesses WHERE user_id = ? AND name = ?",
            (user_id, business_name),
            fetch_one=True
        )
        
        if not business:
            return {'error': 'Бизнес не найден!'}
        
        data = BUSINESSES[business_name]
        
        if business['level'] >= data['max_level']:
            return {'error': f'Бизнес на максимальном уровне ({data["max_level"]})!'}
        
        cost = data['upgrade_price'] * business['level']
        new_income = business['income'] + data['upgrade_income']
        
        # Проверяем деньги
        coins = await db.get_coins(user_id)
        if coins < cost:
            return {'error': f'Недостаточно монет! Нужно {cost}'}
        
        # Проверяем землю (нужно больше земли для высоких уровней)
        land = await self.get_land(user_id)
        required_land = data['land_size'] * (business['level'] + 1)
        if land and land['size'] < required_land:
            return {'error': f'Нужно больше земли! Необходимо {required_land} соток'}
        
        # Снимаем деньги
        await db.add_coins(user_id, -cost)
        
        # Обновляем бизнес
        await db.query(
            "UPDATE businesses SET level = level + 1, income = ? WHERE id = ?",
            (new_income, business['id'])
        )
        
        return {
            'success': True,
            'business': business_name,
            'new_level': business['level'] + 1,
            'new_income': new_income,
            'cost': cost
        }
    
    async def collect_income(self, user_id: int, business_id: int) -> dict:
        """СБОР ДОХОДА С БИЗНЕСА"""
        business = await db.query(
            "SELECT * FROM businesses WHERE id = ? AND user_id = ?",
            (business_id, user_id),
            fetch_one=True
        )
        
        if not business:
            return {'error': 'Бизнес не найден!'}
        
        last_collect = business['last_collect']
        if last_collect:
            last_time = datetime.fromisoformat(last_collect)
            elapsed = (datetime.now() - last_time).total_seconds() / 3600
        else:
            elapsed = 0
        
        if elapsed < 1:
            return {'error': f'⏳ Доход будет через {1 - elapsed:.1f} часов!'}
        
        # Расчёт дохода
        income = business['income']
        
        # Применяем кризис
        chat_id = await db.query(
            "SELECT chat_id FROM users WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        if chat_id:
            multiplier = crisis_system.get_multiplier(chat_id['chat_id'])
            income = int(income * multiplier)
        
        # Бонусы маркетинга
        marketing_level = business.get('marketing_level', 0)
        if marketing_level > 0:
            income = int(income * (1 + marketing_level * 0.1))
        
        # Бонусы бренда
        brand_level = business.get('brand_level', 0)
        if brand_level > 0:
            income = int(income * (1 + brand_level * 0.05))
        
        total_income = int(income * elapsed)
        
        # Начисляем
        await db.add_coins(user_id, total_income)
        
        # Обновляем время сбора
        await db.query(
            "UPDATE businesses SET last_collect = ? WHERE id = ?",
            (datetime.now().isoformat(), business_id)
        )
        
        return {
            'success': True,
            'business': business['name'],
            'income': total_income,
            'hours': elapsed,
            'hourly_income': income
        }
    
