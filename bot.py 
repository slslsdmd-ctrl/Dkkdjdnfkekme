class QuizGame:
    """СИСТЕМА ВИКТОРИН"""
    
    def __init__(self):
        self.games = {}
        self.scores = {}
    
    async def start_quiz(self, user_id: int, category: str) -> dict:
        """НАЧАЛО ВИКТОРИНЫ"""
        if category not in QUIZZES:
            return {'error': 'Категория не найдена! Доступно: история, география, наука, спорт, кино, игры'}
        
        quiz = QUIZZES[category]
        questions = quiz['questions'].copy()
        random.shuffle(questions)
        
        self.games[user_id] = {
            'category': category,
            'questions': questions[:5],
            'current': 0,
            'score': 0,
            'total': len(questions[:5])
        }
        
        return {
            'success': True,
            'category': category,
            'total': self.games[user_id]['total'],
            'question': self.games[user_id]['questions'][0]['q']
        }
    
    async def answer(self, user_id: int, answer: str) -> dict:
        """ОТВЕТ НА ВОПРОС"""
        if user_id not in self.games:
            return {'error': 'Нет активной викторины!'}
        
        game = self.games[user_id]
        current = game['current']
        question = game['questions'][current]
        
        is_correct = answer.lower().strip() == question['a'].lower().strip()
        
        if is_correct:
            game['score'] += 1
        
        game['current'] += 1
        
        if game['current'] >= game['total']:
            # Викторина окончена
            reward = game['score'] * 50
            await db.add_coins(user_id, reward)
            del self.games[user_id]
            
            return {
                'success': True,
                'finished': True,
                'score': game['score'],
                'total': game['total'],
                'reward': reward,
                'correct_answer': question['a']
            }
        
        next_question = game['questions'][game['current']]
        
        return {
            'success': True,
            'finished': False,
            'is_correct': is_correct,
            'score': game['score'],
            'total': game['total'],
            'question': next_question['q'],
            'correct_answer': question['a'] if not is_correct else None
        }

