    conn = sqlite3.connect("fable_bot.db"); c = conn.cursor()
    c.execute("SELECT challenger, opponent, aim_bonus FROM duels WHERE chat_id = ?", (cid,))
    row = c.fetchone(); conn.close()
    if not row: await cb.answer("❌ Завершена!"); return
    ch, op, aim = row
    if random.randint(1, 100) <= 10 + aim * 10:
        winner = turn; loser = ch if winner == op else op
        conn = sqlite3.connect("fable_bot.db"); c = conn.cursor()
        c.execute("DELETE FROM duels WHERE chat_id = ?", (cid,)); conn.commit(); conn.close()
        active_duels.discard((cid, ch, op))
        await bot.send_message(cid, f"💥 ПОПАЛ! 🏆 {await get_name(winner)}!")
    else:
        new_turn = ch if turn == op else op
        conn = sqlite3.connect("fable_bot.db"); c = conn.cursor()
        c.execute("UPDATE duels SET turn = ?, aim_bonus = 0 WHERE chat_id = ?", (new_turn, cid)); conn.commit(); conn.close()
        await bot.send_message(cid, f"💨 Мимо! {await get_name(new_turn)}")
        await send_duel_turn(cid, ch, op, 0, new_turn)

