@dp.message()
async def handle_all_messages(message: types.Message):
    """Главный обработчик всех сообщений"""
    if not message.text:
        return
    
    text = message.text.strip()
    text_lower = text.lower()
    uid = message.from_user.id
    chat_id = message.chat.id
    
    # Админские команды в ЛС
    if chat_id == uid and uid == YOUR_ID:
        if text_lower.startswith("+промокод"):
            args = text.split()
            if len(args) >= 4:
                code = args[1].upper()
                item = args[2].lower()
                try:
                    uses = int(args[3])
                except:
                    uses = 1
                coins = int(args[4]) if len(args) >= 5 and args[4].isdigit() else 0
                await create_promocode(code, uid, coins, item, uses)
                item_name = RARE_ITEMS.get(item, {}).get("name", item)
                await message.reply(f"✅ Промокод **{code}** создан!\n🎁 {item_name}\n👥 {uses} исп.\n💰 {coins} монет")
            else:
                await message.reply("ℹ️ +промокод КОД предмет кол-во [монеты]\nПример: +промокод GOVNO золотая_удочка 100 500")
            return
        
        if text_lower.startswith("+монеты"):
            args = text.split()
            if len(args) >= 3:
                try:
                    target = int(args[1])
                    amount = int(args[2])
                    await add_coins(target, target, amount)
                    await message.reply(f"✅ +{amount} монет для {await get_name(target)}")
                except:
                    await message.reply("❌ Формат: +монеты id сумма")
            return
        
        if text_lower.startswith("+дать"):
            args = text.split()
            if len(args) >= 3:
                try:
                    target = int(args[1])
