async def is_spam(user_id: int, chat_id: int) -> bool:
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        c.execute("SELECT message_count, last_message FROM spam_log WHERE user_id = ? AND chat_id = ?", (user_id, chat_id))
        row = c.fetchone()
        now = datetime.now()
        if row:
            count, last_time = row
            last = datetime.fromisoformat(last_time)
            if (now - last).total_seconds() < 3:
                count += 1
                if count >= 5:
                    conn.close()
                    return True
                c.execute("UPDATE spam_log SET message_count = ?, last_message = ? WHERE user_id = ? AND chat_id = ?", (count, now.isoformat(), user_id, chat_id))
            else:
                c.execute("UPDATE spam_log SET message_count = 1, last_message = ? WHERE user_id = ? AND chat_id = ?", (now.isoformat(), user_id, chat_id))
        else:
            c.execute("INSERT INTO spam_log (user_id, chat_id, message_count, last_message) VALUES (?,?,1,?)", (user_id, chat_id, now.isoformat()))
        conn.commit()
        conn.close()
        return False
    except Exception as e:
        log_error(e, "is_spam")
        return False

