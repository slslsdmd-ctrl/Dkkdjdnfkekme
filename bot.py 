async def add_bank_interest():
    """Начисляет 10% на все вклады каждый час"""
    while True:
        await asyncio.sleep(3600)
        try:
            conn = sqlite3.connect("fable_bot.db")
            c = conn.cursor()
            c.execute("SELECT user_id, chat_id, balance FROM bank WHERE balance > 0")
            for uid, cid, bal in c.fetchall():
                interest = int(bal * 0.1)
                if interest > 0:
                    c.execute(
                        "UPDATE bank SET balance = balance + ? WHERE user_id = ? AND chat_id = ?",
                        (interest, uid, cid)
                    )
            conn.commit()
            conn.close()
        except Exception as e:
            print(f"Ошибка начисления процентов: {e}")


