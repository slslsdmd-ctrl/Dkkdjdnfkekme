class PlayerTrade:
    """СИСТЕМА ТОРГОВЛИ МЕЖДУ ИГРОКАМИ"""
    
    def __init__(self):
        self.offers = {}
        self.offer_id = 0
    
    async def create_offer(self, user_id: int, item_name: str, quantity: int, price: int) -> dict:
        """СОЗДАТЬ ПРЕДЛОЖЕНИЕ О ПРОДАЖЕ"""
        if quantity <= 0:
            return {'error': 'Количество должно быть больше 0!'}
        
        if price <= 0:
            return {'error': 'Цена должна быть больше 0!'}
        
        # Проверяем наличие предмета
        has = await has_item(user_id, item_name)
        if has < quantity:
            return {'error': f'У тебя нет {quantity} {item_name}!'}
        
        self.offer_id += 1
        offer_id = self.offer_id
        
        self.offers[offer_id] = {
            'user_id': user_id,
            'item_name': item_name,
            'quantity': quantity,
            'price': price,
            'created': datetime.now().isoformat(),
            'status': 'active'
        }
        
        return {
            'success': True,
            'offer_id': offer_id,
            'item': item_name,
            'quantity': quantity,
            'price': price
        }
    
    async def buy_offer(self, user_id: int, offer_id: int) -> dict:
        """КУПИТЬ ПО ПРЕДЛОЖЕНИЮ"""
        if offer_id not in self.offers:
            return {'error': 'Предложение не найдено!'}
        
        offer = self.offers[offer_id]
        if offer['status'] != 'active':
            return {'error': 'Предложение уже неактивно!'}
        
        if offer['user_id'] == user_id:
            return {'error': 'Нельзя купить у себя!'}
        
        total_price = offer['price'] * offer['quantity']
        
        coins = await get_coins(user_id)
        if coins < total_price:
            return {'error': f'Недостаточно монет! Нужно {total_price}'}
        
        # Снимаем монеты у покупателя
        await remove_coins(user_id, total_price)
        
        # Добавляем монеты продавцу
        await add_coins(offer['user_id'], total_price)
        
        # Передаём предмет
        await remove_item(offer['user_id'], offer['item_name'], offer['quantity'])
        await add_item(user_id, offer['item_name'], offer['quantity'])
        
        offer['status'] = 'completed'
        
        return {
            'success': True,
            'item': offer['item_name'],
            'quantity': offer['quantity'],
            'price': total_price
        }
    
    async def cancel_offer(self, user_id: int, offer_id: int) -> dict:
