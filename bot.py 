async def get_crypto_price(crypto: str) -> float:
    """ПОЛУЧЕНИЕ ЦЕНЫ КРИПТОВАЛЮТЫ"""
    if crypto not in CRYPTO:
        return None
    
    base_price = CRYPTO[crypto]['base_price']
    volatility = CRYPTO[crypto]['volatility']
    
    # Случайное изменение
    change = random.uniform(-volatility, volatility)
    price = base_price * (1 + change)
    
    # Добавляем тренд
    trend = random.uniform(-0.001, 0.001)
    price *= (1 + trend)
    
    return max(0.0001, price)

async def mine_crypto(user_id: int, crypto: str = "FBC") -> dict:
    """ДОБЫЧА КРИПТОВАЛЮТЫ"""
    if crypto not in CRYPTO:
        return {'error': 'Неизвестная криптовалюта!'}
    
    # Проверяем кулдаун
    last_mine = await db.query(
        "SELECT last_mine FROM users WHERE user_id = ?",
        (user_id,),
        fetch_one=True
    )
    
    if last_mine and last_mine['last_mine']:
        last_time = datetime.fromisoformat(last_mine['last_mine'])
        if (datetime.now() - last_time).seconds < 60:
            return {'error': 'Подожди 1 минуту перед следующим майнингом!'}
    
    # Рассчитываем добычу
    rate = CRYPTO[crypto]['mining_rate']
    amount = rate * random.uniform(0.8, 1.2)
    
    # Бонусы от предметов
    has_asic = await db.query(
        "SELECT quantity FROM inventory WHERE user_id = ? AND item_name = 'asic_майнер'",
        (user_id,),
        fetch_one=True
    )
    if has_asic:
        amount *= 2
    
    # Сохраняем
    await db.query(
        f"INSERT OR REPLACE INTO crypto (user_id, {crypto.lower()}) VALUES (?, COALESCE((SELECT {crypto.lower()} FROM crypto WHERE user_id = ?), 0) + ?)",
        (user_id, user_id, amount)
    )
    
    # Обновляем кулдаун
    await db.query(
        "UPDATE users SET last_mine = ? WHERE user_id = ?",
        (datetime.now().isoformat(), user_id)
    )
    
    # Конвертируем в монеты
    price = await get_crypto_price(crypto)
    coins_value = int(amount * price * CRYPTO_TO_COINS)
    
    return {
        'success': True,
        'crypto': crypto,
        'amount': amount,
        'coins_value': coins_value,
        'price': price
    }

async def convert_crypto(user_id: int, crypto: str, amount: float) -> dict:
    """КОНВЕРТАЦИЯ КРИПТЫ В МОНЕТЫ"""
    if crypto not in CRYPTO:
        return {'error': 'Неизвестная криптовалюта!'}
    
    # Проверяем баланс
    balance = await db.query(
        f"SELECT {crypto.lower()} FROM crypto WHERE user_id = ?",
        (user_id,),
        fetch_one=True
    )
    
    current = balance[crypto.lower()] if balance else 0
    if current < amount:
        return {'error': f'Недостаточно {crypto}! Есть {current}'}
    
    # Получаем цену
    price = await get_crypto_price(crypto)
    coins = int(amount * price * CRYPTO_TO_COINS)
    
    if coins <= 0:
        return {'error': 'Слишком маленькая сумма'}
    
    # Снимаем крипту
    await db.query(
        f"UPDATE crypto SET {crypto.lower()} = {crypto.lower()} - ? WHERE user_id = ?",
        (amount, user_id)
    )
    
    # Добавляем монеты
    await db.add_coins(user_id, coins)
    
    return {
        'success': True,
        'crypto': crypto,
        'amount': amount,
        'coins': coins,
        'rate': price
    }

