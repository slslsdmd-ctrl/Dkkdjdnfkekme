class WheelOfFortune:
    """КОЛЕСО ФОРТУНЫ С ПРИЗАМИ"""
    
    def __init__(self):
        self.segments = [
            {'name': '💰 100', 'value': 100},
            {'name': '💰 200', 'value': 200},
            {'name': '💰 500', 'value': 500},
            {'name': '💰 1000', 'value': 1000},
            {'name': '🎁 Бонус', 'value': 'bonus'},
            {'name': '💎 Джекпот', 'value': 'jackpot'},
            {'name': '🍀 Удача', 'value': 'luck'},
            {'name': '😭 Пусто', 'value': 0},
            {'name': '💰 50', 'value': 50},
            {'name': '💰 300', 'value': 300}
        ]
        self.jackpot = 10000
    
    async def spin(self, user_id: int) -> dict:
        """ВРАЩЕНИЕ КОЛЕСА (БЕСПЛАТНО, 1 раз в час)"""
        # Проверяем кулдаун
        last_spin = await db.query(
            "SELECT last_wheel FROM users WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if last_spin and last_spin['last_wheel']:
            last_time = datetime.fromisoformat(last_spin['last_wheel'])
            if (datetime.now() - last_time).seconds < 3600:
                return {'error': '⏳ Колесо доступно раз в час!'}
        
        segment = random.choice(self.segments)
        prize = segment['value']
        
        if prize == 'bonus':
            # Бонус - случайный предмет
            items = ['энергетик', 'золотая_удочка', 'сеть', 'фонарь', 'золотые_семена']
            item = random.choice(items)
            await db.add_item(user_id, item)
            result_text = f'🎁 Бонус: {item}!'
        elif prize == 'jackpot':
            # Джекпот
            amount = self.jackpot
            self.jackpot = 10000
            await db.add_coins(user_id, amount)
            result_text = f'💎 ДЖЕКПОТ! {amount} монет!'
        elif prize == 'luck':
            # Удача - случайный множитель
            multiplier = random.randint(2, 5)
            result_text = f'🍀 Удача x{multiplier}!'
        elif prize > 0:
            await db.add_coins(user_id, prize)
            result_text = f'💰 +{prize} монет!'
        else:
            result_text = '😭 Ничего не выпало...'
        
        # Обновляем кулдаун
        await db.query(
            "UPDATE users SET last_wheel = ? WHERE user_id = ?",
            (datetime.now().isoformat(), user_id)
        )
        
        return {
            'success': True,
            'segment': segment['name'],
            'prize': prize,
            'result': result_text,
            'jackpot': self.jackpot
        }

