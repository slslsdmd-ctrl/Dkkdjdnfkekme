async def get_message_stats(chat_id, period="day"):
    conn = sqlite3.connect("fable_bot.db")
    c = conn.cursor()
    now = datetime.now()
    if period == "day":
        date = now.strftime("%Y-%m-%d")
        c.execute("SELECT user_id, count FROM message_stats WHERE chat_id = ? AND date = ? ORDER BY count DESC LIMIT 5", (chat_id, date))
    elif period == "week":
        week_ago = (now - timedelta(days=7)).strftime("%Y-%m-%d")
        c.execute("SELECT user_id, SUM(count) as total FROM message_stats WHERE chat_id = ? AND date >= ? GROUP BY user_id ORDER BY total DESC LIMIT 5", (chat_id, week_ago))
    elif period == "month":
        month_ago = (now - timedelta(days=30)).strftime("%Y-%m-%d")
        c.execute("SELECT user_id, SUM(count) as total FROM message_stats WHERE chat_id = ? AND date >= ? GROUP BY user_id ORDER BY total DESC LIMIT 5", (chat_id, month_ago))
    elif period == "year":
        year_ago = (now - timedelta(days=365)).strftime("%Y-%m-%d")
        c.execute("SELECT user_id, SUM(count) as total FROM message_stats WHERE chat_id = ? AND date >= ? GROUP BY user_id ORDER BY total DESC LIMIT 5", (chat_id, year_ago))
    else:
