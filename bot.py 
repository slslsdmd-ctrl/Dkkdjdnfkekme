def get_cached_answer(question: str) -> str:
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        q_hash = hashlib.md5(question.lower().encode()).hexdigest()
        c.execute("SELECT answer, timestamp FROM ai_cache WHERE question_hash = ?", (q_hash,))
        row = c.fetchone()
        conn.close()
        if row:
            answer, timestamp = row
            cache_time = datetime.fromisoformat(timestamp)
            if (datetime.now() - cache_time).total_seconds() < 86400:
                return answer
        return None
    except Exception as e:
        log_error(e, "get_cached_answer")
        return None

def save_cached_answer(question: str, answer: str):
    try:
        conn = sqlite3.connect("fable_bot.db")
        c = conn.cursor()
        q_hash = hashlib.md5(question.lower().encode()).hexdigest()
        now = datetime.now().isoformat()
        c.execute("INSERT OR REPLACE INTO ai_cache (question_hash, question, answer, timestamp) VALUES (?, ?, ?, ?)", (q_hash, question, answer, now))
        conn.commit()
        conn.close()
    except Exception as e:
        log_error(e, "save_cached_answer")

