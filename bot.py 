async def transfer_coins(sender_id: int, receiver_id: int, amount: int) -> str:
    """Передает монеты от одного пользователя другому"""
    if amount <= 0:
        return "❌ Сумма должна быть больше 0!"
    
    if sender_id == receiver_id:
        return "❌ Нельзя передать самому себе!"
    
    if await get_coins(sender_id) < amount:
        return f"❌ У тебя нет {amount} монет!"
    
    receiver_coins = await get_coins(receiver_id)
    if receiver_coins + amount > MAX_COINS:
        return f"❌ У получателя уже {format_large_number(receiver_coins)} монет! Лимит {MAX_COINS_STR}!"
    
    await remove_coins(sender_id, amount)
    await add_coins(receiver_id, amount)
    
    return f"💰 {await get_name(sender_id)} передал **{amount}** монет {await get_name(receiver_id)}! 🎉"

async def transfer_item(sender_id: int, receiver_id: int, item_name: str, quantity: int = 1) -> str:
    """Передает предмет от одного пользователя другому"""
    if sender_id == receiver_id:
        return "❌ Нельзя передать самому себе!"
    
    if not await has_item(sender_id, item_name):
        return f"❌ У тебя нет {item_name}!"
    
    if await has_item(sender_id, item_name) < quantity:
        return f"❌ У тебя только {await has_item(sender_id, item_name)} {item_name}!"
    
    await remove_item(sender_id, item_name, quantity)
    await add_item(receiver_id, item_name, quantity)
    
    return f"📦 {await get_name(sender_id)} передал {item_name} x{quantity} {await get_name(receiver_id)}!"

