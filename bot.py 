# ============================================================
# КЛАСС УПРАВЛЕНИЯ ПРОФЕССИЯМИ
# ============================================================

class ProfessionManager:
    """УПРАВЛЕНИЕ ПРОФЕССИЯМИ, КАРЬЕРОЙ И СКИЛЛАМИ"""
    
    def __init__(self):
        self.skill_levels = {}
        self.profession_bonuses = {}
        self.work_cooldowns = {}
        self.career_paths = {}
    
    # ============================================================
    # ПОЛУЧЕНИЕ ПРОФЕССИИ
    # ============================================================
    
    async def get_profession(self, user_id: int) -> Optional[str]:
        """ПОЛУЧЕНИЕ ТЕКУЩЕЙ ПРОФЕССИИ"""
        result = await db.query(
            "SELECT profession FROM professions WHERE user_id = ?",
            (user_id,),
            fetch_one=True,
            cache_ttl=30
        )
        return result['profession'] if result else None
    
    async def set_profession(self, user_id: int, profession: str) -> dict:
        """УСТАНОВКА ПРОФЕССИИ"""
        if profession not in PROFESSIONS:
            return {'error': 'Профессия не найдена! Список: список_профессий'}
        
        current = await self.get_profession(user_id)
        if current == profession:
            return {'error': f'Ты уже работаешь {profession}!'}
        
        # Сохраняем профессию
        await db.query(
            "INSERT OR REPLACE INTO professions (user_id, profession) VALUES (?, ?)",
            (user_id, profession)
        )
        
        # Сбрасываем кэш
        self.get_profession.cache_clear()
        
        return {
            'success': True,
            'profession': profession,
            'emoji': PROFESSIONS[profession]['emoji'],
            'desc': PROFESSIONS[profession]['desc']
        }
    
    # ============================================================
    # РАБОТА
    # ============================================================
    
    async def work(self, user_id: int, chat_id: int = 0) -> dict:
        """РАБОТА ПО ПРОФЕССИИ"""
        profession = await self.get_profession(user_id)
        if not profession:
            return {'error': 'У тебя нет профессии! Напиши: устроиться [профессия]'}
        
        if profession not in PROFESSIONS:
            return {'error': 'Профессия не найдена!'}
        
        # Проверяем кулдаун
        last_work = await db.query(
            "SELECT last_work FROM users WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if last_work and last_work['last_work']:
            last_time = datetime.fromisoformat(last_work['last_work'])
            elapsed = (datetime.now() - last_time).seconds
            if elapsed < 30:
                return {'error': f'⏳ Подожди {30 - elapsed} секунд!'}
        
        # Получаем данные профессии
        data = PROFESSIONS[profession]
        base_salary = random.randint(data['min'], data['max'])
        
        # ============================================================
        # РАСЧЁТ БОНУСОВ
        # ============================================================
        
        # 1. Опыт (увеличивает зарплату)
        exp_result = await db.query(
            "SELECT experience, level, work_count FROM professions WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        experience = exp_result['experience'] if exp_result else 0
        level = exp_result['level'] if exp_result else 1
        work_count = exp_result['work_count'] if exp_result else 0
        
        # Бонус за опыт (каждый уровень +5%)
        exp_bonus = 1 + (level - 1) * 0.05
        
        # 2. Скиллы (прокачка)
        skill_bonus = await self.get_skill_bonus(user_id, profession)
        
        # 3. Трудовой стаж (каждые 100 работ +5%)
        seniority_bonus = 1 + (work_count // 100) * 0.05
        
        # 4. Экономический кризис (может уменьшить доход)
        crisis_multiplier = crisis_system.get_multiplier(chat_id) if chat_id else 1.0
        
        # 5. Предметы (увеличивают доход)
        item_bonus = await self.get_work_bonus_items(user_id, profession)
        
        # 6. Премия (случайный бонус)
        bonus_multiplier = 1.0
        bonus_chance = 0.1  # 10% шанс
        if random.random() < bonus_chance:
            bonus_multiplier = random.uniform(1.2, 2.0)
        
        # ИТОГОВАЯ ЗАРПЛАТА
        final_salary = int(
            base_salary * 
            exp_bonus * 
            skill_bonus * 
            seniority_bonus * 
            crisis_multiplier * 
            item_bonus * 
            bonus_multiplier
        )
        
        # Применяем инфляцию
        if chat_id:
            inflation = crisis_system.get_inflation(chat_id)
            final_salary = int(final_salary * (1 + inflation * 0.1))
        
        # Проверяем лимит
        if final_salary > MAX_COINS:
            final_salary = int(MAX_COINS * 0.01)
        
        # Начисляем монеты
        await db.add_coins(user_id, final_salary)
        
        # Обновляем статистку
        await db.query(
            """UPDATE professions SET 
               experience = experience + ?,
               work_count = work_count + 1,
               total_earned = total_earned + ?
               WHERE user_id = ?""",
            (final_salary // 100, final_salary, user_id)
        )
        
        # Проверяем повышение уровня
        new_level = await self.check_level_up(user_id)
        
        # Обновляем кулдаун
        await db.query(
            "UPDATE users SET last_work = ? WHERE user_id = ?",
            (datetime.now().isoformat(), user_id)
        )
        
        return {
            'success': True,
            'profession': profession,
            'emoji': data['emoji'],
            'salary': final_salary,
            'base_salary': base_salary,
            'bonus': bonus_multiplier > 1.0,
            'bonus_multiplier': bonus_multiplier,
            'level': level,
            'new_level': new_level,
            'work_count': work_count + 1,
            'exp_bonus': exp_bonus,
            'skill_bonus': skill_bonus,
            'seniority_bonus': seniority_bonus,
            'crisis_multiplier': crisis_multiplier
        }
    
    # ============================================================
    # СКИЛЛЫ (ПРОКАЧКА)
    # ============================================================
    
    async def get_skills(self, user_id: int) -> List[dict]:
        """ПОЛУЧЕНИЕ СКИЛЛОВ ПОЛЬЗОВАТЕЛЯ"""
        result = await db.query(
            "SELECT * FROM skills WHERE user_id = ?",
            (user_id,),
            fetch_all=True,
            cache_ttl=30
        )
        return result or []
    
    async def upgrade_skill(self, user_id: int, skill: str) -> dict:
        """ПРОКАЧКА СКИЛЛА"""
        if skill not in ['python', 'java', 'sql', 'management', 'analytics', 
                        'design', 'marketing', 'finance', 'leadership', 'sales']:
            return {'error': 'Такой скилл не существует!'}
        
        # Проверяем текущий уровень
        current = await db.query(
            "SELECT * FROM skills WHERE user_id = ? AND skill_name = ?",
            (user_id, skill),
            fetch_one=True
        )
        
        current_level = current['level'] if current else 0
        if current_level >= 10:
            return {'error': f'Скилл {skill} на максимальном уровне (10)!'}
        
        cost = int(100 * (current_level + 1) * 1.5)
        
        # Проверяем деньги
        coins = await db.get_coins(user_id)
        if coins < cost:
            return {'error': f'Недостаточно монет! Нужно {cost}'}
        
        # Снимаем монеты
        await db.add_coins(user_id, -cost)
        
        # Повышаем скилл
        if current:
            await db.query(
                "UPDATE skills SET level = level + 1 WHERE user_id = ? AND skill_name = ?",
                (user_id, skill)
            )
        else:
            await db.query(
                "INSERT INTO skills (user_id, skill_name, level) VALUES (?, ?, 1)",
                (user_id, skill)
            )
        
        return {
            'success': True,
            'skill': skill,
            'new_level': (current_level + 1),
            'cost': cost
        }
    
    async def get_skill_bonus(self, user_id: int, profession: str) -> float:
        """ПОЛУЧЕНИЕ БОНУСА ОТ СКИЛЛОВ"""
        if profession not in PROFESSIONS:
            return 1.0
        
        required_skills = PROFESSIONS[profession].get('skills', [])
        if not required_skills:
            return 1.0
        
        user_skills = await self.get_skills(user_id)
        skill_dict = {s['skill_name']: s['level'] for s in user_skills}
        
        total_bonus = 1.0
        for skill in required_skills:
            level = skill_dict.get(skill, 0)
            # Каждый уровень +2%
            total_bonus += level * 0.02
        
        return total_bonus
    
    async def get_work_bonus_items(self, user_id: int, profession: str) -> float:
        """ПОЛУЧЕНИЕ БОНУСА ОТ ПРЕДМЕТОВ"""
        items = await db.query(
            "SELECT item_name, quantity FROM inventory WHERE user_id = ?",
            (user_id,),
            fetch_all=True
        )
        
        bonus = 1.0
        item_bonuses = {
            'золотая_кирка': 1.5,
            'алмазная_кирка': 2.0,
            'золотая_удочка': 1.5,
            'сеть': 2.0,
            'квантовый_ноутбук': 2.0,
            'нейрочип': 3.0,
            'asic_майнер': 2.0,
            'квантовый_кошелёк': 3.0
        }
        
        for item in items:
            if item['item_name'] in item_bonuses:
                bonus *= item_bonuses[item['item_name']]
        
        return bonus
    
    # ============================================================
    # УРОВНИ И ОПЫТ
    # ============================================================
    
    async def check_level_up(self, user_id: int) -> Optional[int]:
        """ПРОВЕРКА ПОВЫШЕНИЯ УРОВНЯ"""
        exp_result = await db.query(
            "SELECT experience, level FROM professions WHERE user_id = ?",
            (user_id,),
            fetch_one=True
        )
        
        if not exp_result:
            return None
        
        current_exp = exp_result['experience']
        current_level = exp_result['level']
        
        # Опыт для уровня: level * 100
        required_exp = current_level * 100
        
        new_level = current_level
        while current_exp >= required_exp:
            current_exp -= required_exp
            new_level += 1
            required_exp = new_level * 100
        
        if new_level > current_level:
            # Повышаем уровень
            await db.query(
                "UPDATE professions SET level = ?, experience = ? WHERE user_id = ?",
                (new_level, current_exp, user_id)
            )
            
            # Бонус за уровень
            bonus = new_level * 50
            await db.add_coins(user_id, bonus)
            
            return new_level
        
        return None
    
